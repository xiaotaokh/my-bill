<!-- components/custom-dialog/custom-dialog.wxml -->
<view class="dialog-overlay" wx:if="{{visible}}" bindtap="onOverlayTap">
  <view class="dialog-container">
    <view class="dialog-header">
      <text class="dialog-title">{{title}}</text>
      <view class="dialog-close" bindtap="onCancel">×</view>
    </view>
    <view class="dialog-content">
      <slot></slot>
    </view>
    <view class="dialog-footer">
      <button class="btn-cancel" bindtap="onCancel">{{cancelText}}</button>
      <button class="btn-confirm" bindtap="onConfirm">{{okText}}</button>
    </view>
  </view>
</view>