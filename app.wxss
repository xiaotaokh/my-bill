/**app.wxss**/
page {
  background-color: #F6F4F0;
  font-family: -apple-system, 'SF Pro Display', 'PingFang SC', 'Noto Sans SC', sans-serif;

  /* Design Tokens - 温暖极简浅色主题 */
  --primary-700: #5D7D6E;
  --primary-600: #6F8E7E;
  --primary-500: #86A396;
  --primary-400: #A5BBB1;
  --primary-200: #C8D7CF;
  --primary-100: #E2EAE5;
  --primary-soft: #EDF2EF;

  --neutral-900: #2C2B28;
  --neutral-700: #6B6965;
  --neutral-500: #9E9B97;
  --neutral-300: #C8C5C0;
  --neutral-200: #DEDBD6;
  --neutral-100: #EBE8E3;
  --neutral-50: #F0EDE8;

  --bg-base: #F6F4F0;
  --bg-card: #FCFBF9;
  --bg-subtle: #F0EDE8;
  --bg-hover: #EBE8E3;
  --bg-card-rgb: 252, 251, 249;

  --border-default: #E5E2DC;
  --border-light: #EBE8E3;
  --border-focus: #6F8E7E;

  --text-default: #2C2B28;
  --text-muted: #7A7874;
  --text-hint: #A8A5A0;
  --text-inverse: #FFFFFF;

  --success: #6F8E7E;
  --success-bg: #EEF3F0;
  --error: #C4918A;
  --error-bg: #F6EEEC;
  --warning: #C4A99A;
  --warning-bg: #F4EFEC;
  --amber: #9B5C1A;

  --retired: #C8A078;
  --sold: #BE828C;
  --gold: #FBBF24;

  /* 装饰色 - 用于气泡/边框渐变等 */
  --pink: #F472B6;
  --hot-pink: #EC4899;
  --mint: #34D399;
  --emerald: #10B981;
  --warm-yellow: #F59E0B;
  --cream: #FEF3C7;
  --cream-dark: #FDE68A;
  --cream-light: #FEF7E6;
  --cream-mid: #FDE9B8;
  --orange: #FB923C;
  --purple: #A78BFA;
  --sky-blue: #38BDF8;
  --blue: #60A5FA;

  --primary-gradient: linear-gradient(135deg, #6F8E7E 0%, #86A396 100%);
  --accent-color: #6F8E7E;
  --primary-600-rgb: 111, 142, 126;
  --warning-rgb: 196, 169, 154;
  --error-rgb: 196, 145, 138;
  --neutral-900-rgb: 44, 43, 40;
  --shadow-rgb: 160, 150, 140;
  --text-inverse-rgb: 255, 255, 255;
  --retired-rgb: 200, 160, 120;
  --sold-rgb: 190, 130, 140;
  --gold-rgb: 251, 191, 36;
  --glass-bg: rgba(var(--bg-card-rgb), 0.92);
  --glass-border: rgba(var(--neutral-900-rgb), 0.04);
  --shadow-soft: 0 8rpx 32rpx rgba(var(--shadow-rgb), 0.08);
  --shadow-card: 0 4rpx 16rpx rgba(var(--shadow-rgb), 0.06);
  --shadow-neumorph: -3rpx -3rpx 8rpx rgba(var(--text-inverse-rgb), 0.6), 3rpx 3rpx 10rpx rgba(var(--shadow-rgb), 0.06);
  --shadow-neumorph-sm: -2rpx -2rpx 6rpx rgba(var(--text-inverse-rgb), 0.5), 2rpx 2rpx 6rpx rgba(var(--shadow-rgb), 0.04);
}
