/* asset-list.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 筛选栏 */
.filter-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.status-filter {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.status-item {
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f0f0f0;
  transition: all 0.2s;
}

.status-item.active {
  background-color: #07c160;
  color: #fff;
}

.sort-bar {
  display: flex;
  align-items: center;
}

.sort-picker {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #333;
  padding: 10rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

.sort-icon {
  font-size: 20rpx;
  color: #999;
  transition: transform 0.2s;
}

.sort-icon.desc {
  transform: rotate(180deg);
}

.sort-icon.asc {
  transform: rotate(0deg);
}

/* 资产列表 */
.asset-list {
  padding: 20rpx 30rpx;
}

.asset-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.asset-avatar {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 2rpx solid #e5e7eb;
}

.avatar-icon {
  font-size: inherit;
  line-height: 1;
}

.asset-content {
  flex: 1;
  min-width: 0;
}

.asset-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.asset-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.asset-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.asset-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.asset-status.status-active {
  background-color: #e6f7ed;
  color: #07c160;
}

.asset-status.status-retired {
  background-color: #fff7e6;
  color: #fa8c16;
}

.asset-status.status-sold {
  background-color: #f0f0f0;
  color: #999;
}

.asset-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  font-size: 26rpx;
}

.info-row .label {
  color: #999;
  min-width: 140rpx;
}

.info-row .value {
  color: #333;
}

.info-row .value.price {
  color: #ff4d4f;
  font-weight: 500;
}

.asset-extra {
  display: flex;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.extra-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.extra-label {
  font-size: 22rpx;
  color: #999;
}

.extra-value {
  font-size: 26rpx;
  color: #333;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state .add-btn {
  margin-top: 30rpx;
  padding: 20rpx 60rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 浮动添加按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.fab text {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
}