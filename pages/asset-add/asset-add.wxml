<!--asset-add.wxml-->
<view class="container">
  <form bindsubmit="onSubmit" class="form">
    <!-- 资产类型选择 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">资产类型</text>
      </view>
      <view class="asset-type-selector">
        <view class="type-option {{assetType === 'fixed' ? 'selected' : ''}}"
              bindtap="onAssetTypeChange" data-type="fixed">
          <text class="type-icon">💰</text>
          <text class="type-label">普通资产</text>
        </view>
        <view class="type-option {{assetType === 'subscription' ? 'selected' : ''}}"
              bindtap="onAssetTypeChange" data-type="subscription">
          <text class="type-icon">🔄</text>
          <text class="type-label">订阅资产</text>
        </view>
      </view>
    </view>

    <!-- 物品名称 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">基本信息</text>
      </view>
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>物品名称</text>
        </view>
        <input
          class="item-input"
          name="name"
          placeholder="请输入物品名称"
          placeholder-class="input-placeholder"
          maxlength="50"
          value="{{name}}"
          bindinput="onNameInput"
        />
      </view>

      <!-- 价格（普通资产） -->
      <view class="form-item" wx:if="{{assetType === 'fixed'}}">
        <view class="item-label">
          <text class="required">*</text>
          <text>价格</text>
        </view>
        <input
          class="item-input"
          type="digit"
          name="price"
          placeholder="请输入价格"
          placeholder-class="input-placeholder"
          value="{{price}}"
          bindinput="onPriceInput"
        />
      </view>

      <!-- 购买日期 -->
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>{{assetType === 'subscription' ? '订阅日期' : '购买日期'}}</text>
        </view>
        <picker
          mode="date"
          bindchange="onDateChange"
          value="{{purchaseDate}}"
          class="item-picker"
        >
          <view class="picker-content">
            <text class="picker-value">{{purchaseDate || '请选择日期'}}</text>
            <text class="picker-icon">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 订阅设置（订阅资产专用） -->
    <view class="form-group" wx:if="{{assetType === 'subscription'}}">
      <view class="form-header">
        <text class="form-title">订阅设置</text>
      </view>
      <!-- 每期金额 -->
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>每期金额</text>
        </view>
        <input
          class="item-input"
          type="digit"
          name="periodAmount"
          placeholder="请输入每期金额"
          placeholder-class="input-placeholder"
          value="{{periodAmount}}"
          bindinput="onPeriodAmountInput"
        />
      </view>

      <!-- 周期类型 -->
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>周期类型</text>
        </view>
        <picker
          mode="selector"
          range="{{periodTypeOptions}}"
          value="{{periodTypeIndex}}"
          bindchange="onPeriodTypeChange"
          class="item-picker"
        >
          <view class="picker-content">
            <text class="picker-value">{{periodTypeOptions[periodTypeIndex]}}</text>
            <text class="picker-icon">›</text>
          </view>
        </picker>
      </view>

      <!-- 周期天数（自定义周期） -->
      <view class="form-item" wx:if="{{periodType === 'custom'}}">
        <view class="item-label">
          <text class="required">*</text>
          <text>周期天数</text>
        </view>
        <input
          class="item-input"
          type="number"
          name="periodDays"
          placeholder="请输入周期天数(1-365)"
          placeholder-class="input-placeholder"
          value="{{periodDays}}"
          bindinput="onPeriodDaysInput"
        />
      </view>

      <!-- 结束订阅（编辑模式） -->
      <view class="form-item" wx:if="{{isEdit}}">
        <view class="item-label">
          <text>结束订阅</text>
        </view>
        <switch
          checked="{{endSubscription}}"
          bindchange="onEndSubscriptionChange"
          color="#f44336"
        />
      </view>

      <!-- 订阅结束日期 -->
      <view class="form-item" wx:if="{{endSubscription || subscriptionEndDate}}">
        <view class="item-label">
          <text>结束日期</text>
        </view>
        <picker
          mode="date"
          bindchange="onSubscriptionEndDateChange"
          value="{{subscriptionEndDate}}"
          class="item-picker"
        >
          <view class="picker-content">
            <text class="picker-value">{{subscriptionEndDate || '请选择结束日期'}}</text>
            <text class="picker-icon">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 待订阅设置 -->
    <view class="form-group" wx:if="{{assetType === 'subscription' && !isEdit}}">
      <view class="form-header">
        <text class="form-title">其他</text>
      </view>
      <view class="switch-list">
        <view class="switch-item">
          <text class="switch-label">待订阅</text>
          <switch
            checked="{{pendingSubscription}}"
            bindchange="onPendingSubscriptionChange"
            color="#6366f1"
          />
        </view>
        <!-- 订阅开始日期（待订阅开关打开时显示） -->
        <view class="retired-date-wrapper" wx:if="{{pendingSubscription}}">
          <view class="retired-date-item">
            <view class="item-label">
              <text class="required">*</text>
              <text>开始日期</text>
            </view>
            <picker
              mode="date"
              bindchange="onSubscriptionStartDateChange"
              value="{{subscriptionStartDate}}"
              class="item-picker"
            >
              <view class="picker-content">
                <text class="picker-value">{{subscriptionStartDate || '请选择开始日期'}}</text>
                <text class="picker-icon">›</text>
              </view>
            </picker>
          </view>
        </view>
        <view class="switch-item">
          <text class="switch-label">不计入总资产</text>
          <switch
            checked="{{excludeTotal}}"
            bindchange="onExcludeTotalChange"
            color="#6366f1"
          />
        </view>
        <view class="switch-item">
          <text class="switch-label">不计入总日均</text>
          <switch
            checked="{{excludeDaily}}"
            bindchange="onExcludeDailyChange"
            color="#6366f1"
          />
        </view>
      </view>
    </view>

    <!-- 缩略图选择 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">选择缩略图</text>
      </view>
      <view class="icon-selector">
        <!-- 内置图标分组选择 -->
        <view class="icon-groups-container">
          <view wx:for="{{builtinIconGroups}}" wx:key="name" wx:for-item="group" wx:for-index="idx">
            <!-- 分组标题 -->
            <view class="group-title {{idx === 0 ? 'first' : ''}}">{{group.name}}</view>
            <!-- 分组图标列表 -->
            <view class="group-icons">
              <view class="group-icon-item {{selectedGroupName === group.name && selectedIconIndex === index ? 'selected' : ''}}"
                    wx:for="{{group.icons}}"
                    wx:key="name"
                    bindtap="selectBuiltinIcon"
                    data-icon="{{item}}"
                    data-group-name="{{group.name}}"
                    data-icon-idx="{{index}}">
                <text class="icon-emoji">{{item.icon}}</text>
                <text class="icon-name">{{item.name}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 上传组件 -->
        <view class="upload-area-large" bindtap="chooseIcon">
          <text class="upload-icon-large">📷</text>
          <text class="upload-text-large">上传自定义缩略图</text>
          <text class="upload-desc-large">支持jpg/png/webp/svg格式，不超过2M</text>
        </view>

        <!-- 用户上传的缩略图预览区域 -->
        <view class="uploaded-preview-area" wx:if="{{uploadedImagePath}}">
          <view class="image-container">
            <image class="uploaded-preview-image" src="{{uploadedImagePath}}" mode="aspectFill"></image>
            <view class="remove-upload" bindtap="removeUploadedImage">✕</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 类别选择 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">分类</text>
      </view>
      <view class="category-grid">
        <view
          class="category-item {{item.selected ? 'selected' : ''}}"
          wx:for="{{categories}}"
          wx:key="name"
          bindtap="toggleCategory"
          data-category="{{item.name}}"
          data-index="{{index}}"
        >
          <!-- 单选圆点样式 -->
          <view class="radio-dot {{item.selected ? 'checked' : ''}}">
            <view class="radio-inner" wx:if="{{item.selected}}"></view>
          </view>
          <!-- 显示类别图标：支持自定义图片和emoji -->
          <view class="category-icon-wrap">
            <image wx:if="{{item.displayIcon}}" src="{{item.displayIcon}}" mode="aspectFit" class="category-icon-img"></image>
            <text wx:else class="category-icon">{{item.icon || '🏷️'}}</text>
          </view>
          <text class="category-name">{{item.name}}</text>
        </view>

        <!-- 空状态 -->
        <view class="category-empty" wx:if="{{categories.length === 0}}">
          <text class="empty-icon">📦</text>
          <text class="empty-text">暂无类别</text>
        </view>
      </view>
      <view class="category-error" wx:if="{{errors.category}}">
        <text>{{errors.category}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">备注</text>
      </view>
      <view class="form-item">
        <textarea
          class="item-textarea"
          name="remark"
          placeholder="请输入备注信息（可选）"
          placeholder-class="textarea-placeholder"
          maxlength="200"
          value="{{remark}}"
          bindinput="onRemarkInput"
        />
        <text class="char-count">{{remark.length}}/200</text>
      </view>
    </view>

    <!-- 选项开关（普通资产专用） -->
    <view class="form-group" wx:if="{{assetType === 'fixed'}}">
      <view class="form-header">
        <text class="form-title">其他</text>
      </view>
      <!-- 提示信息 -->
      <view class="notice-tip" wx:if="{{isRetired || isSold}}">
        <text class="notice-icon">💡</text>
        <text class="notice-text">已退役或已卖出的资产不计入总日均成本统计，关闭后默认开启计入总日均</text>
      </view>
      <view class="switch-list">
        <view class="switch-item">
          <text class="switch-label">已退役</text>
          <switch
            checked="{{isRetired}}"
            bindchange="onRetiredChange"
            color="#10b981"
          />
        </view>
        <!-- 退役日期选择器 -->
        <view class="retired-date-wrapper" wx:if="{{isRetired}}">
          <view class="retired-date-item">
            <view class="item-label">
              <text class="required">*</text>
              <text>退役日期</text>
            </view>
            <picker
              mode="date"
              bindchange="onRetiredDateChange"
              value="{{retiredDate}}"
              class="item-picker"
            >
              <view class="picker-content">
                <text class="picker-value">{{retiredDate || '请选择退役日期'}}</text>
                <text class="picker-icon">›</text>
              </view>
            </picker>
          </view>
        </view>
        <view class="switch-item">
          <text class="switch-label">已卖出</text>
          <switch
            checked="{{isSold}}"
            bindchange="onSoldChange"
            color="#f59e0b"
          />
        </view>
        <!-- 卖出日期选择器 -->
        <view class="retired-date-wrapper" wx:if="{{isSold}}">
          <view class="retired-date-item">
            <view class="item-label">
              <text class="required">*</text>
              <text>卖出日期</text>
            </view>
            <picker
              mode="date"
              bindchange="onSoldDateChange"
              value="{{soldDate}}"
              class="item-picker"
            >
              <view class="picker-content">
                <text class="picker-value">{{soldDate || '请选择卖出日期'}}</text>
                <text class="picker-icon">›</text>
              </view>
            </picker>
          </view>
        </view>
        <view class="switch-item">
          <text class="switch-label">不计入总资产</text>
          <switch
            checked="{{excludeTotal}}"
            bindchange="onExcludeTotalChange"
            color="#6366f1"
          />
        </view>
        <view class="switch-item">
          <text class="switch-label">不计入总日均</text>
          <switch
            checked="{{excludeDaily}}"
            bindchange="onExcludeDailyChange"
            color="#6366f1"
            disabled="{{isRetired || isSold}}"
          />
        </view>
      </view>
    </view>

    <!-- 占位空间，防止内容被底部按钮遮挡 -->
    <view class="form-spacer" style="height: 140rpx;"></view>
  </form>

  <!-- fixed 悬浮保存按钮 -->
  <view class="submit-bar">
    <view class="submit-btn" bindtap="onSubmit">
      <text class="submit-text">保存资产</text>
    </view>
  </view>
</view>
