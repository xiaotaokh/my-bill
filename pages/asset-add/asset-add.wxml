<!--asset-add.wxml-->
<view class="container">
  <form bindsubmit="onSubmit" class="form">
    <!-- 物品名称 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">基本信息</text>
      </view>
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>物品名称</text>
        </view>
        <input
          class="item-input"
          name="name"
          placeholder="请输入物品名称"
          maxlength="50"
          value="{{name}}"
          bindinput="onNameInput"
        />
      </view>

      <!-- 价格 -->
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>价格</text>
        </view>
        <input
          class="item-input"
          type="number"
          name="price"
          placeholder="请输入价格"
          value="{{price}}"
          bindinput="onPriceInput"
        />
      </view>

      <!-- 购买日期 -->
      <view class="form-item">
        <view class="item-label">
          <text class="required">*</text>
          <text>购买日期</text>
        </view>
        <picker
          mode="date"
          bindchange="onDateChange"
          value="{{purchaseDate}}"
          class="item-picker"
        >
          <view class="picker-content">
            <text class="picker-value">{{purchaseDate || '请选择购买日期'}}</text>
            <text class="picker-icon">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 类别选择 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">选择类别</text>
        <view class="category-action" bindtap="addCategory">
          <text class="action-icon">+</text>
          <text class="action-text">新增</text>
        </view>
      </view>
      <view class="category-grid">
        <view
          class="category-item {{item.selected ? 'selected' : ''}}"
          wx:for="{{categories}}"
          wx:key="name"
          bindtap="toggleCategory"
          data-index="{{index}}"
        >
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text class="check-mark">✓</text>
          </view>
          <text class="category-name">{{item.name}}</text>
        </view>

        <!-- 空状态 -->
        <view class="category-empty" wx:if="{{categories.length === 0}}">
          <text class="empty-icon">📦</text>
          <text class="empty-text">暂无类别，点击右上角新增</text>
        </view>
      </view>
      <view class="category-error" wx:if="{{errors.category}}">
        <text>{{errors.category}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">备注</text>
      </view>
      <view class="form-item">
        <textarea
          class="item-textarea"
          name="remark"
          placeholder="请输入备注信息（可选）"
          placeholder-class="textarea-placeholder"
          maxlength="200"
          value="{{remark}}"
          bindinput="onRemarkInput"
        />
        <text class="char-count">{{remark.length}}/200</text>
      </view>
    </view>

    <!-- 选项开关 -->
    <view class="form-group">
      <view class="form-header">
        <text class="form-title">其他</text>
      </view>
      <view class="switch-list">
        <view class="switch-item">
          <text class="switch-label">已退役</text>
          <switch
            checked="{{isRetired}}"
            bindchange="onRetiredChange"
            color="#10b981"
          />
        </view>
        <view class="switch-item">
          <text class="switch-label">已卖出</text>
          <switch
            checked="{{isSold}}"
            bindchange="onSoldChange"
            color="#f59e0b"
          />
        </view>
        <view class="switch-item">
          <text class="switch-label">不计入总资产</text>
          <switch
            checked="{{excludeTotal}}"
            bindchange="onExcludeTotalChange"
            color="#6366f1"
          />
        </view>
        <view class="switch-item">
          <text class="switch-label">不计入日均</text>
          <switch
            checked="{{excludeDaily}}"
            bindchange="onExcludeDailyChange"
            color="#6366f1"
          />
        </view>
      </view>
    </view>

    <!-- 占位空间，防止内容被底部按钮遮挡 -->
    <view class="form-spacer" style="height: 140rpx;"></view>
  </form>

  <!-- fixed 悬浮保存按钮 -->
  <view class="submit-bar">
    <button class="submit-btn" bindtap="onSubmit">保存资产</button>
  </view>
</view>
