/* asset-add.wxss */

/* ========== 设计主题：蓝紫渐变 × 呼吸感 ==========
   配色方案：
   - 主渐变：青蓝 → 紫罗兰 → 玫红
   - 辅渐变：青翠绿 → 湖蓝
   - 背景：柔和的蓝紫渐变
   ============================================== */

/* 容器 - 柔和渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg,
    #f0f4ff 0%,
    #faf5ff 50%,
    #fdf4ff 100%);
  padding-bottom: 180rpx;
}

.form {
  padding: 32rpx;
}

/* 表单组 - 玻璃态卡片 */
.form-group {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow:
    0 8rpx 32rpx rgba(139, 92, 246, 0.1),
    0 0 0 1rpx rgba(255, 255, 255, 0.5) inset;
  border: 1rpx solid rgba(139, 92, 246, 0.1);
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(139, 92, 246, 0.1);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg,
    #3b82f6 0%,
    #8b5cf6 50%,
    #d946ef 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 1rpx;
}

/* 类别新增按钮 - 渐变胶囊 */
.category-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg,
    #06b6d4 0%,
    #3b82f6 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.35);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

.action-icon {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.action-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 表单项 - 宽松布局 */
.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #5f6368;
  margin-bottom: 20rpx;
}

.required {
  color: #ec4899;
  font-size: 32rpx;
  font-weight: bold;
  animation: heartbeat 1.5s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

/* 输入框 - 玻璃态 */
.item-input,
.item-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.8) 0%,
    rgba(240, 244, 255, 0.6) 100%);
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #374151;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.item-input:focus,
.item-textarea:focus {
  background: #fff;
  border-color: #8b5cf6;
  box-shadow:
    0 0 0 4rpx rgba(139, 92, 246, 0.1),
    0 8rpx 24rpx rgba(139, 92, 246, 0.15);
  transform: translateY(-2rpx);
}

.item-input {
  min-height: 96rpx;
}

.item-textarea {
  min-height: 220rpx;
  resize: none;
  line-height: 1.7;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 16rpx;
  font-weight: 500;
}

/* 选择器 - 渐变边框 */
.item-picker {
  width: 100%;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.9) 0%,
    rgba(240, 244, 255, 0.7) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.2);
  transition: all 0.3s ease;
}

.picker-content:active {
  background: #fff;
  border-color: #8b5cf6;
}

.picker-value {
  font-size: 30rpx;
  color: #4b5563;
  font-weight: 500;
}

.picker-icon {
  font-size: 44rpx;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6, #d946ef);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
}

/* 类别网格 - 呼吸感布局 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx 20rpx;
  background: linear-gradient(180deg,
    rgba(255, 255, 255, 0.9) 0%,
    rgba(240, 244, 255, 0.6) 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.15);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.category-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg,
    #3b82f6 0%,
    #8b5cf6 50%,
    #d946ef 100%);
  opacity: 0;
  transition: opacity 0.4s ease;
}

.category-item.selected::before {
  opacity: 1;
}

.category-item:active {
  transform: scale(0.95);
}

.category-item.selected {
  transform: scale(1.05);
  border-color: transparent;
  box-shadow:
    0 12rpx 40rpx rgba(139, 92, 246, 0.4),
    0 0 20rpx rgba(217, 70, 239, 0.2);
}

.category-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,
    #dbeafe 0%,
    #ddd6fe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  z-index: 1;
  transition: all 0.4s ease;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.2);
}

.category-item.selected .category-icon {
  background: #fff;
  box-shadow:
    0 4rpx 16rpx rgba(255, 255, 255, 0.4),
    0 0 0 3rpx rgba(255, 255, 255, 0.2);
}

.category-icon text {
  font-size: 30rpx;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6, #d946ef);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: bold;
}

.category-item.selected .category-icon text {
  background: linear-gradient(135deg, #10b981, #34d399);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.category-name {
  font-size: 26rpx;
  color: #6b7280;
  z-index: 1;
  transition: all 0.4s ease;
  text-align: center;
  font-weight: 500;
}

.category-item.selected .category-name {
  color: #fff;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(139, 92, 246, 0.3);
}

.category-empty {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #9ca3af;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  font-weight: 500;
}

.category-error {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg,
    rgba(225, 225, 255, 0.8) 0%,
    rgba(233, 213, 255, 0.6) 100%);
  border-radius: 16rpx;
  border-left: 4rpx solid #8b5cf6;
  backdrop-filter: blur(10rpx);
}

.category-error text {
  font-size: 24rpx;
  color: #7c3aed;
  font-weight: 500;
}

/* 开关列表 - 卡片式 */
.switch-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.9) 0%,
    rgba(248, 250, 252, 0.7) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s ease;
}

.switch-item:active {
  background: #fff;
  transform: scale(0.98);
}

.switch-label {
  font-size: 30rpx;
  color: #4b5563;
  font-weight: 500;
}

/* 占位 */
.form-spacer {
  height: 40rpx;
}

/* 悬浮提交栏 - 渐变光晕 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg,
    transparent 0%,
    rgba(255, 255, 255, 0.85) 60%,
    rgba(255, 255, 255, 0.95) 100%);
  backdrop-filter: blur(24rpx);
  z-index: 100;
  box-shadow: 0 -8rpx 32rpx rgba(139, 92, 246, 0.06);
}

.submit-btn {
  width: 100%;
  height: 108rpx;
  background: linear-gradient(135deg,
    #3b82f6 0%,
    #6366f1 30%,
    #8b5cf6 70%,
    #a855f7 100%);
  background-size: 200% 100%;
  border-radius: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow:
    0 12rpx 40rpx rgba(139, 92, 246, 0.45),
    0 0 60rpx rgba(99, 102, 241, 0.3);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.submit-btn:active {
  transform: scale(0.96);
  box-shadow:
    0 6rpx 24rpx rgba(139, 92, 246, 0.35),
    0 0 30rpx rgba(99, 102, 241, 0.2);
}

.btn-icon {
  font-size: 38rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.btn-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1.5rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.submit-btn:after {
  border: none;
}

/* 进入动画 - 更流畅的阶梯式 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.form-group {
  animation: fadeInUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  opacity: 0;
}

.form-group:nth-child(1) { animation-delay: 0s; }
.form-group:nth-child(2) { animation-delay: 0.1s; }
.form-group:nth-child(3) { animation-delay: 0.2s; }
.form-group:nth-child(4) { animation-delay: 0.3s; }

/* 光晕装饰 */
.container::before {
  content: '';
  position: fixed;
  top: -20%;
  right: -10%;
  width: 60%;
  height: 60%;
  background: radial-gradient(circle,
    rgba(139, 92, 246, 0.08) 0%,
    transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.container::after {
  content: '';
  position: fixed;
  bottom: -20%;
  left: -10%;
  width: 60%;
  height: 60%;
  background: radial-gradient(circle,
    rgba(59, 130, 246, 0.06) 0%,
    transparent 70%);
  pointer-events: none;
  z-index: 0;
}
