/* asset-add.wxss - 温暖极简浅色主题 */

/* 容器 - 中性背景 */
.container {
  min-height: 100vh;
  background: var(--bg-base);
  padding: 24rpx;
  box-sizing: border-box;
}

.form {
  padding: 0;
}

/* 表单组 - 白色卡片 */
.form-group {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(var(--shadow-rgb), 0.06);
  border: 1rpx solid var(--border-default);
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-default);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-default);
  letter-spacing: 1rpx;
}

.icon-groups-toggle-all {
  flex-shrink: 0;
  padding: 0rpx 0 8rpx 20rpx;
}

.icon-groups-toggle-all:active {
  opacity: 0.65;
}

.icon-groups-toggle-all text {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--text-default);
}

/* 表单项 */
.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 20rpx;
}

.required {
  color: var(--error);
  font-size: 32rpx;
  font-weight: bold;
}

/* 输入框 */
.item-input,
.item-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--text-default);
  box-sizing: border-box;
  border: 1rpx solid var(--border-default);
  transition: none;
}

.input-placeholder {
  font-size: 26rpx;
  color: var(--text-hint);
  padding-left: 4rpx;
}

.item-input:focus,
.item-textarea:focus {
  background: var(--bg-card);
  border-color: var(--border-focus);
}

.item-input {
  min-height: 96rpx;
}

.item-textarea {
  min-height: 220rpx;
  resize: none;
  text-indent: 8rpx;
}

.textarea-placeholder {
  font-size: 26rpx;
  color: var(--text-hint);
  padding-left: 4rpx;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-hint);
  margin-top: 16rpx;
  font-weight: 500;
}

/* 选择器 */
.item-picker {
  width: 100%;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-default);
  transition: none;
}

.picker-content:active {
  background: var(--bg-subtle);
  border-color: var(--border-default);
}

.picker-value {
  font-size: 30rpx;
  color: var(--text-default);
  font-weight: 500;
}

.picker-icon {
  font-size: 44rpx;
  color: var(--text-muted);
  font-weight: bold;
}

/* 类别网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  width: 100%;
}

.category-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  min-width: 0;
  padding: 18rpx 14rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-default);
  transition: all 0.2s ease;
  position: relative;
}

.category-item:active {
  transform: scale(0.96);
}

/* 选中状态 */
.category-item.selected {
  border-color: var(--primary-600);
  background: var(--bg-subtle);
}

/* 单选圆点样式 */
.radio-dot {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-default);
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.category-item.selected .radio-dot {
  border-color: var(--primary-600);
}

.radio-dot.checked .radio-inner {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary-600);
}

.category-name {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: left;
  font-weight: 500;
  line-height: 1.2;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.category-icon {
  font-size: 28rpx;
  line-height: 1;
  width: 100%;
  text-align: center;
}

/* 自定义图片图标的容器 */
.category-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

/* 自定义图片图标的样式 */
.category-icon-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.category-item.selected .category-name {
  color: var(--primary-600);
  font-weight: 600;
}

.category-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  grid-column: 1 / -1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-hint);
  font-weight: 400;
}

.category-error {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: var(--error-bg);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--error);
}

.category-error text {
  font-size: 24rpx;
  color: var(--error);
  font-weight: 500;
}

/* 开关列表 */
.switch-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.switch-list-margin {
  margin-bottom: 24rpx;
}

/* 提示信息 */
.notice-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: var(--warning-bg);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--warning);
}

.notice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 24rpx;
  color: var(--warning);
  line-height: 1.4;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-default);
  transition: none;
}

.switch-item:active {
  background: var(--bg-subtle);
  transform: none;
}

.switch-label {
  font-size: 30rpx;
  color: var(--text-default);
  font-weight: 500;
}

/* 开关颜色 - 使用全局变量 */
.switch-primary {
  color: var(--primary-600);
}

.switch-warning {
  color: var(--warning);
}

.switch-error {
  color: var(--error);
}

/* 退役日期容器 */
.retired-date-wrapper {
  background: var(--success-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid var(--success);
}

.retired-date-item {
  width: 100%;
}

.retired-date-item .item-label {
  margin-bottom: 16rpx;
}

/* 图标选择样式 */
.icon-selector {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* 图标分组容器 */
.icon-groups-container {
  overflow-y: auto;
  max-height: 800rpx;
  padding: 16rpx;
  background: transparent;
  border-radius: 12rpx;
}

/* 分组标题 */
.group-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-default);
  margin-top: 24rpx;
  margin-bottom: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border-default);
}

.group-title.first {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}

.group-title-text {
  min-width: 0;
  flex: 1;
}

.group-toggle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: transparent;
  border: none;
}

.group-toggle-btn:active {
  opacity: 0.65;
}

.group-toggle-icon {
  display: block;
  font-size: 34rpx;
  color: var(--text-muted);
  line-height: 36rpx;
  height: 36rpx;
  text-align: center;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
}

.group-toggle-icon.collapsed {
  transform: rotate(0deg);
}

/* 分组图标列表 */
.group-icons {
  display: flex;
  flex-wrap: wrap;
}

/* 单个图标项 */
.group-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 6rpx;
  border-radius: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
  transition: all 0.2s ease;
  width: 19%;
  margin-right: 1.25%;
  margin-bottom: 8rpx;
  box-sizing: border-box;
}

/* 每行第5个去掉右边距 */
.group-icon-item:nth-child(5n) {
  margin-right: 0;
}

.group-icon-item:active {
  transform: scale(0.95);
}

.group-icon-item.selected {
  border-color: var(--primary-600);
  background: var(--bg-subtle);
}

.icon-emoji {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.icon-name {
  font-size: 18rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.3;
  word-break: break-all;
}

.group-icon-item.selected .icon-name {
  color: var(--primary-600);
  font-weight: 600;
}

/* 旧的内置图标样式（保留兼容） */
.builtin-icons-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 20rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.builtin-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
  transition: all 0.2s ease;
  min-width: 80rpx;
}

.builtin-icon-item:active {
  transform: scale(0.95);
  border-color: var(--border-focus);
  background: var(--bg-subtle);
}

.builtin-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.builtin-icon-name {
  font-size: 20rpx;
  color: var(--text-muted);
}

.builtin-icon-item.selected {
  border-color: var(--primary-600);
  background: var(--bg-subtle);
}

.builtin-icon-item.selected .builtin-icon-name {
  color: var(--primary-600);
  font-weight: 600;
}

.current-icon-display {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.selected-icon-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border: 1rpx solid var(--border-default);
  border-radius: 12rpx;
  background: var(--bg-card);
  flex: 1;
}

.selected-icon-text {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.selected-icon-name {
  font-size: 24rpx;
  color: var(--text-muted);
}

.uploaded-preview-area {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  margin-top: 20rpx;
  width: 100%;
  max-width: 100%;
}

.image-container {
  position: relative;
  display: inline-block;
}

.uploaded-preview-image {
  width: 200rpx;
  height: 200rpx;
  max-width: 100%;
  border-radius: 12rpx;
  object-fit: cover;
  margin-bottom: 15rpx;
  border: 1rpx solid var(--border-default);
}

.remove-upload {
  position: absolute;
  top: -18rpx;
  right: -18rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--error);
  color: var(--text-inverse);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  box-shadow: 0 2rpx 8rpx rgba(var(--error-rgb), 0.3);
  z-index: 10;
  transition: all 0.2s ease;
}

.remove-upload:hover {
  transform: scale(1.1);
}

.upload-area-large {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  border: 1rpx dashed var(--border-default);
  border-radius: 12rpx;
  background: var(--bg-subtle);
  transition: all 0.2s ease;
  cursor: pointer;
}

.upload-area-large:active {
  background: var(--bg-card);
  border-color: var(--border-focus);
  transform: scale(0.98);
}

.upload-icon-large {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text-large {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-default);
  margin-bottom: 8rpx;
}

.upload-desc-large {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  justify-content: center;
  padding: 10rpx;
  border-radius: 60rpx;
  background: linear-gradient(
    135deg,
    rgba(var(--bg-card-rgb), 0.18) 0%,
    rgba(var(--bg-card-rgb), 0.06) 100%
  );
  border: 1rpx solid rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.24);
  box-shadow:
    0 24rpx 56rpx rgba(var(--neutral-900-rgb), 0.14),
    0 8rpx 18rpx rgba(var(--neutral-900-rgb), 0.06),
    inset 0 1rpx 0 rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.36),
    inset 0 -1rpx 0 rgba(var(--neutral-900-rgb), 0.03);
  -webkit-backdrop-filter: blur(42rpx) saturate(200%);
  backdrop-filter: blur(42rpx) saturate(200%);
  z-index: 100;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 60rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-700);
  box-shadow: none;
  padding: 16rpx 34rpx;
  margin: 0 auto;
  transition: transform 0.2s ease, background 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.96);
  background: rgba(var(--bg-card-rgb), 0.08);
}

.submit-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-700);
  letter-spacing: 1rpx;
}

.submit-btn::after {
  border: none;
}

/* 资产类型选择器 */
.asset-type-selector {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.type-option {
  flex: 1;
  position: relative;
  border-radius: 14rpx;
  background: var(--bg-card);
  border: 1rpx solid transparent;
  box-shadow: 0 0 0 1rpx var(--border-default);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.type-option:active {
  transform: scale(0.97);
}

.type-option.selected {
  box-shadow: 0 0 0 1.5rpx var(--primary-600), 0 4rpx 16rpx rgba(var(--primary-600-rgb, 79, 70, 229), 0.12);
}

/* 选中时背景装饰光晕 */
.type-option::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -40%;
  width: 80%;
  height: 80%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(var(--primary-600-rgb, 79, 70, 229), 0.04) 0%, transparent 70%);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
  pointer-events: none;
}

.type-option.selected::after {
  opacity: 1;
  transform: translate(-10%, -10%);
}

.type-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 14rpx 16rpx;
  position: relative;
  z-index: 1;
}

.type-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(var(--shadow-rgb), 0.04);
}

.type-option.selected .type-icon-wrap {
  background: var(--bg-subtle);
  border-color: var(--primary-200, rgba(79, 70, 229, 0.2));
  box-shadow: 0 4rpx 12rpx rgba(var(--primary-600-rgb, 79, 70, 229), 0.08);
}

.type-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.type-text-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.type-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-default);
  transition: color 0.2s ease;
  letter-spacing: 0.5rpx;
}

.type-option.selected .type-label {
  color: var(--primary-600);
}

.type-desc {
  font-size: 20rpx;
  color: var(--text-hint);
  font-weight: 400;
  letter-spacing: 0.3rpx;
  transition: color 0.2s ease;
}

.type-option.selected .type-desc {
  color: var(--text-muted);
}

/* 选中勾选标记 */
.type-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border-default);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
  transform: scale(0.5);
}

.type-check.checked {
  opacity: 1;
  transform: scale(1);
  background: var(--primary-600);
  box-shadow: 0 2rpx 8rpx rgba(var(--primary-600-rgb, 79, 70, 229), 0.3);
}

.check-symbol {
  font-size: 14rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

/* ========== 自定义emoji相关样式 ========== */

/* 自定义图标区域：左右分布 */
.custom-icon-row {
  display: flex;
  gap: 20rpx;
}

/* 上传图片区域 */
.upload-box-asset {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  border: 1rpx dashed var(--border-default);
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.upload-box-asset:active {
  background: transparent;
  border-color: var(--border-focus);
}

.upload-box-asset.has-image {
  padding: 24rpx;
  border-style: solid;
  border-color: var(--primary-600);
}

/* emoji输入区域 */
.emoji-input-box-asset {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  border: 1rpx dashed var(--border-default);
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.emoji-input-box-asset:active {
  background: transparent;
  border-color: var(--border-focus);
}

.emoji-input-box-asset.has-emoji {
  padding: 24rpx;
  border-style: solid;
  border-color: var(--primary-600);
}

/* 右上角删除按钮 */
.delete-corner-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--error);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-inverse);
  z-index: 10;
}

.delete-corner-btn:active {
  opacity: 0.8;
  transform: scale(0.9);
}

/* 上传图片占位符 */
.upload-placeholder-asset {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.upload-icon-asset {
  font-size: 48rpx;
}

.upload-text-asset {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-default);
}

.upload-hint-asset {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 上传图片预览 */
.upload-preview-asset {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-img-asset {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.image-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.loading-spinner {
  font-size: 32rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* emoji占位符 */
.emoji-placeholder-asset {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.emoji-icon-asset {
  font-size: 48rpx;
}

.emoji-text-asset {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-default);
}

.emoji-hint-asset {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* emoji预览 */
.emoji-preview-asset {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.preview-emoji-asset {
  font-size: 48rpx;
}

/* ========== Emoji输入弹窗样式 ========== */

.emoji-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(var(--neutral-900-rgb), 0.5);
  z-index: 1100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.emoji-dialog-mask.show {
  opacity: 1;
  visibility: visible;
}

.emoji-dialog-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 92%;
  max-width: 600rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  z-index: 1101;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(var(--shadow-rgb), 0.2);
}

.emoji-dialog-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.emoji-dialog-content {
  display: flex;
  flex-direction: column;
}

.emoji-dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-default);
}

.emoji-dialog-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.emoji-dialog-emoji {
  font-size: 40rpx;
}

.emoji-dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-default);
}

.emoji-dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-hint);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.emoji-dialog-close:active {
  background: var(--bg-subtle);
  color: var(--text-default);
}

.emoji-dialog-body {
  padding: 32rpx;
}

.emoji-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: var(--warning-bg);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.emoji-tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.emoji-tip-text {
  font-size: 26rpx;
  color: var(--warning);
  line-height: 1.5;
  flex: 1;
}

.emoji-input-wrap {
  margin-bottom: 24rpx;
}

.emoji-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-default);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--text-default);
  box-sizing: border-box;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
}

.emoji-input:focus {
  background: var(--bg-card);
  border-color: var(--border-focus);
}

.emoji-input::placeholder {
  color: var(--text-hint);
}

.emoji-examples {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
}

.emoji-examples-label {
  font-size: 26rpx;
  color: var(--text-hint);
  white-space: nowrap;
  flex-shrink: 0;
}

.emoji-example {
  font-size: 40rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.emoji-example:active {
  background: var(--bg-card);
  transform: scale(1.1);
}

.emoji-dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid var(--border-default);
}

.emoji-dialog-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s ease;
}

.emoji-dialog-btn::after {
  border: none;
}

.emoji-dialog-btn.cancel {
  background: var(--bg-subtle);
  color: var(--text-muted);
}

.emoji-dialog-btn.cancel:active {
  background: var(--bg-card);
  transform: scale(0.98);
}

.emoji-dialog-btn.confirm {
  background: var(--primary-600);
  color: var(--text-inverse);
}

.emoji-dialog-btn.confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.amount-warning {
  font-size: 24rpx;
  color: #f59e0b;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* ========== 星辰靛蓝主题适配 ========== */
.theme-fintech .item-input,
.theme-fintech .item-textarea {
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
}

.theme-fintech .item-input:focus,
.theme-fintech .item-textarea:focus {
  background: var(--bg-card);
  border-color: var(--border-default);
}

.theme-fintech .picker-content {
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
}

.theme-fintech .picker-content:active {
  background: var(--bg-card);
  border-color: var(--border-default);
}

.theme-fintech .switch-item {
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
}

.theme-fintech .switch-item:active {
  background: var(--bg-card);
  border-color: var(--border-default);
}
