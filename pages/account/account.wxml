<!--pages/account/account.wxml-->
<view class="container theme-{{currentThemeKey}}" style="{{themeStyle}}">
  <!-- 提交中的全屏遮罩层 -->
  <view class="page-mask" wx:if="{{submitting || choosingAvatar}}" catchtouchmove="preventTouchMove" catchtap="preventTap"></view>

  <view class="header-bg"></view>
  <view class="bg-decoration"></view>

  <view class="page-header">
    <view>
      <text class="page-kicker">Account</text>
      <text class="page-title">账号身份</text>
    </view>
    <view class="role-badge">
      <text class="role-dot"></text>
      <text>{{isAdmin ? '管理员' : '普通用户'}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrapper">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{userInfo}}" class="account-card {{isEditing ? 'is-editing' : ''}}">
    <!-- 非编辑模式 -->
    <view wx:if="{{!isEditing}}">
      <view class="profile-panel">
        <view class="avatar-section">
          <view class="avatar-wrapper">
            <view class="avatar-aura"></view>
            <view class="avatar-loading-overlay" wx:if="{{avatarLoading}}">
              <view class="avatar-loader"></view>
            </view>
            <image
              wx:if="{{userInfo.avatarUrl}}"
              class="avatar-img {{canPreviewAvatar ? 'can-preview' : ''}}"
              src="{{userInfo.avatarUrl}}"
              mode="aspectFill"
              bindload="onAvatarLoad"
              binderror="onAvatarImageError"
              bindtap="previewAvatar"
            ></image>
            <view wx:else class="avatar-placeholder">
              <text class="placeholder-icon">人</text>
            </view>
          </view>
        </view>

        <view class="identity-copy">
          <text class="identity-label">当前昵称</text>
          <text class="identity-name">{{userInfo.nickName || '未设置'}}</text>
          <view class="identity-meta">
            <text class="meta-pill">{{canPreviewAvatar ? '头像可预览' : '随机头像'}}</text>
            <text wx:if="{{isAdmin}}" class="meta-pill">管理权限</text>
          </view>
        </view>
      </view>

      <view class="account-time-panel">
        <view class="time-row">
          <text class="time-label">创建时间</text>
          <text class="time-value">{{userInfo.createdAtText || '-'}}</text>
        </view>
        <view class="time-row">
          <text class="time-label">资料更新时间</text>
          <text class="time-value">{{userInfo.updatedAtText || '-'}}</text>
        </view>
        <view class="time-row">
          <text class="time-label">最近访问时间</text>
          <text class="time-value">{{userInfo.lastAccessTimeText || '-'}}</text>
        </view>
      </view>

      <view class="edit-tip">
        <text class="tip-text">头像和昵称可随时修改，仅用于账号展示。</text>
      </view>

      <button class="edit-btn" bindtap="startEdit">
        <text class="btn-text">修改头像昵称</text>
      </button>
    </view>

    <!-- 编辑模式 -->
    <view wx:else class="edit-mode">
      <view class="edit-heading">
        <text class="edit-title">修改展示资料</text>
        <text class="edit-subtitle">选择微信资料、相册原图，或生成一套随机形象。</text>
      </view>

      <view class="edit-notice">
        <text class="notice-text">这些信息只在小程序内展示，不会公开分享。</text>
      </view>

      <view class="edit-group">
        <view class="avatar-editor">
          <view class="avatar-editor-header">
            <view>
              <text class="edit-label">头像</text>
              <text class="edit-help">选择后会在这里统一预览</text>
            </view>
          </view>

          <view class="avatar-preview-stage">
            <image wx:if="{{editAvatarUrl}}" class="edit-avatar-preview" src="{{editAvatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="edit-avatar-empty">
              <text class="edit-avatar-empty-text">头像</text>
            </view>
          </view>

          <view class="avatar-source-actions">
            <button class="avatar-source-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" disabled="{{submitting}}">
              <text class="source-title">微信头像</text>
              <text class="source-desc">使用微信资料</text>
            </button>
            <button class="avatar-source-btn" bindtap="chooseAvatarFromAlbum" disabled="{{submitting}}">
              <text class="source-title">相册头像</text>
              <text class="source-desc">上传原图</text>
            </button>
          </view>
        </view>

        <view class="nickname-editor">
          <view class="nickname-editor-header">
            <view>
              <text class="edit-label">昵称</text>
              <text class="edit-help">最多 10 个字</text>
            </view>
          </view>
          <button class="nickname-select-btn" bindtap="chooseNickname" disabled="{{submitting}}">
            <text class="nickname-text {{editNickName ? 'filled' : 'empty'}}">{{editNickName || '点击获取昵称'}}</text>
            <text class="nickname-action">点击修改</text>
          </button>
          <input class="nickname-hidden-input" type="nickname" focus="{{nicknameFocus}}" bindinput="onNicknameInput" bindblur="onNicknameBlur" />
        </view>
      </view>

      <view class="random-tip" bindtap="showRandomPicker">
        <view class="random-mark">R</view>
        <view class="random-copy">
          <text class="random-text">使用随机头像和昵称</text>
          <text class="random-subtext">快速生成一套轻量身份</text>
        </view>
        <text class="random-action">生成</text>
      </view>

      <!-- 操作按钮 -->
      <view class="edit-actions">
        <button class="cancel-btn" bindtap="cancelEdit" disabled="{{submitting}}">取消</button>
        <button class="confirm-btn {{(!editAvatarUrl || !editNickName || submitting) ? 'disabled' : ''}}" bindtap="submitEdit" loading="{{submitting}}" disabled="{{!editAvatarUrl || !editNickName || submitting}}">
          {{submitting ? '保存中...' : '保存'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无账号信息</text>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer"></view>
</view>

<!-- 随机信息选择弹窗 -->
<view class="random-modal {{showRandomModal ? 'show' : ''}}" wx:if="{{showRandomModal}}">
  <view class="random-mask" bindtap="cancelRandomModal"></view>
  <view class="random-panel">
    <view class="random-header">
      <text class="random-title">随机生成的形象</text>
      <text class="random-desc">确认使用以下头像和昵称？</text>
    </view>
    <view class="random-body">
      <view class="random-avatar-container">
        <view class="random-avatar-wrapper">
          <image class="random-avatar-img" src="{{randomAvatarUrl}}" mode="aspectFill"></image>
        </view>
        <view class="random-refresh-btn" bindtap="refreshRandomAvatar">
          <image class="refresh-icon" src="/images/refresh.svg" mode="aspectFit"></image>
        </view>
      </view>
      <view class="random-nickname-row">
        <text class="random-nickname-text">{{randomNickName}}</text>
        <view class="random-nickname-refresh" bindtap="refreshRandomNickname">
          <image class="refresh-icon-small" src="/images/refresh.svg" mode="aspectFit"></image>
        </view>
      </view>
    </view>
    <view class="random-footer">
      <button class="random-cancel-btn" bindtap="cancelRandomModal">取消</button>
      <view class="btn-gap"></view>
      <button class="random-confirm-btn" bindtap="confirmRandomInfo">确认</button>
    </view>
  </view>
</view>
