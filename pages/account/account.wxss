/* pages/account/account.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e8ecf1 100%);
  position: relative;
  overflow: hidden;
}

/* 渐变背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 50% 50% / 0 0 30rpx 30rpx;
}

/* 装饰气泡 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  overflow: hidden;
  pointer-events: none;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bubble-1 {
  width: 100rpx;
  height: 100rpx;
  top: 20rpx;
  left: 30rpx;
  animation: float 6s ease-in-out infinite;
}

.bubble-2 {
  width: 60rpx;
  height: 60rpx;
  top: 60rpx;
  right: 40rpx;
  animation: float 8s ease-in-out infinite reverse;
}

.bubble-3 {
  width: 40rpx;
  height: 40rpx;
  top: 120rpx;
  left: 80rpx;
  animation: float 7s ease-in-out infinite;
}

.bubble-4 {
  width: 50rpx;
  height: 50rpx;
  top: 100rpx;
  right: 100rpx;
  animation: float 5s ease-in-out infinite reverse;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 页面标题 */
.page-header {
  position: relative;
  z-index: 1;
  padding: 40rpx 40rpx 30rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 账号卡片 */
.account-card {
  position: relative;
  z-index: 1;
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
}

.avatar-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e0e5ec 0%, #d5dae0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
}

/* 信息区域 */
.info-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.info-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #eee, transparent);
  margin: 30rpx 0;
}

/* 授权提示 */
.auth-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}

/* 按钮 */
.auth-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin-top: 20rpx;
}

.get-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.4);
}

.update-btn {
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
  color: #666;
  border: 2rpx solid #ddd;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.btn-text {
  font-weight: 500;
}

/* 底部留白 */
.bottom-spacer {
  height: 60rpx;
}
