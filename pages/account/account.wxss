/* pages/account/account.wxss - 账号身份页 */

.container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  padding: 28rpx 28rpx 80rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 0%, rgba(var(--primary-600-rgb), 0.12), transparent 38%),
    linear-gradient(180deg, var(--bg-base) 0%, var(--bg-subtle) 100%);
  color: var(--text-default);
}

.header-bg {
  position: absolute;
  top: -170rpx;
  right: -170rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: rgba(var(--primary-600-rgb), 0.1);
  pointer-events: none;
}

.bg-decoration {
  position: absolute;
  left: 0;
  right: 0;
  top: 156rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(var(--primary-600-rgb), 0.2), transparent);
  pointer-events: none;
}

.page-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 30rpx 4rpx 34rpx;
}

.page-kicker {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  color: var(--primary-600);
  text-transform: uppercase;
}

.page-title {
  display: block;
  font-size: 56rpx;
  line-height: 1.04;
  font-weight: 800;
  color: var(--text-default);
}

.role-badge {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  min-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(var(--primary-600-rgb), 0.16);
  border-radius: 10rpx;
  background: rgba(var(--bg-card-rgb), 0.78);
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: var(--shadow-card);
}

.role-dot {
  margin-right: 10rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 0 8rpx rgba(var(--primary-600-rgb), 0.08);
}

.loading-wrapper {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 460rpx;
}

.loading-spinner,
.avatar-loader {
  width: 54rpx;
  height: 54rpx;
  border: 4rpx solid rgba(var(--primary-600-rgb), 0.14);
  border-top-color: var(--primary-600);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 22rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.account-card {
  position: relative;
  z-index: 1;
  padding: 24rpx;
  border: 1rpx solid rgba(var(--neutral-900-rgb), 0.05);
  border-radius: 20rpx;
  background: rgba(var(--bg-card-rgb), 0.88);
  box-shadow: 0 22rpx 60rpx rgba(var(--shadow-rgb), 0.16);
  box-sizing: border-box;
}

.account-card.is-editing {
  padding: 28rpx 24rpx 24rpx;
}

.profile-panel {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 236rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(135deg, rgba(var(--primary-600-rgb), 0.11), transparent 58%),
    var(--bg-subtle);
  overflow: hidden;
}

.profile-panel::after {
  content: '';
  position: absolute;
  right: -72rpx;
  bottom: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border: 1rpx solid rgba(var(--primary-600-rgb), 0.18);
  border-radius: 50%;
}

.avatar-section {
  flex-shrink: 0;
  margin-right: 44rpx;
  display: flex;
  justify-content: center;
}

.avatar-wrapper {
  position: relative;
  width: 176rpx;
  height: 176rpx;
}

.avatar-aura {
  position: absolute;
  top: -14rpx;
  left: -14rpx;
  right: -14rpx;
  bottom: -14rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, rgba(var(--primary-600-rgb), 0.2), rgba(var(--warning-rgb), 0.12));
  transform: rotate(-4deg);
}

.avatar-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  background: rgba(var(--bg-card-rgb), 0.72);
}

.avatar-img,
.avatar-placeholder {
  position: relative;
  z-index: 2;
  width: 176rpx;
  height: 176rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  border: 6rpx solid rgba(var(--bg-card-rgb), 0.86);
  background: var(--bg-card);
  box-shadow: 0 16rpx 34rpx rgba(var(--shadow-rgb), 0.18);
}

.avatar-img.can-preview {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.avatar-img.can-preview:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 18rpx rgba(var(--shadow-rgb), 0.18);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 58rpx;
  font-weight: 800;
  color: var(--primary-600);
}

.identity-copy {
  flex: 1;
  position: relative;
  z-index: 1;
  min-width: 0;
}

.identity-label,
.edit-help {
  display: block;
  color: var(--text-muted);
  font-size: 23rpx;
  line-height: 1.45;
}

.identity-name {
  display: block;
  max-width: 100%;
  margin: 8rpx 0 18rpx;
  color: var(--text-default);
  font-size: 44rpx;
  line-height: 1.16;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.identity-meta {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  margin: 6rpx;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: rgba(var(--bg-card-rgb), 0.72);
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 600;
}

.account-time-panel {
  margin-top: 24rpx;
  padding: 6rpx 22rpx;
  border-radius: 16rpx;
  background: var(--bg-card);
  box-shadow: inset 0 0 0 1rpx rgba(var(--neutral-900-rgb), 0.05);
}

.time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
}

.time-row + .time-row {
  border-top: 1rpx solid var(--border-light);
}

.time-label {
  flex-shrink: 0;
  margin-right: 24rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.4;
}

.time-value {
  flex: 1;
  min-width: 0;
  color: var(--text-default);
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: right;
  word-break: break-all;
}

.edit-tip {
  padding: 24rpx 4rpx 22rpx;
}

.tip-text {
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1.55;
}

.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 92rpx;
  margin: 0;
  padding: 0 28rpx;
  border: none;
  border-radius: 14rpx;
  background: var(--primary-600);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 14rpx 26rpx rgba(var(--primary-600-rgb), 0.24);
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.confirm-btn,
.random-confirm-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin: 0;
  padding: 0 28rpx;
  border: none;
  border-radius: 14rpx;
  background: var(--primary-600);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 14rpx 26rpx rgba(var(--primary-600-rgb), 0.24);
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.edit-btn::after,
.confirm-btn::after,
.cancel-btn::after,
.avatar-source-btn::after,
.nickname-select-btn::after,
.random-cancel-btn::after,
.random-confirm-btn::after {
  border: none;
}

.edit-btn:active,
.confirm-btn:active,
.random-confirm-btn:active {
  transform: translateY(2rpx) scale(0.99);
}

.btn-text {
  line-height: 1;
}

.edit-mode {
  position: relative;
}

.page-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: transparent;
}

.edit-heading {
  padding: 4rpx 4rpx 24rpx;
}

.edit-title {
  display: block;
  color: var(--text-default);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.edit-subtitle {
  display: block;
  max-width: 560rpx;
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1.5;
}

.edit-notice {
  margin-bottom: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(var(--primary-600-rgb), 0.08);
}

.notice-text {
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.edit-group {
  border-radius: 16rpx;
  background: transparent;
}

.avatar-editor {
  padding: 24rpx;
  border-radius: 16rpx;
  background: var(--bg-card);
  box-shadow: inset 0 0 0 1rpx rgba(var(--neutral-900-rgb), 0.05);
  box-sizing: border-box;
}

.avatar-editor-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.avatar-preview-stage {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  height: 168rpx;
  margin: 0 auto 22rpx;
  border-radius: 28rpx;
  background: var(--bg-subtle);
  box-shadow: inset 0 0 0 1rpx rgba(var(--neutral-900-rgb), 0.05);
  box-sizing: border-box;
}

.edit-avatar-preview,
.edit-avatar-empty {
  width: 144rpx;
  height: 144rpx;
  border-radius: 24rpx;
  background: var(--bg-card);
  box-shadow: 0 10rpx 24rpx rgba(var(--shadow-rgb), 0.14);
}

.edit-avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-avatar-empty-text {
  color: var(--text-hint);
  font-size: 28rpx;
  font-weight: 700;
}

.avatar-source-actions {
  display: flex;
}

.avatar-source-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 92rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 1rpx solid var(--border-default);
  border-radius: 14rpx;
  background: var(--bg-card);
  line-height: normal;
  box-sizing: border-box;
}

.avatar-source-btn + .avatar-source-btn {
  margin-left: 16rpx;
}

.source-title {
  color: var(--text-default);
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
}

.source-desc {
  margin-top: 6rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.25;
}

.nickname-editor {
  position: relative;
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(135deg, rgba(var(--primary-600-rgb), 0.05), transparent 62%),
    var(--bg-card);
  box-shadow: inset 0 0 0 1rpx rgba(var(--neutral-900-rgb), 0.05);
  box-sizing: border-box;
}

.nickname-editor-header {
  margin-bottom: 18rpx;
}

.edit-label {
  display: block;
  color: var(--text-default);
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.nickname-select-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 78rpx;
  margin: 0;
  padding: 0 18rpx 0 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(var(--primary-600-rgb), 0.14);
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-subtle) 100%);
  box-shadow: 0 6rpx 14rpx rgba(var(--shadow-rgb), 0.08);
  line-height: normal;
  box-sizing: border-box;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
}

.nickname-select-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(var(--shadow-rgb), 0.08);
}

.nickname-text {
  flex: 1;
  min-width: 0;
  max-width: none;
  font-size: 29rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nickname-text.filled {
  color: var(--text-default);
}

.nickname-text.empty {
  color: var(--text-hint);
}

.nickname-action {
  flex-shrink: 0;
  margin-left: 14rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(var(--primary-600-rgb), 0.08);
  color: var(--primary-600);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.nickname-hidden-input {
  position: absolute;
  width: 0;
  height: 0;
  opacity: 0;
}

.random-tip {
  display: flex;
  align-items: center;
  min-height: 112rpx;
  margin: 24rpx 0;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(var(--warning-rgb), 0.18);
  background:
    linear-gradient(135deg, rgba(var(--warning-rgb), 0.11), transparent 54%),
    var(--bg-card);
  box-shadow: 0 8rpx 18rpx rgba(var(--shadow-rgb), 0.1);
  box-sizing: border-box;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.random-tip:active {
  transform: translateY(2rpx);
  box-shadow: 0 3rpx 10rpx rgba(var(--shadow-rgb), 0.09);
}

.random-mark {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 14rpx;
  background: var(--text-default);
  color: var(--text-inverse);
  font-size: 25rpx;
  font-weight: 800;
  margin-right: 18rpx;
}

.random-copy {
  flex: 1;
  min-width: 0;
}

.random-text {
  display: block;
  color: var(--text-default);
  font-size: 28rpx;
  font-weight: 700;
}

.random-subtext {
  display: block;
  margin-top: 6rpx;
  color: var(--text-muted);
  font-size: 23rpx;
}

.random-action {
  flex-shrink: 0;
  margin-left: 14rpx;
  padding: 10rpx 14rpx;
  border-radius: 10rpx;
  background: var(--text-default);
  color: var(--text-inverse);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.cancel-btn,
.random-cancel-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 1rpx solid var(--border-default);
  border-radius: 14rpx;
  background: var(--bg-card);
  color: var(--text-muted);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.confirm-btn {
  flex: 1.25;
  min-height: 92rpx;
}

.confirm-btn.disabled {
  background: var(--neutral-300);
  box-shadow: none;
  opacity: 0.7;
}

.empty-state {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 420rpx;
  border-radius: 20rpx;
  background: rgba(var(--bg-card-rgb), 0.78);
}

.empty-icon {
  margin-bottom: 18rpx;
  color: var(--text-hint);
  font-size: 72rpx;
}

.empty-text {
  color: var(--text-muted);
  font-size: 28rpx;
}

.bottom-spacer {
  height: 30rpx;
}

.random-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.24s ease, visibility 0.24s ease;
}

.random-modal.show {
  opacity: 1;
  visibility: visible;
}

.random-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.48);
}

.random-panel {
  position: relative;
  width: 100%;
  max-width: 690rpx;
  margin: 0 24rpx 30rpx;
  padding: 34rpx 28rpx 28rpx;
  border-radius: 22rpx;
  background: var(--bg-card);
  box-shadow: 0 -18rpx 54rpx rgba(15, 23, 42, 0.18);
  transform: translateY(34rpx);
  transition: transform 0.24s ease;
  box-sizing: border-box;
}

.random-modal.show .random-panel {
  transform: translateY(0);
}

.random-header {
  text-align: left;
  padding: 0 4rpx 22rpx;
}

.random-title {
  display: block;
  color: var(--text-default);
  font-size: 36rpx;
  font-weight: 800;
}

.random-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.random-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 22rpx;
  border-radius: 18rpx;
  background: var(--bg-subtle);
}

.random-avatar-container {
  display: flex;
  align-items: center;
  justify-content: center;
}

.random-avatar-wrapper {
  width: 148rpx;
  height: 148rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: transparent;
  box-shadow: none;
}

.random-avatar-img {
  width: 100%;
  height: 100%;
}

.random-refresh-btn,
.random-nickname-refresh {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(var(--neutral-900-rgb), 0.08);
  background: transparent;
  box-shadow: none;
  transition: transform 0.18s ease;
}

.random-refresh-btn {
  margin-left: 24rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 16rpx;
}

.random-refresh-btn:active,
.random-nickname-refresh:active {
  transform: scale(0.92);
}

.refresh-icon {
  width: 30rpx;
  height: 30rpx;
}

.random-nickname-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
}

.random-nickname-text {
  max-width: 430rpx;
  color: var(--text-default);
  font-size: 34rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.random-nickname-refresh {
  margin-left: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 13rpx;
}

.refresh-icon-small {
  width: 23rpx;
  height: 23rpx;
}

.random-footer {
  display: flex;
  margin-top: 24rpx;
}

.btn-gap {
  width: 16rpx;
  flex-shrink: 0;
}

.random-confirm-btn {
  flex: 1.2;
}

@media (max-width: 360px) {
  .profile-panel {
    flex-direction: column;
    align-items: flex-start;
  }

  .avatar-section {
    margin-right: 0;
    margin-bottom: 24rpx;
    justify-content: flex-start;
  }

  .nickname-text {
    max-width: 220rpx;
  }
}
