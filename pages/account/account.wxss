/* pages/account/account.wxss - 温暖极简浅色主题 */

.container {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
  padding-bottom: 60rpx;
}

/* 头部背景 - 移除渐变和装饰 */
.header-bg {
  display: none;
}

/* 装饰气泡 - 移除 */
.bg-decoration {
  display: none;
}

/* 页面标题 */
.page-header {
  position: relative;
  z-index: 1;
  padding: 40rpx 40rpx 30rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-default);
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 加载状态 */
.loading-wrapper {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-default);
  border-top-color: var(--primary-600);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 20rpx;
}

/* 账号卡片 */
.account-card {
  position: relative;
  z-index: 1;
  margin: 20rpx 30rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(var(--shadow-rgb), 0.1);
  border: 1rpx solid var(--border-default);
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.avatar-loading-overlay .loading-spinner {
  font-size: 40rpx;
  animation: spin 1s linear infinite;
}

.avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border-default);
}

.avatar-img.can-preview {
  box-shadow: 0 8rpx 24rpx rgba(var(--shadow-rgb), 0.18);
}

.avatar-img.can-preview:active {
  transform: scale(0.96);
}

.avatar-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: var(--bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
}

/* 信息区域 */
.info-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 10rpx;
}

.info-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-default);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-default);
  margin: 30rpx 0;
}

/* 编辑提示 */
.edit-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-default);
}

/* 编辑按钮 */
.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  background: var(--primary-600);
  color: var(--text-inverse);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.btn-text {
  font-weight: 500;
}

/* 编辑模式 */
.edit-mode {
  padding: 10rpx 0;
}

/* 提交中的全屏遮罩层 */
.page-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: transparent;
}

/* 编辑提示信息 */
.edit-notice {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--primary-600);
}

.notice-text {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.edit-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-default);
}

.edit-label {
  width: 100rpx;
  font-size: 28rpx;
  color: var(--text-default);
  font-weight: 500;
}

.avatar-select-btn {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-edit-actions {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 18rpx;
  min-width: 0;
}

.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-default);
}

.avatar-empty-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

.avatar-album-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 18rpx;
  margin: 0;
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-default);
  border-radius: 28rpx;
  line-height: normal;
}

.avatar-album-btn::after {
  border: none;
}

.avatar-album-text {
  font-size: 24rpx;
  color: var(--primary-600);
  white-space: nowrap;
}

.nickname-select-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.nickname-text {
  font-size: 28rpx;
}

.nickname-text.filled {
  color: var(--text-default);
}

.nickname-text.empty {
  color: var(--text-hint);
}

.select-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-left: 10rpx;
}

.nickname-hidden-input {
  position: absolute;
  width: 0;
  height: 0;
  opacity: 0;
}

/* 随机选择提示 */
.random-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  margin: 30rpx 0 20rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx dashed var(--primary-600);
}

.random-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.random-text {
  font-size: 26rpx;
  color: var(--primary-600);
}

/* 操作按钮 */
.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: var(--bg-subtle);
  color: var(--text-muted);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.cancel-btn::after {
  border: none;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: var(--primary-600);
  color: var(--text-inverse);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.disabled {
  background: var(--border-default);
}

/* 空状态 */
.empty-state {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 底部留白 */
.bottom-spacer {
  height: 60rpx;
}

/* 随机信息弹窗 */
/* 随机信息选择弹窗 */
.random-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.random-modal.show {
  opacity: 1;
  visibility: visible;
}

.random-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.random-panel {
  position: relative;
  width: 640rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.random-modal.show .random-panel {
  transform: scale(1);
}

.random-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.random-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-default);
  display: block;
  margin-bottom: 12rpx;
}

.random-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  display: block;
}

.random-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.random-avatar-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.random-avatar-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(var(--primary-600-rgb), 0.2);
}

.random-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.random-refresh-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.random-refresh-btn:active {
  transform: scale(0.9);
}

.refresh-icon {
  width: 28rpx;
  height: 28rpx;
}

.random-nickname-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.random-nickname-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-default);
}

.random-nickname-refresh {
  width: 44rpx;
  height: 44rpx;
  background: var(--bg-default);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s ease;
}

.random-nickname-refresh:active {
  transform: scale(0.9);
}

.refresh-icon-small {
  width: 22rpx;
  height: 22rpx;
}

.random-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.random-cancel-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: var(--bg-subtle);
  color: var(--text-muted);
  border: 2rpx solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: all 0.2s ease;
}

.random-cancel-btn:active {
  background: var(--bg-muted);
}

.random-cancel-btn::after {
  border: none;
}

.random-confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(var(--primary-600-rgb), 0.3);
  transition: all 0.2s ease;
}

.random-confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(var(--primary-600-rgb), 0.2);
}

.random-confirm-btn::after {
  border: none;
}
