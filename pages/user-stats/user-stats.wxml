<!--pages/user-stats/user-stats.wxml-->
<view class="container theme-{{currentThemeKey}}" style="{{themeStyle}}">
  <!-- 渐变背景头部 -->
  <view class="header-bg"></view>

  <!-- 装饰气泡 -->
  <view class="bg-decoration">
    <view class="bubble bubble-1"></view>
    <view class="bubble bubble-2"></view>
    <view class="bubble bubble-3"></view>
    <view class="bubble bubble-4"></view>
  </view>

  <!-- 页面标题区域 -->
  <view class="page-header">
    <text class="page-title">用户管理</text>
    <text class="page-subtitle">管理用户及其资产数据</text>
  </view>

  <!-- 统计概览 - 一体化数据看板 -->
  <view class="stats-overview">
    <view class="stats-dashboard">
      <!-- 顶部渐变装饰条 -->
      <view class="dashboard-accent"></view>

      <!-- 主指标行：用户总数 / 资产总数 / 活跃客户 -->
      <view class="stats-row-main">
        <!-- 用户总数 - 主指标 -->
        <view class="stat-block stat-block-primary">
          <view class="stat-block-icon">
            <image class="stat-block-icon-img" src="{{usersIcon}}" mode="aspectFit" />
          </view>
          <text class="stat-block-value primary">{{userTotalCount}}</text>
          <text class="stat-block-label">用户总数</text>
        </view>

        <!-- 资产总数 -->
        <view class="stat-block">
          <view class="stat-block-icon">
            <image class="stat-block-icon-img" src="{{boxIcon}}" mode="aspectFit" />
          </view>
          <text class="stat-block-value">{{totalAssetCount}}</text>
          <text class="stat-block-label">资产总数</text>
        </view>

        <!-- 活跃客户 -->
        <view class="stat-block stat-block-live">
          <view class="stat-block-icon">
            <image class="stat-block-icon-img" src="{{lightningIcon}}" mode="aspectFit" />
          </view>
          <text class="stat-block-value">{{activeUserCount}}</text>
          <view class="stat-block-label-row">
            <text class="stat-block-label">活跃客户</text>
            <image class="stat-detail-icon" src="{{detailIcon}}" mode="aspectFit" catchtap="showActiveUserDetail" />
          </view>
          <view class="live-indicator"></view>
        </view>
      </view>

      <!-- 分隔线 -->
      <view class="dashboard-divider"></view>

      <!-- 访问统计行：今日访问 / 全部访问 -->
      <view class="stats-row-access">
        <view class="access-block">
          <view class="access-block-inner">
            <image class="access-block-icon" src="{{calendarCheckIcon}}" mode="aspectFit" />
            <view class="access-block-text">
              <view class="access-block-nums">
                <text class="access-block-value">{{todayCount}}</text>
                <text class="access-block-unit">次</text>
                <text class="access-block-divider">/</text>
                <text class="access-block-value sub">{{todayUserCount}}</text>
                <text class="access-block-unit">人</text>
              </view>
              <text class="access-block-label">今日访问</text>
            </view>
          </view>
        </view>
        <view class="access-block">
          <view class="access-block-inner">
            <image class="access-block-icon" src="{{calendarClockIcon}}" mode="aspectFit" />
            <view class="access-block-text">
              <view class="access-block-nums">
                <text class="access-block-value">{{totalAccessCount}}</text>
                <text class="access-block-unit">次</text>
              </view>
              <text class="access-block-label">全部访问</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 时间粒度选择器 -->
  <view wx:if="{{!loading && rawChartData.length > 0}}" class="granularity-section">
    <!-- 粒度切换标签 -->
    <view class="granularity-tabs">
      <view
        class="granularity-tab {{chartGranularity === 'day' ? 'active' : ''}}"
        bindtap="switchGranularity"
        data-granularity="day"
      >按日</view>
      <view
        class="granularity-tab {{chartGranularity === 'month' ? 'active' : ''}}"
        bindtap="switchGranularity"
        data-granularity="month"
      >按月</view>
      <view
        class="granularity-tab {{chartGranularity === 'quarter' ? 'active' : ''}}"
        bindtap="switchGranularity"
        data-granularity="quarter"
      >按季</view>
      <view
        class="granularity-tab {{chartGranularity === 'year' ? 'active' : ''}}"
        bindtap="switchGranularity"
        data-granularity="year"
      >按年</view>
      <!-- 日期筛选按钮 -->
      <view
        class="granularity-tab date-filter-btn {{showDateFilter ? 'active' : ''}} {{chartDateStart || chartDateEnd ? 'has-filter' : ''}}"
        bindtap="toggleDateFilter"
      >
        <text>筛选</text>
        <text wx:if="{{chartDateStart || chartDateEnd}}" class="filter-dot"></text>
      </view>
    </view>

    <!-- 日期范围选择面板 -->
    <view wx:if="{{showDateFilter}}" class="date-filter-panel">
      <view class="date-filter-row">
        <view class="date-picker-box">
          <text class="date-picker-label">起始</text>
          <picker mode="date" value="{{chartDateStart}}" bindchange="onDateStartChange" end="{{chartDateEnd || ''}}">
            <view class="date-picker-value {{chartDateStart ? '' : 'placeholder'}}">
              {{chartDateStart || '选择日期'}}
            </view>
          </picker>
        </view>
        <text class="date-range-sep">至</text>
        <view class="date-picker-box">
          <text class="date-picker-label">结束</text>
          <picker mode="date" value="{{chartDateEnd}}" bindchange="onDateEndChange" start="{{chartDateStart || ''}}">
            <view class="date-picker-value {{chartDateEnd ? '' : 'placeholder'}}">
              {{chartDateEnd || '选择日期'}}
            </view>
          </picker>
        </view>
        <view wx:if="{{chartDateStart || chartDateEnd}}" class="date-clear-btn" bindtap="clearDateFilter">
          <text>✕</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 每日访问趋势图表 -->
  <view wx:if="{{!loading && !showActiveModal && accessChartData.length > 0}}" class="chart-section">
    <view class="chart-header">
      <image class="chart-header-icon" src="{{chartIcon}}" mode="aspectFit" />
      <text wx:if="{{chartGranularity === 'day'}}" class="chart-title">每日访问数据</text>
      <text wx:elif="{{chartGranularity === 'month'}}" class="chart-title">每月访问数据</text>
      <text wx:elif="{{chartGranularity === 'quarter'}}" class="chart-title">每季访问数据</text>
      <text wx:elif="{{chartGranularity === 'year'}}" class="chart-title">每年访问数据</text>
      <text wx:else class="chart-title">访问数据</text>
    </view>
    <view class="chart-wrapper">
      <ec-canvas id="access-chart" canvas-id="access-chart" ec="{{accessEc}}"></ec-canvas>
    </view>
  </view>

  <!-- 筛选排序栏 -->
  <view class="filter-bar" wx:if="{{!empty && !loading}}">
    <!-- 搜索框 -->
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索用户"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">✕</text>
    </view>
    <!-- 排序选择 -->
    <view class="sort-selector">
      <picker mode="selector" range="{{sortOptions}}" range-key="label" value="{{sortIndex}}" bindchange="onSortChange">
        <view class="sort-btn">
          <text class="sort-text">{{sortOptions[sortIndex].label}}</text>
          <text class="sort-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 骨架屏加载状态 -->
  <view wx:if="{{loading}}" class="skeleton-wrapper">
    <!-- 统计卡片骨架 -->
    <view class="skeleton-stats">
      <view class="skeleton-dashboard skeleton-animate"></view>
    </view>
    <!-- 用户卡片骨架 -->
    <view class="skeleton-list">
      <view class="skeleton-user-card skeleton-animate" wx:for="{{3}}" wx:key="*this">
        <view class="skeleton-avatar skeleton-animate"></view>
        <view class="skeleton-info">
          <view class="skeleton-name skeleton-animate"></view>
          <view class="skeleton-row skeleton-animate"></view>
          <view class="skeleton-row skeleton-animate"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户列表 -->
  <view wx:elif="{{!empty}}" class="user-list">
    <view class="list-section">
      <view class="list-header">
        <text class="list-title">用户列表</text>
        <view class="list-count">
          <text>{{filteredUsers.length}}</text>
          <text class="count-label">/{{userTotalCount}}</text>
        </view>
      </view>

      <view class="user-card {{item._expanded ? 'expanded' : ''}}" wx:for="{{filteredUsers}}" wx:key="_id">
        <!-- 用户卡片头部 -->
        <view class="user-card-header" bindtap="toggleUserExpand" data-index="{{index}}">
          <!-- 头像区域 -->
          <view
            class="user-avatar-wrapper"
            catchtap="previewAvatar"
            data-index="{{index}}"
            data-avatar="{{item.avatarUrl}}"
          >
            <view class="avatar-ring {{item.activityLevel}}"></view>
            <image
              class="avatar-img"
              src="{{item.avatarUrl}}"
              mode="aspectFill"
              binderror="onAvatarError"
              data-index="{{index}}"
            ></image>
            <view class="activity-dot {{item.isTodayAccess ? 'today' : item.activityLevel}}"></view>
          </view>

          <!-- 用户信息 -->
          <view class="user-info">
            <view class="user-header">
              <text class="user-name">{{item.nickName}}</text>
              <view wx:if="{{item.isTodayAccess}}" class="today-badge">
                <text>今日</text>
              </view>
              <view class="activity-badge {{item.activityLevel}}">
                <text>{{item.activityLevelText}}</text>
              </view>
            </view>

            <!-- 用户资产统计 + 访问时间 -->
            <view class="user-asset-summary">
              <view class="summary-item">
                <text class="summary-icon">📦</text>
                <text class="summary-value">{{item.assetCount}}件</text>
              </view>
              <view class="summary-item" wx:if="{{item.totalAssetPrice > 0}}">
                <text class="summary-icon">💰</text>
                <text class="summary-value">¥{{item.totalAssetPriceText}}</text>
              </view>
            </view>

            <!-- 访问时间（紧凑显示） -->
            <view class="access-time-compact">
              <text class="access-time-text">首: {{item.firstAccessText}}</text>
              <text class="access-time-divider">|</text>
              <text class="access-time-text">近: {{item.lastAccessText}}</text>
            </view>
          </view>

          <!-- 操作按钮 -->
          <view class="action-buttons">
            <view class="expand-btn {{item._expanded ? 'expanded' : ''}}">
              <text class="expand-icon">{{item._expanded ? '▼' : '▶'}}</text>
            </view>
          </view>
        </view>

        <!-- 用户资产列表（可展开） -->
        <view wx:if="{{item._expanded && item.assets.length > 0}}" class="user-assets-section">
          <view class="assets-header">
            <text class="assets-title">资产列表</text>
            <text class="assets-count">{{item.assets.length}}件</text>
          </view>

          <view class="asset-item" wx:for="{{item.assets}}" wx:for-item="asset" wx:key="_id">
            <view class="asset-icon-box">
              <image wx:if="{{asset.displayIcon}}" class="asset-icon-img" src="{{asset.displayIcon}}" mode="aspectFill" bindtap="previewIcon" data-icon="{{asset.displayIcon}}"></image>
              <text wx:else class="asset-icon">{{asset.icon || '📦'}}</text>
            </view>
            <view class="asset-info">
              <view class="asset-header">
                <text class="asset-name">{{asset.name}}</text>
                <view class="asset-status-badge {{asset.status}}">
                  <text>{{asset.status === 'active' ? '服役中' : asset.status === 'retired' ? '已退役' : '已卖出'}}</text>
                </view>
              </view>
              <view class="asset-stats-row">
                <view class="asset-stat">
                  <text class="stat-label">价格</text>
                  <text class="stat-value">¥{{asset.price}}</text>
                </view>
                <view class="asset-stat">
                  <text class="stat-label">服役时长</text>
                  <text class="stat-value">{{asset.usedDaysText}}</text>
                </view>
                <view class="asset-stat">
                  <text class="stat-label">日均成本</text>
                  <text class="stat-value cost">¥{{asset.dailyCost}}/天</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 用户无资产提示 -->
        <view wx:if="{{item._expanded && item.assets.length === 0}}" class="no-assets-tip">
          <text class="no-assets-icon">📭</text>
          <text class="no-assets-text">该用户暂无资产</text>
        </view>

        <!-- 卡片装饰 -->
        <view class="card-decoration"></view>

        <!-- 删除按钮 -->
        <view class="delete-btn" catchtap="deleteUser" data-openid="{{item._openid}}" data-name="{{item.nickName}}"></view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{userHasMore}}" class="load-more-wrap">
      <view wx:if="{{loadingMore}}" class="load-more-loading">
        <text class="load-more-spinner"></text>
        <text>加载中...</text>
      </view>
      <view wx:else class="load-more-btn" bindtap="loadMoreUsers">
        <text>加载更多</text>
        <text class="load-more-hint">（{{users.length}}/{{userTotalCount}}）</text>
      </view>
    </view>
    <view wx:elif="{{!loading && userTotalCount > 0}}" class="load-more-wrap">
      <text class="load-more-end">— 共{{userTotalCount}}位用户 —</text>
    </view>

    <!-- 底部留白 -->
    <view class="list-spacer"></view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{empty && !loading}}" class="empty-state">
    <view class="empty-visual">
      <view class="empty-circle">
        <view class="empty-face">
          <view class="face-eyes">
            <view class="eye eye-left"><view class="eye-pupil"></view></view>
            <view class="eye eye-right"><view class="eye-pupil"></view></view>
          </view>
          <view class="face-mouth"></view>
        </view>
      </view>
      <view class="empty-waves">
        <view class="wave wave-1"></view>
        <view class="wave wave-2"></view>
        <view class="wave wave-3"></view>
      </view>
    </view>
    <text class="empty-title">暂无用户数据</text>
    <text class="empty-desc">等待用户访问小程序</text>
  </view>

  <!-- 搜索无结果状态 -->
  <view wx:if="{{!empty && filteredUsers.length === 0 && searchKeyword}}" class="search-empty">
    <text class="search-empty-icon">🔍</text>
    <text class="search-empty-title">未找到匹配用户</text>
    <text class="search-empty-desc">换个关键词试试</text>
  </view>

  <!-- 活跃客户分布弹窗 -->
  <view wx:if="{{showActiveModal}}" class="modal-overlay" bindtap="closeActiveModal">
    <view class="modal-card" catchtap="">
      <!-- 顶部色条 -->
      <view class="modal-accent"></view>
      <!-- 标题栏 -->
      <view class="modal-header">
        <text class="modal-title">活跃客户分布</text>
        <view class="modal-close" bindtap="closeActiveModal">
          <text>✕</text>
        </view>
      </view>
      <!-- 内容区 -->
      <view class="modal-body">
        <!-- 醒目数字：活跃客户数 -->
        <view class="modal-hero">
          <text class="modal-hero-num">{{activeModalData.high}}</text>
          <text class="modal-hero-unit">/{{activeModalData.total}}人</text>
        </view>
        <text class="modal-hero-label">活跃客户（7天内访问）</text>

        <!-- 分布条 -->
        <view class="modal-bar-wrap">
          <view class="modal-bar">
            <view class="modal-bar-seg high" style="flex: {{activeModalData.high}};"></view>
            <view class="modal-bar-seg medium" style="flex: {{activeModalData.medium}};"></view>
            <view class="modal-bar-seg low" style="flex: {{activeModalData.low}};"></view>
          </view>
          <view class="modal-bar-labels">
            <view class="modal-bar-label">
              <view class="bar-dot high"></view>
              <text>高</text>
              <text class="bar-count">{{activeModalData.high}}人</text>
            </view>
            <view class="modal-bar-label">
              <view class="bar-dot medium"></view>
              <text>中</text>
              <text class="bar-count">{{activeModalData.medium}}人</text>
            </view>
            <view class="modal-bar-label">
              <view class="bar-dot low"></view>
              <text>低</text>
              <text class="bar-count">{{activeModalData.low}}人</text>
            </view>
          </view>
        </view>

        <!-- 说明文字 -->
        <view class="modal-desc">
          <text>活跃客户 = 高活跃 = 7天内访问过的用户</text>
        </view>
      </view>
    </view>
  </view>
</view>
