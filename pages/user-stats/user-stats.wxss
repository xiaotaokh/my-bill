/* pages/user-stats/user-stats.wxss */
/* 用户统计页面 - 轻奢数据仪表板风格 */

/* CSS 变量 */
page {
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --accent-purple: #9b72e8;
  --accent-blue: #667eea;
  --glass-bg: rgba(255, 255, 255, 0.92);
  --glass-border: rgba(255, 255, 255, 0.5);
  --shadow-soft: 0 8rpx 32rpx rgba(102, 126, 234, 0.12);
  --shadow-card: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);

  /* 活跃度颜色 */
  --activity-high: #10b981;
  --activity-medium: #f59e0b;
  --activity-low: #9ca3af;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f5 0%, #e8eaf6 50%, #f5f7fa 100%);
  padding: 0;
  position: relative;
  overflow: hidden;
}

/* ============================================
   渐变背景头部
   ============================================ */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #9b72e8 100%);
  border-radius: 0 0 48rpx 48rpx;
  z-index: 0;
}

/* ============================================
   装饰气泡 - 动态渐变
   ============================================ */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 1;
}

.bubble {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.bubble-1 {
  width: 200rpx;
  height: 200rpx;
  top: -40rpx;
  right: 40rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
  animation: float 8s ease-in-out infinite;
}

.bubble-2 {
  width: 160rpx;
  height: 160rpx;
  top: 120rpx;
  left: -20rpx;
  background: radial-gradient(circle, rgba(118, 75, 162, 0.25) 0%, transparent 70%);
  animation: float 10s ease-in-out infinite reverse;
}

.bubble-3 {
  width: 120rpx;
  height: 120rpx;
  bottom: 200rpx;
  right: -30rpx;
  background: radial-gradient(circle, rgba(155, 114, 232, 0.2) 0%, transparent 70%);
  animation: float 6s ease-in-out infinite;
}

.bubble-4 {
  width: 80rpx;
  height: 80rpx;
  bottom: 100rpx;
  left: 60rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.15) 0%, transparent 70%);
  animation: float 12s ease-in-out infinite reverse;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.05); }
}

/* ============================================
   页面标题
   ============================================ */
.page-header {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
}

.page-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 4rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* ============================================
   统计概览卡片组
   ============================================ */
.stats-overview {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.overview-card {
  position: relative;
  flex: 1;
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--glass-border);
  transition: transform 0.3s ease;
  animation: fadeInUp 0.5s ease forwards;
  animation-delay: 0.1s;
  opacity: 0;
}

.overview-card:nth-child(2) {
  animation-delay: 0.2s;
}

.overview-card:nth-child(3) {
  animation-delay: 0.3s;
}

.overview-card:active {
  transform: scale(0.96);
}

/* 主卡片 - 更大更突出 */
.main-card {
  flex: 1.3;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  padding: 28rpx 24rpx;
}

.main-card .card-value {
  font-size: 44rpx;
}

.card-glow {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.12) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.card-icon {
  font-size: 36rpx;
  line-height: 1;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.card-value {
  font-size: 36rpx;
  font-weight: 800;
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

.card-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================
   筛选排序栏
   ============================================ */
.filter-bar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--glass-bg);
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--glass-border);
}

.search-icon {
  font-size: 28rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 4rpx 8rpx;
}

.sort-selector {
  flex-shrink: 0;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--primary-gradient);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: transform 0.2s ease;
}

.sort-btn:active {
  transform: scale(0.95);
}

.sort-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.sort-arrow {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ============================================
   骨架屏样式
   ============================================ */
.skeleton-wrapper {
  position: relative;
  z-index: 2;
  padding: 0 24rpx;
}

.skeleton-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.skeleton-card {
  flex: 1;
  height: 140rpx;
  background: linear-gradient(90deg, #e0e5ec 25%, #f0f2f5 50%, #e0e5ec 75%);
  border-radius: 24rpx;
}

.skeleton-list {
  margin-top: 24rpx;
}

.skeleton-user-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(90deg, #e0e5ec 25%, #f0f2f5 50%, #e0e5ec 75%);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #d8dce6;
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-name {
  width: 160rpx;
  height: 32rpx;
  background: #d8dce6;
  border-radius: 8rpx;
}

.skeleton-row {
  width: 100%;
  height: 24rpx;
  background: #d8dce6;
  border-radius: 6rpx;
}

.skeleton-animate {
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ============================================
   用户列表
   ============================================ */
.user-list {
  position: relative;
  z-index: 2;
  padding: 0 24rpx;
}

.list-section {
  margin-top: 16rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.list-count {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.list-count text:first-child {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

.count-label {
  font-size: 22rpx;
  color: #999;
}

/* ============================================
   用户卡片 - 玻璃态设计（可展开）
   ============================================ */
.user-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--glass-bg);
  border-radius: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--glass-border);
  transition: all 0.3s ease;
  animation: fadeInUp 0.4s ease forwards;
  opacity: 0;
  overflow: hidden;
}

.user-card:nth-child(1) { animation-delay: 0.05s; }
.user-card:nth-child(2) { animation-delay: 0.1s; }
.user-card:nth-child(3) { animation-delay: 0.15s; }
.user-card:nth-child(4) { animation-delay: 0.2s; }
.user-card:nth-child(5) { animation-delay: 0.25s; }

.user-card.expanded {
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

/* 用户卡片头部 - 可点击展开 */
.user-card-header {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx;
  transition: background 0.2s ease;
}

.user-card-header:active {
  background: rgba(102, 126, 234, 0.05);
}

/* 头像区域 */
.user-avatar-wrapper {
  position: relative;
  width: 88rpx;
  height: 88rpx;
}

.avatar-ring {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
}

.avatar-ring.high {
  border-color: var(--activity-high);
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.3);
}

.avatar-ring.medium {
  border-color: var(--activity-medium);
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.3);
}

.avatar-ring.low {
  border-color: var(--activity-low);
}

.avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  object-fit: cover;
}

/* 活跃度指示灯 */
.activity-dot {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.activity-dot.high {
  background: var(--activity-high);
}

.activity-dot.medium {
  background: var(--activity-medium);
}

.activity-dot.low {
  background: var(--activity-low);
}

/* 用户信息 */
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 活跃度徽章 */
.activity-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.activity-badge.high {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.activity-badge.medium {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
}

.activity-badge.low {
  background: rgba(156, 163, 175, 0.12);
  color: #9ca3af;
}

/* 用户资产统计摘要 */
.user-asset-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.summary-icon {
  font-size: 22rpx;
}

.summary-value {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 访问时间（紧凑显示） */
.access-time-compact {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.access-time-text {
  font-size: 18rpx;
  color: #999;
}

.access-time-divider {
  font-size: 18rpx;
  color: #ccc;
}

/* 展开/收起按钮 */
.expand-btn {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.expand-btn.expanded {
  background: rgba(102, 126, 234, 0.15);
}

.expand-icon {
  font-size: 24rpx;
  color: #667eea;
  transition: transform 0.3s ease;
}

/* ============================================
   用户资产列表区域
   ============================================ */
.user-assets-section {
  padding: 0 24rpx 24rpx;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    max-height: 0;
  }
  to {
    opacity: 1;
    max-height: 1000rpx;
  }
}

.assets-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx dashed rgba(102, 126, 234, 0.2);
  margin-top: 8rpx;
}

.assets-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
}

.assets-count {
  font-size: 22rpx;
  color: #999;
}

/* 资产项 */
.asset-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: rgba(102, 126, 234, 0.04);
  border-radius: 16rpx;
  margin-top: 12rpx;
  transition: background 0.2s ease;
}

.asset-item:active {
  background: rgba(102, 126, 234, 0.08);
}

.asset-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.asset-icon {
  font-size: 28rpx;
}

.asset-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.asset-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.asset-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.asset-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-status-badge {
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
}

.asset-status-badge.active {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.asset-status-badge.retired {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
}

.asset-status-badge.sold {
  background: rgba(102, 126, 234, 0.12);
  color: #667eea;
}

.asset-stats-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.asset-stat {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.asset-stat .stat-label {
  font-size: 20rpx;
  color: #999;
}

.asset-stat .stat-value {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.asset-stat .stat-value.cost {
  color: #667eea;
}

/* 无资产提示 */
.no-assets-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-top: 12rpx;
  background: rgba(102, 126, 234, 0.04);
  border-radius: 16rpx;
}

.no-assets-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.no-assets-text {
  font-size: 24rpx;
  color: #999;
}

/* 统计信息 */
.user-stats {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-icon {
  font-size: 24rpx;
  width: 32rpx;
  text-align: center;
}

.stat-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  min-width: 100rpx;
}

.stat-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 卡片装饰 */
.card-decoration {
  position: absolute;
  top: 0;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background: radial-gradient(circle at top right, rgba(102, 126, 234, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* 底部留白 */
.list-spacer {
  height: 60rpx;
}

/* ============================================
   空状态 - 精致设计
   ============================================ */
.empty-state {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-visual {
  position: relative;
  margin-bottom: 32rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-face {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.face-eyes {
  display: flex;
  gap: 32rpx;
}

.eye {
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-pupil {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: #fff;
}

.face-mouth {
  width: 32rpx;
  height: 16rpx;
  border-radius: 16rpx 16rpx 0 0;
  border: 3rpx solid #667eea;
  border-bottom: none;
}

.empty-waves {
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 16rpx;
}

.wave {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(102, 126, 234, 0.3);
  animation: wave-float 2s ease-in-out infinite;
}

.wave-1 { animation-delay: 0s; }
.wave-2 { animation-delay: 0.3s; transform: scale(0.8); }
.wave-3 { animation-delay: 0.6s; transform: scale(0.6); }

@keyframes wave-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
}

/* ============================================
   搜索无结果状态
   ============================================ */
.search-empty {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.search-empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.search-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.search-empty-desc {
  font-size: 24rpx;
  color: #9ca3af;
}