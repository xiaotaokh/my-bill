/* pages/user-stats/user-stats.wxss - 现代金融科技风主题 */

/* Activity Levels - 使用全局主题变量 */
page {
  --activity-high: var(--activity-high);
  --activity-high-bg: var(--activity-high-bg);
  --activity-high-text: var(--activity-high-text);
  --activity-medium: var(--activity-medium);
  --activity-medium-bg: var(--activity-medium-bg);
  --activity-medium-text: var(--activity-medium-text);
  --activity-low: var(--activity-low);
}

.container {
  min-height: 100vh;
  background: var(--bg-base);
  padding: 0;
  position: relative;
}

/* 渐变背景头部 - 移除 */
.header-bg {
  display: none;
}

/* 装饰气泡 - 移除 */
.bg-decoration {
  display: none;
}

/* 页面标题 */
.page-header {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
}

.page-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-default);
  letter-spacing: 4rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 统计概览卡片组 */
.stats-overview {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.overview-card {
  position: relative;
  flex: 1;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(var(--shadow-rgb), 0.06);
  border: 1rpx solid var(--border-default);
  transition: transform 0.2s ease;
}

.overview-card:nth-child(2) {
}

.overview-card:nth-child(3) {
}

.overview-card:active {
  transform: scale(0.96);
}

/* 主卡片 - 更大更突出 */
.main-card {
  flex: 1.3;
  background: var(--bg-card);
  padding: 28rpx 24rpx;
}

.main-card .card-value {
  font-size: 44rpx;
}

.card-glow {
  display: none;
}

.card-icon {
  font-size: 36rpx;
  line-height: 1;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.card-value {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary-600);
  letter-spacing: 2rpx;
}

.card-label {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* 篰选排序栏 */
.filter-bar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(var(--shadow-rgb), 0.06);
  border: 1rpx solid var(--border-default);
}

.search-icon {
  font-size: 28rpx;
  color: var(--text-hint);
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-default);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 4rpx 8rpx;
}

.sort-selector {
  flex-shrink: 0;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--primary-600);
  border-radius: 12rpx;
  transition: transform 0.2s ease;
}

.sort-btn:active {
  transform: scale(0.95);
}

.sort-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-inverse);
}

.sort-arrow {
  font-size: 18rpx;
  color: var(--text-inverse);
}

/* 骨架屏样式 */
.skeleton-wrapper {
  position: relative;
  z-index: 2;
  padding: 0 24rpx;
}

.skeleton-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.skeleton-card {
  flex: 1;
  height: 140rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
}

.skeleton-list {
  margin-top: 24rpx;
}

.skeleton-user-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: var(--border-default);
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-name {
  width: 160rpx;
  height: 32rpx;
  background: var(--border-default);
  border-radius: 8rpx;
}

.skeleton-row {
  width: 100%;
  height: 24rpx;
  background: var(--border-default);
  border-radius: 6rpx;
}

/* 用户列表 */
.user-list {
  position: relative;
  z-index: 2;
  padding: 0 24rpx;
}

.list-section {
  margin-top: 16rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-default);
}

.list-count {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.list-count text:first-child {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-600);
}

.count-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 用户卡片 */
.user-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(var(--shadow-rgb), 0.06);
  border: 1rpx solid var(--border-default);
  transition: all 0.2s ease;
  overflow: hidden;
}

.user-card.expanded {
  box-shadow: 0 4rpx 12rpx rgba(var(--shadow-rgb), 0.1);
}

/* 用户卡片头部 - 可点击展开 */
.user-card-header {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx;
  transition: background 0.2s ease;
}

.user-card-header:active {
  background: var(--bg-subtle);
}

/* 头像区域 */
.user-avatar-wrapper {
  position: relative;
  width: 88rpx;
  height: 88rpx;
}

.avatar-ring {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
}

.avatar-ring.high {
  border-color: var(--activity-high);
}

.avatar-ring.medium {
  border-color: var(--activity-medium);
}

.avatar-ring.low {
  border-color: var(--border-default);
}

.avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  object-fit: cover;
}

/* 活跃度指示灯 */
.activity-dot {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid var(--bg-card);
}

.activity-dot.high {
  background: var(--activity-high);
}

.activity-dot.medium {
  background: var(--activity-medium);
}

.activity-dot.low {
  background: var(--activity-low);
}

/* 用户信息 */
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-default);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 活跃度徽章 */
.activity-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.activity-badge.high {
  background: var(--activity-high-bg);
  color: var(--activity-high-text);
}

.activity-badge.medium {
  background: var(--activity-medium-bg);
  color: var(--activity-medium-text);
}

.activity-badge.low {
  background: var(--bg-subtle);
  color: var(--text-hint);
}

/* 用户资产统计摘要 */
.user-asset-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.summary-icon {
  font-size: 22rpx;
}

.summary-value {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* 访问时间（紧凑显示） */
.access-time-compact {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.access-time-text {
  font-size: 18rpx;
  color: var(--text-hint);
}

.access-time-divider {
  font-size: 18rpx;
  color: var(--border-default);
}

/* 展开/收起按钮 */
.expand-btn {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-subtle);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.expand-btn.expanded {
  background: var(--bg-subtle);
}

.expand-icon {
  font-size: 24rpx;
  color: var(--primary-600);
  transition: transform 0.2s ease;
}

/* 用户资产列表区域 */
.user-assets-section {
  padding: 0 24rpx 24rpx;
}

.assets-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx dashed var(--border-default);
  margin-top: 8rpx;
}

.assets-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-600);
}

.assets-count {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 资产项 */
.asset-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
  margin-top: 12rpx;
  transition: background 0.2s ease;
}

.asset-item:active {
  background: var(--bg-card);
}

.asset-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.asset-icon {
  font-size: 28rpx;
}

.asset-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.asset-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.asset-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.asset-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-default);
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-status-badge {
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
}

.asset-status-badge.active {
  background: var(--success-bg);
  color: var(--primary-700);
}

.asset-status-badge.retired {
  background: var(--warning-bg);
  color: var(--warning);
}

.asset-status-badge.sold {
  background: var(--bg-subtle);
  color: var(--text-muted);
}

.asset-stats-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.asset-stat {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.asset-stat .stat-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

.asset-stat .stat-value {
  font-size: 22rpx;
  color: var(--text-default);
  font-weight: 500;
}

.asset-stat .stat-value.cost {
  color: var(--primary-600);
}

/* 无资产提示 */
.no-assets-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-top: 12rpx;
  background: var(--bg-subtle);
  border-radius: 12rpx;
}

.no-assets-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.5;
}

.no-assets-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 统计信息 */
.user-stats {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-icon {
  font-size: 24rpx;
  width: 32rpx;
  text-align: center;
}

.stat-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
  min-width: 100rpx;
}

.stat-value {
  font-size: 24rpx;
  color: var(--text-default);
  font-weight: 500;
}

/* 卡片装饰 - 移除 */
.card-decoration {
  display: none;
}

/* 底部留白 */
.list-spacer {
  height: 60rpx;
}

/* 空状态 */
.empty-state {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-visual {
  position: relative;
  margin-bottom: 32rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: var(--bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-face {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.face-eyes {
  display: flex;
  gap: 32rpx;
}

.eye {
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: var(--primary-600);
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-pupil {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: var(--text-inverse);
}

.face-mouth {
  width: 32rpx;
  height: 16rpx;
  border-radius: 16rpx 16rpx 0 0;
  border: 2rpx solid var(--primary-600);
  border-bottom: none;
}

.empty-waves {
  display: none;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-default);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 搜索无结果状态 */
.search-empty {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.search-empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.search-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-default);
  margin-bottom: 10rpx;
}

.search-empty-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}