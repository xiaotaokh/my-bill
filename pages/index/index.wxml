<!--index.wxml-->
<view class="container">
  <!-- 顶部背景 - 仅首页显示 -->
  <view class="header-bg" style="{{showSetting || showBatchDelete ? 'display: none;' : 'display: block;'}}"></view>

  <!-- 主内容区域 -->
  <view class="main-content" style="{{showSetting || showReport || showBatchDelete ? 'display: none;' : 'display: block;'}}">
    <!-- 日期显示 -->
    <view class="date-section">
      <view class="date-display">
        <text class="date-day">{{currentDay}}</text>
        <view class="date-info">
          <text class="date-month">{{currentMonth}}月 {{currentYear}}</text>
          <text class="date-week">{{currentWeek}}</text>
        </view>
      </view>
    </view>

    <!-- 总资产卡片 -->
    <view class="total-card">
      <view class="total-card-left">
        <view class="total-label">总资产</view>
        <view class="total-value" style="font-size: {{totalPriceSize}}rpx;">¥{{totalPrice}}</view>
      </view>
      <view class="total-divider"></view>
      <view class="total-card-right">
        <view class="daily-label">总日均成本</view>
        <view class="daily-value" style="font-size: {{dailyCostSize}}rpx;">¥{{dailyCost}}</view>
      </view>
      <view class="total-glow"></view>
    </view>

    <!-- 统计指标卡片 -->
    <view class="stats-section">
      <view class="stat-row">
        <view class="stat-item">
          <view class="stat-icon active-icon">
            <text class="iconfont">🚀</text>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{activeCount}}</text>
            <text class="stat-name">服役中</text>
          </view>
        </view>
        <view class="stat-item">
          <view class="stat-icon retired-icon">
            <text class="iconfont">🏠</text>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{retiredCount}}</text>
            <text class="stat-name">已退役</text>
          </view>
        </view>
        <view class="stat-item">
          <view class="stat-icon sold-icon">
            <text class="iconfont">💰</text>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{soldCount}}</text>
            <text class="stat-name">已卖出</text>
          </view>
        </view>
        <view class="stat-item">
          <view class="stat-icon total-icon">
            <text class="iconfont">🗂️</text>
          </view>
          <view class="stat-content">
            <text class="stat-number">{{statsTotalCount}}</text>
            <text class="stat-name">资产总数</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 筛选和排序 -->
    <view class="filter-section">
      <!-- 分类筛选 - 带图标 -->
      <view class="category-bar">
        <!-- 全部分类 -->
        <view
          class="category-pill {{activeCategory === 'all' ? 'active' : ''}}"
          bindtap="filterByCategory"
          data-category="all"
        >
          <text class="pill-icon">🏷️</text>
          <text class="pill-text">全部</text>
        </view>
        <!-- 分类列表 -->
        <block wx:for="{{categoryList}}" wx:key="name">
          <view
            class="category-pill {{activeCategory === item.name ? 'active' : ''}}"
            bindtap="filterByCategory"
            data-category="{{item.name}}"
          >
            <image wx:if="{{item.displayIcon}}" class="pill-icon-img" src="{{item.displayIcon}}" mode="aspectFit"></image>
            <text wx:else class="pill-icon">{{item.icon}}</text>
            <text class="pill-text">{{item.name}}</text>
          </view>
        </block>
      </view>
      <!-- 状态筛选 -->
      <view class="filter-bar">
        <view
          class="filter-pill {{activeStatus === 'all' ? 'active-all' : ''}}"
          bindtap="filterByStatus"
          data-status="all"
        >全部</view>
        <view
          class="filter-pill {{activeStatus === 'active' ? 'active-active' : ''}}"
          bindtap="filterByStatus"
          data-status="active"
        >服役中</view>
        <view
          class="filter-pill {{activeStatus === 'retired' ? 'active-retired' : ''}}"
          bindtap="filterByStatus"
          data-status="retired"
        >已退役</view>
        <view
          class="filter-pill {{activeStatus === 'sold' ? 'active-sold' : ''}}"
          bindtap="filterByStatus"
          data-status="sold"
        >已卖出</view>
      </view>
    </view>

    <!-- 资产列表 -->
    <view class="asset-list">
      <view class="list-header">
        <view class="list-title-wrapper">
          <view class="list-title-box">
            <text class="list-title">我的资产</text>
            <view class="list-count-badge">
              <text>{{filteredAssets.length}}</text>
            </view>
          </view>
          <view wx:if="{{filteredAssets.length > 0}}" class="list-price-group">
            <view class="list-total-price">
              <text class="price-value">¥{{filteredTotalPrice}}</text>
              <text class="price-label">/总</text>
            </view>
            <view class="list-total-price">
              <text class="price-value">¥{{filteredDailyCost}}</text>
              <text class="price-label">/日</text>
            </view>
          </view>
        </view>
        <view class="sort-wrapper">
          <picker mode="selector" range="{{sortOptions}}" bindchange="changeSort">
            <view class="sort-btn">
              <text class="sort-text">{{sortOptions[currentSortIndex]}}</text>
              <text class="sort-arrow {{sortOrder === 'desc' ? 'desc' : 'asc'}}">▼</text>
            </view>
          </picker>
        </view>
      </view>

      <block wx:if="{{filteredAssets.length > 0}}">
        <view
          class="asset-card"
          wx:for="{{filteredAssets}}"
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="card-left">
            <view class="asset-avatar">
              <image wx:if="{{item.displayIcon}}" class="avatar-img" src="{{item.displayIcon}}" mode="aspectFit"></image>
              <text wx:else class="avatar-icon">{{item.icon || '📦'}}</text>
            </view>
          </view>
          <view class="card-content">
            <view class="card-header">
              <view class="name-row">
                <text class="asset-name">{{item.name}}</text>
                <view class="asset-badge {{item.status}}">
                  <text>{{item.status === 'active' ? '服役中' : item.status === 'retired' ? '已退役' : '已卖出'}}</text>
                </view>
              </view>
              <!-- 名称下方的标签信息 -->
              <view class="name-sub-info">
                <view wx:if="{{item.excludeTotal || item.excludeDaily}}" class="exclude-tags">
                  <text wx:if="{{item.excludeTotal}}" class="exclude-tag total">不计入总资产</text>
                  <text wx:if="{{item.excludeDaily}}" class="exclude-tag daily">不计入总日均</text>
                </view>
                <view wx:if="{{activeCategory === 'all'}}" class="category-tag-inline">
                  <image wx:if="{{item.categoryIconUrl}}" class="tag-icon-inline" src="{{item.categoryIconUrl}}" mode="aspectFit"></image>
                  <text wx:else class="tag-icon-text-inline">{{item.categoryIcon || '📦'}}</text>
                  <text class="tag-text-inline">{{item.category}}</text>
                </view>
              </view>
            </view>
            <view class="card-info">
              <text class="purchase-date">{{item.dateRange}}</text>
            </view>
            <view class="card-stats">
              <block wx:if="{{item.status === 'active'}}">
                <view class="stat-item {{item.excludeDaily ? 'has-badge' : ''}}">
                  <text class="stat-label">日均成本</text>
                  <text class="stat-value cost {{item.excludeDaily ? 'excluded' : 'included'}}">¥{{item.dailyCost}}/天</text>
                  <text wx:if="{{item.excludeDaily}}" class="exclude-badge">不计入</text>
                </view>
                <view class="stat-divider"></view>
              </block>
              <block wx:else>
                <view class="stat-item">
                  <text class="stat-label">折合每日</text>
                  <text class="stat-value cost">¥{{item.dailyEquivalent}}/天</text>
                </view>
                <view class="stat-divider"></view>
                <view class="stat-item has-badge">
                  <text class="stat-label">日均成本</text>
                  <text class="stat-value cost excluded">¥{{item.dailyCost}}/天</text>
                  <text class="exclude-badge">不计入</text>
                </view>
                <view class="stat-divider"></view>
              </block>
              <view class="stat-item">
                <text class="stat-label">已使用(含今天)</text>
                <text class="stat-value">{{item.usedDays}}天</text>
              </view>
              <view class="stat-divider"></view>
              <view class="stat-item {{item.excludeTotal ? 'has-badge' : ''}}">
                <text class="stat-label">价格</text>
                <text class="stat-value price {{item.excludeTotal ? 'excluded' : ''}}">¥{{item.price}}</text>
                <text wx:if="{{item.excludeTotal}}" class="exclude-badge">不计入</text>
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:else>
        <view class="empty-state">
          <view class="empty-bubble bubble-1"></view>
          <view class="empty-bubble bubble-2"></view>
          <view class="empty-bubble bubble-3"></view>
          <view class="empty-content">
            <view class="empty-face">
              <view class="face-eyes">
                <view class="eye eye-left">
                  <view class="eye-pupil"></view>
                </view>
                <view class="eye eye-right">
                  <view class="eye-pupil"></view>
                </view>
              </view>
              <view class="face-mouth"></view>
            </view>
            <text class="empty-title">空空如也~</text>
            <text class="empty-desc">快去添加你的第一笔资产吧</text>
          </view>
        </view>
      </block>

      <view class="list-bottom-spacer"></view>
    </view>
  </view>

  <!-- 设置视图 -->
  <view class="setting-content" style="{{showSetting ? 'display: block;' : 'display: none;'}}">
    <!-- 设置头部 -->
    <view class="setting-header">
      <text class="setting-title">设置</text>
    </view>

    <!-- 功能列表 -->
    <view class="setting-list">
      <!-- 分类管理 -->
      <view class="setting-item-full" bindtap="navigateToCategoryManage">
        <view class="setting-icon-box">
          <text>🏷️</text>
        </view>
        <view class="setting-info">
          <text class="setting-title-text">分类管理</text>
          <text class="setting-desc">管理资产分类</text>
        </view>
        <view class="setting-arrow">
          <text class="arrow">›</text>
        </view>
      </view>

      <!-- 批量删除资产 -->
      <view class="setting-item-full warm-item" bindtap="enterBatchDelete">
        <view class="setting-icon-box warm-icon">
          <text>🗑️</text>
        </view>
        <view class="setting-info">
          <text class="setting-title-text">批量删除资产</text>
          <text class="setting-desc">选择多个资产一键删除</text>
        </view>
        <view class="setting-arrow warm-arrow">
          <text class="arrow">›</text>
        </view>
      </view>

      <!-- 关于 -->
      <view class="setting-item-full" bindtap="showAboutInfo">
        <view class="setting-icon-box">
          <text>ℹ️</text>
        </view>
        <view class="setting-info">
          <text class="setting-title-text">关于</text>
          <text class="setting-desc">了解我的账本</text>
        </view>
        <view class="setting-arrow">
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text">我的账本 v1.0.0</text>
    </view>
  </view>

  <!-- 批量删除视图 -->
  <view class="batch-delete-content" style="{{showBatchDelete ? 'display: block;' : 'display: none;'}}">
    <!-- 批量删除头部 -->
    <view class="batch-header">
      <view class="batch-back" bindtap="exitBatchDelete">
        <text class="back-icon">←</text>
      </view>
      <view class="batch-header-center">
        <text class="batch-title">选择要删除的资产</text>
        <text class="batch-subtitle">已选择 {{selectedAssets.length}} 项</text>
      </view>
      <view class="batch-placeholder"></view>
    </view>

    <!-- 全选操作栏 -->
    <view class="batch-action-bar">
      <view class="select-all-btn {{isAllSelected ? 'selected' : ''}}" bindtap="toggleSelectAll">
        <view class="checkbox {{isAllSelected ? 'checked' : ''}}">
          <text wx:if="{{isAllSelected}}" class="check-icon">✓</text>
        </view>
        <text class="select-all-text">{{isAllSelected ? '取消全选' : '全选'}}</text>
      </view>
      <view class="filter-hint">
        <text>共 {{batchAssetList.length}} 项资产</text>
      </view>
    </view>

    <!-- 资产选择列表 -->
    <scroll-view class="batch-asset-list" scroll-y="true">
      <view class="batch-asset-grid">
        <view
          class="batch-asset-card {{item._selected ? 'selected' : ''}}"
          wx:for="{{batchAssetList}}"
          wx:key="_id"
          bindtap="toggleSelectAsset"
          data-id="{{item._id}}"
        >
          <!-- 资产图标 -->
          <view class="batch-asset-icon">
            <image wx:if="{{item.displayIcon}}" class="icon-img" src="{{item.displayIcon}}" mode="aspectFit"></image>
            <text wx:else class="icon-emoji">{{item.icon || '📦'}}</text>
          </view>

          <!-- 资产信息 -->
          <view class="batch-asset-info">
            <view class="batch-asset-header">
              <text class="batch-asset-name">{{item.name}}</text>
              <view class="batch-status-badge {{item.status}}">
                <text>{{item.status === 'active' ? '服役中' : item.status === 'retired' ? '已退役' : '已卖出'}}</text>
              </view>
            </view>
            <view class="batch-asset-meta">
              <text class="batch-asset-price">¥{{item.price}}</text>
              <text class="batch-asset-divider">·</text>
              <text class="batch-asset-date">{{item.dateRange}}</text>
              <text class="batch-asset-divider">·</text>
              <text class="batch-asset-category">{{item.category}}</text>
            </view>
          </view>

          <!-- 选中状态指示器 -->
          <view class="select-indicator">
            <view class="select-circle {{item._selected ? 'checked' : ''}}">
              <text wx:if="{{item._selected}}" class="select-check">✓</text>
            </view>
          </view>

          <!-- 装饰元素 -->
          <view class="card-decoration"></view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{batchAssetList.length === 0}}" class="batch-empty">
        <view class="empty-sun">
          <view class="sun-face"></view>
          <view class="sun-ray ray-1"></view>
          <view class="sun-ray ray-2"></view>
          <view class="sun-ray ray-3"></view>
        </view>
        <text class="empty-title">暂无资产可删除</text>
        <text class="empty-desc">快去添加你的第一个资产吧~</text>
      </view>

      <!-- 底部留白 -->
      <view class="batch-list-spacer"></view>
    </scroll-view>

    <!-- 底部删除按钮 -->
    <view class="batch-delete-footer">
      <view class="delete-summary">
        <text class="summary-text">已选择</text>
        <text class="summary-count">{{selectedAssets.length}}</text>
        <text class="summary-text">项</text>
        <text wx:if="{{selectedTotalPrice > 0}}" class="summary-price">¥{{selectedTotalPrice}}</text>
      </view>
      <view class="delete-btn-wrapper">
        <view class="delete-btn {{selectedAssets.length > 0 ? 'active' : 'disabled'}}" bindtap="confirmBatchDelete">
          <text class="delete-btn-text">删除选中</text>
        </view>
      </view>
    </view>

    <!-- 背景装饰 -->
    <view class="batch-bg-decor">
      <view class="decor-circle circle-1"></view>
      <view class="decor-circle circle-2"></view>
      <view class="decor-circle circle-3"></view>
    </view>
  </view>

  <!-- 底部悬浮：首页/统计/设置切换 + 新增资产按钮 -->
  <view class="bottom-controls" style="{{showBatchDelete ? 'display: none;' : 'display: flex;'}}">
    <!-- 首页/统计/设置切换悬浮按钮组 -->
    <view class="mode-switch-fab">
      <view class="fab-group">
        <view class="fab-item {{!showSetting && !showReport ? 'active' : ''}}" bindtap="switchToHome">
          <text class="fab-icon">🏠</text>
          <text class="fab-label">首页</text>
        </view>
        <view class="fab-item {{showReport ? 'active' : ''}}" bindtap="switchToReport">
          <image class="fab-icon-svg" src="/images/pie-chart.svg" mode="aspectFit"></image>
          <text class="fab-label">统计</text>
        </view>
        <view class="fab-item {{showSetting ? 'active' : ''}}" bindtap="navigateToSetting">
          <text class="fab-icon">⚙️</text>
          <text class="fab-label">设置</text>
        </view>
      </view>
    </view>

    <!-- 新增资产悬浮按钮 -->
    <view class="add-asset-fab" bindtap="goToAdd">
      <view class="fab-inner">
        <text class="fab-icon">+</text>
      </view>
      <view class="fab-glow"></view>
    </view>
  </view>

  <!-- 统计视图 -->
  <view class="report-view" wx:if="{{showReport}}">
    <!-- 加载状态 -->
    <view wx:if="{{reportLoading}}" class="report-loading">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{reportEmpty}}" class="report-empty">
      <view class="empty-face">
        <view class="face-eyes">
          <view class="eye eye-left"><view class="eye-pupil"></view></view>
          <view class="eye eye-right"><view class="eye-pupil"></view></view>
        </view>
        <view class="face-mouth"></view>
      </view>
      <text class="empty-title">暂无数据</text>
      <text class="empty-desc">添加资产后即可查看统计数据</text>
    </view>

    <!-- 统计内容 -->
    <view wx:else class="report-content">
      <!-- 统计概览 -->
      <view class="report-stats-card">
        <view class="stats-header">
          <text class="stats-title">资产总览</text>
        </view>
        <view class="stats-row">
          <view class="stat-card">
            <view class="stat-value-wrapper">
              <text class="stat-value">{{reportTotalAssets}}</text>
              <text class="stat-unit">件</text>
            </view>
            <text class="stat-label">资产总数</text>
          </view>
          <view class="stat-card">
            <view class="stat-value-wrapper">
              <text class="stat-value">¥{{reportTotalPrice}}</text>
            </view>
            <text class="stat-sub">{{reportIncludedCount}}件资产</text>
            <text class="stat-label">总资产</text>
          </view>
        </view>
        <view class="stats-row">
          <view class="stat-card">
            <view class="stat-value-wrapper">
              <text class="stat-value">{{reportCategoryStats.length}}</text>
              <text class="stat-unit">个</text>
            </view>
            <text class="stat-label">分类</text>
          </view>
          <view class="stat-card excluded">
            <view class="stat-value-wrapper">
              <text class="stat-value">¥{{reportExcludedPrice}}</text>
            </view>
            <text class="stat-sub">{{reportExcludedCount}}件资产</text>
            <text class="stat-label">不计入总资产</text>
          </view>
        </view>
      </view>

      <!-- 环形图 -->
      <view class="report-chart-section">
        <view class="section-header">
          <text class="section-title">资产分类</text>
          <image class="section-icon-svg" src="/images/pie-chart.svg" mode="aspectFit"></image>
        </view>
        <view class="chart-wrapper" style="height: 450rpx;">
          <ec-canvas id="pie-chart" canvas-id="pie-chart" ec="{{ pieEc }}"></ec-canvas>
        </view>
        <view class="category-list" wx:if="{{reportCategoryStats.length > 0}}">
          <view class="category-item" wx:for="{{reportCategoryStats}}" wx:key="name">
            <view class="category-left">
              <view class="category-dot" style="background: {{reportColors[index % reportColors.length]}}"></view>
              <image wx:if="{{item.displayIcon}}" class="category-icon" src="{{item.displayIcon}}" mode="aspectFit"></image>
              <text wx:elif="{{item.icon}}" class="category-emoji">{{item.icon}}</text>
              <text class="category-name">{{item.name}}</text>
            </view>
            <view class="category-right">
              <text class="category-count">{{item.count}}件</text>
              <text class="category-price">¥{{item.totalFixed}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 折线图 -->
      <view class="report-chart-section">
        <view class="section-header">
          <text class="section-title">资产时间线</text>
          <image class="section-icon-svg" src="/images/line-chart.svg" mode="aspectFit"></image>
        </view>
        <view class="chart-wrapper" style="height: 500rpx;">
          <ec-canvas id="line-chart" canvas-id="line-chart" ec="{{ lineEc }}"></ec-canvas>
        </view>
      </view>

      <!-- 时间段资产统计 -->
      <view class="report-chart-section">
        <view class="section-header">
          <text class="section-title">资产时间段</text>
          <image class="section-icon-svg" src="/images/bar-chart.svg" mode="aspectFit"></image>
        </view>

        <!-- 时间段选择器 -->
        <view class="time-period-selector">
          <view
            wx:for="{{['all', 'year', 'quarter', 'month', 'week']}}"
            wx:key="*this"
            class="period-pill {{activeTimePeriod === item ? 'active' : ''}}"
            bindtap="selectTimePeriod"
            data-period="{{item}}"
          >
            {{item === 'week' ? '本周' : item === 'month' ? '本月' : item === 'quarter' ? '本季度' : item === 'year' ? '本年' : '全部'}}
          </view>
        </view>

        <!-- 时间线粒度选择器 (仅"全部"时显示) -->
        <view wx:if="{{activeTimePeriod === 'all'}}" class="granularity-selector">
          <text class="granularity-label">时间线:</text>
          <view
            wx:for="{{['year', 'quarter', 'month']}}"
            wx:key="*this"
            class="granularity-pill {{activeGranularity === item ? 'active' : ''}}"
            bindtap="selectGranularity"
            data-granularity="{{item}}"
          >
            {{item === 'year' ? '按年' : item === 'quarter' ? '按季度' : '按月'}}
          </view>
        </view>

        <!-- 统计概览 -->
        <view wx:if="{{timePeriodStats}}" class="time-stats-summary">
          <view class="summary-item">
            <text class="summary-label">总金额</text>
            <text class="summary-value">¥{{timePeriodStats.summary.totalAmount}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">资产数</text>
            <text class="summary-value">{{timePeriodStats.summary.totalCount}}件</text>
          </view>
        </view>

        <!-- 柱状图 -->
        <view wx:if="{{timePeriodStats && timePeriodStats.data.length > 0}}" class="chart-wrapper" style="height: 400rpx;">
          <ec-canvas id="time-chart" canvas-id="time-chart" ec="{{ timePeriodEc }}"></ec-canvas>
        </view>

        <!-- 空状态提示 -->
        <view wx:if="{{timePeriodStats && timePeriodStats.data.length === 0}}" class="time-empty-state">
          <text class="empty-text">该时间段内暂无资产记录</text>
        </view>
      </view>

      <view class="report-bottom-spacer"></view>
    </view>

    <!-- 背景装饰 -->
    <view class="report-bg-decor">
      <view class="decor-circle decor-1"></view>
      <view class="decor-circle decor-2"></view>
      <view class="decor-circle decor-3"></view>
    </view>
  </view>

  <!-- 回到顶部悬浮按钮 -->
  <view class="back-to-top-fab {{showBackToTop && !showBatchDelete ? 'show' : ''}}" bindtap="scrollToTop" catchtouchmove="preventTouchMove">
    <text class="back-top-icon">↑</text>
  </view>
</view>