/* index.wxss - 温暖极简浅色主题 */

/* 欢迎提示弹窗 */
.welcome-toast {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  padding: 40rpx 30rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
  opacity: 0;
  visibility: hidden;
  transform: translateY(-100%);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.welcome-toast.show {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.welcome-toast-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-neumorph-sm);
  border: 1rpx solid var(--border-light);
}

.welcome-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  background: var(--primary-500);
  border-radius: 50%;
  flex-shrink: 0;
}

.welcome-icon {
  font-size: 24rpx;
  color: var(--text-inverse);
}

.welcome-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-default);
  letter-spacing: 1rpx;
}

.welcome-sub {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 0.5rpx;
}

.welcome-progress-bar {
  height: 4rpx;
  margin-top: 16rpx;
  background: var(--primary-100);
  border-radius: 2rpx;
  overflow: hidden;
  position: relative;
  --duration: 10s;
}

.welcome-progress-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 0;
  background: var(--primary-500);
  border-radius: 2rpx;
}

.welcome-toast.show .welcome-progress-bar::after {
  animation: progress-fill var(--duration) linear 0.4s forwards;
}

@keyframes progress-fill {
  from {
    width: 0;
  }
  to {
    width: 100%;
  }
}

.welcome-close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  transition: opacity 0.15s ease;
}

.welcome-close-btn:active {
  opacity: 0.5;
}

.welcome-close-icon {
  font-size: 32rpx;
  color: var(--text-hint);
  line-height: 1;
}

.container {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
}

.main-content {
  position: relative;
}

/* 日期显示 - 简化样式 */
.date-section {
  position: relative;
  z-index: 1;
  padding: 0;
  margin-bottom: 0;
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 20rpx;
}

.date-left {
  display: flex;
  align-items: flex-end;
  gap: 0;
}

.date-day {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-default);
  line-height: 1;
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 6rpx;
  margin-left: 12rpx;
}

.date-month {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.date-week {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* 用户头像和昵称 */
.user-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 10rpx 2rpx;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.user-profile:active {
  opacity: 0.7;
}

.header-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.header-nickname {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-default);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 天气显示 */
.weather-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
}

.weather-icon {
  font-size: 44rpx;
}

.weather-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
}

.weather-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.weather-temp {
  font-size: 32rpx;
  color: var(--text-default);
  font-weight: 700;
  line-height: 1.2;
}

.weather-text {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.2;
}

.weather-range {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.temp-max {
  color: var(--text-default);
}

.temp-divider {
  color: var(--border-default);
  margin: 0 2rpx;
}

.temp-min {
  color: var(--text-hint);
}

/* 总资产卡片 - 左右布局 */
.total-card {
  position: relative;
  margin: 0 20rpx 24rpx;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-700) 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(var(--primary-600-rgb), 0.25), 0 2rpx 8rpx rgba(var(--primary-600-rgb), 0.1);
  border: none;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  grid-template-rows: auto auto auto;
  column-gap: 40rpx;
  row-gap: 16rpx;
  align-items: center;
}

.total-label {
  grid-area: 1 / 1 / 2 / 2;
  font-size: 24rpx;
  color: rgba(var(--text-inverse-rgb), 0.75);
  font-weight: 500;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  line-height: 1;
  min-width: 0;
}

.total-label text,
.daily-label text {
  min-width: 0;
  overflow-wrap: anywhere;
}

.total-value {
  grid-area: 2 / 1 / 3 / 2;
  font-weight: 800;
  color: var(--text-inverse);
  letter-spacing: 2rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.card-divider {
  grid-area: 1 / 2 / 3 / 3;
  width: 1rpx;
  align-self: stretch;
  background: linear-gradient(
    to bottom,
    transparent 10%,
    rgba(var(--text-inverse-rgb), 0.15) 10%,
    rgba(var(--text-inverse-rgb), 0.15) 90%,
    transparent 90%
  );
}

.daily-label {
  grid-area: 1 / 3 / 2 / 4;
  font-size: 22rpx;
  color: rgba(var(--text-inverse-rgb), 0.6);
  font-weight: 500;
  text-align: center;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.daily-value {
  grid-area: 2 / 3 / 3 / 4;
  font-weight: 700;
  color: var(--text-inverse);
  white-space: nowrap;
  text-align: center;
}

.amount-toggle {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.75;
  flex-shrink: 0;
  margin-left: 14rpx;
}

.amount-toggle:active {
  opacity: 1;
}

.metric-tip-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.7;
  flex-shrink: 0;
}

.metric-tip-icon:active {
  opacity: 1;
}

.excluded-summary {
  grid-area: 3 / 1 / 4 / 4;
  font-size: 20rpx;
  color: rgba(var(--text-inverse-rgb), 0.62);
  line-height: 1.35;
  text-align: center;
  min-width: 0;
}

.excluded-count {
  display: inline-block;
  min-width: 28rpx;
  margin: 0 4rpx;
  padding: 0 8rpx;
  border-radius: 8rpx;
  font-weight: 800;
  color: var(--text-inverse);
  background: rgba(var(--text-inverse-rgb), 0.16);
  text-align: center;
}

.total-glow {
  display: none;
}

/* 统计指标卡片 */
.stats-section {
  position: relative;
  z-index: 1;
  padding: 0 20rpx;
  margin-bottom: 18rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  border-radius: 28rpx;
  padding: 16rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s ease;
  position: relative;
  min-width: 0;
}

.active-item,
.pending-item,
.retired-item,
.sold-item {
  border: 2rpx solid transparent;
  box-shadow: inset 0 -1rpx 0 var(--shadow-subtle);
}

.active-item.stat-active,
.pending-item.stat-active,
.retired-item.stat-active,
.sold-item.stat-active {
  border: 2rpx solid var(--primary-600);
  box-shadow: var(--shadow-neumorph-sm);
}

/* 激活状态深色叠层 */
.stat-active::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--shadow-active-overlay);
  border-radius: 28rpx;
  pointer-events: none;
}

.stat-item.stat-active .stat-icon {
  background: transparent;
  transform: scale(1.12);
}

.stat-item.stat-active .stat-number {
  color: var(--accent-bg-text-active);
}

.stat-item.stat-active .stat-name {
  color: var(--accent-bg-text-active);
}

.stat-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.stat-icon-svg {
  width: 34rpx;
  height: 34rpx;
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  flex: 1;
  min-width: 0;
  width: 100%;
}

.stat-number {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent-bg-text);
}

.active-item .stat-number {
  color: var(--accent-bg-text);
}

.retired-item .stat-number {
  color: var(--accent-bg-text);
}

.sold-item .stat-number {
  color: var(--accent-bg-text-muted);
}

.stat-name {
  font-size: 18rpx;
  color: var(--accent-bg-text-muted);
  width: 100%;
  min-width: 0;
  text-align: center;
  line-height: 22rpx;
  white-space: normal;
  overflow-wrap: anywhere;
}

.asset-content-panel {
  position: relative;
  z-index: 1;
  margin: 0 20rpx;
  overflow: hidden;
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-default);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow:
    0 -4rpx 18rpx rgba(var(--shadow-rgb), 0.08),
    0 8rpx 28rpx rgba(var(--shadow-rgb), 0.12);
}

/* 筛选和排序 */
.filter-section {
  position: relative;
  z-index: 1;
  margin: 0;
  padding: 16rpx 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
  box-shadow: inset 0 -1rpx 0 rgba(var(--neutral-900-rgb), 0.04);
  box-sizing: border-box;
}

/* ============================================
   分类筛选栏 - 标签云风格（轻盈、可横向滚动）
   ============================================ */
.category-bar {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 4rpx 2rpx 10rpx;
  /* 隐藏滚动条 */
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.category-bar::-webkit-scrollbar {
  display: none;
}

.category-pill {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 12rpx 18rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-muted);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  z-index: 0;
  overflow: visible;
}

.category-pill:active {
  transform: scale(0.96);
}

.category-pill.active {
  background: transparent;
  color: var(--primary-600);
  border-color: transparent;
  box-shadow: none;
  font-weight: 700;
}

.category-pill.active::after {
  content: '';
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 6rpx;
  height: 24rpx;
  z-index: 0;
  border-radius: 72% 38% 64% 44% / 52% 68% 36% 58%;
  background: linear-gradient(
    100deg,
    rgba(var(--primary-600-rgb), 0.16) 0%,
    rgba(var(--primary-600-rgb), 0.42) 24%,
    rgba(var(--primary-600-rgb), 0.36) 68%,
    rgba(var(--primary-600-rgb), 0.14) 100%
  );
  transform: rotate(-2deg) skewX(-7deg);
  box-shadow:
    -6rpx 2rpx 0 rgba(var(--primary-600-rgb), 0.18),
    8rpx -1rpx 0 rgba(var(--primary-600-rgb), 0.16),
    0 5rpx 0 rgba(var(--primary-600-rgb), 0.14);
}

.category-pill.active::before {
  content: '';
  position: absolute;
  left: 18rpx;
  right: 16rpx;
  bottom: 15rpx;
  height: 8rpx;
  z-index: 0;
  border-radius: 999rpx;
  background: rgba(var(--primary-600-rgb), 0.52);
  transform: rotate(1deg) skewX(8deg);
}

/* 分类图标 - emoji */
.pill-icon {
  font-size: 26rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

/* 分类图标 - 图片 */
.pill-icon-img {
  width: 32rpx;
  height: 32rpx;
  position: relative;
  z-index: 1;
}

.pill-text {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 28rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

/* 新增类别按钮 - 虚线边框设计 */
.category-add {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--primary-500);
  background: var(--primary-soft);
  border: 2rpx dashed var(--primary-400);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-add:active {
  background: var(--primary-100);
  border-color: var(--primary-500);
  transform: scale(0.96);
}

.category-add .add-icon {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

.sort-wrapper {
  display: flex;
  align-items: center;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0;
  font-size: 22rpx;
}

.sort-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-neumorph-sm);
}

.sort-text {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--primary-600);
  line-height: 1;
}

.sort-arrow {
  font-size: 16rpx;
  color: var(--text-hint);
  transition: transform 0.3s ease;
}

.sort-arrow.desc {
  transform: rotate(0deg);
}

.sort-arrow.asc {
  transform: rotate(180deg);
}

/* 资产列表 - 无限滚动 */
.asset-list {
  position: relative;
  z-index: 1;
  margin-top: 0;
  padding: 18rpx 20rpx 200rpx;
  width: 100%;
  box-sizing: border-box;
  background: var(--bg-base);
  border-radius: 0;
  box-shadow: inset 0 8rpx 18rpx rgba(var(--shadow-rgb), 0.08);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx 2rpx;
}

.list-title-wrapper {
  display: flex;
  align-items: center;
  gap: 34rpx;
}

.list-title-box {
  position: relative;
  display: flex;
  align-items: flex-start;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-default);
}

.list-count-badge {
  position: absolute;
  top: -8rpx;
  right: -30rpx;
  padding: 4rpx 10rpx;
  background: var(--primary-600);
  border-radius: 16rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: var(--text-inverse);
  box-shadow: var(--shadow-neumorph-sm);
}

.list-count-right {
  display: flex;
  align-items: center;
}

.list-count-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--warning);
  line-height: 1;
}

.list-count-label {
  font-size: 18rpx;
  font-weight: 500;
  color: var(--text-muted);
  margin-left: 2rpx;
  line-height: 1;
}

.list-count-badge text {
  line-height: 1;
}

/* 视图切换按钮 */
.view-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.view-toggle:active {
  background: var(--bg-subtle);
}

.toggle-icon {
  width: 32rpx;
  height: 32rpx;
}

.list-total-price {
  display: flex;
  align-items: flex-end;
}

.list-price-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.price-divider {
  width: 2rpx;
  height: 24rpx;
  background: var(--border-default);
  border-radius: 1rpx;
  flex-shrink: 0;
}

.list-total-price .price-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-600);
  line-height: 1;
}

/* /总 价格数字 - 暖棕 */
.list-total-price.is-total .price-value {
  color: var(--amber);
}

/* /日 价格数字 - 绿色 */
.list-total-price.is-daily .price-value {
  color: var(--success);
}

.list-total-price .price-label {
  font-size: 18rpx;
  font-weight: 500;
  color: var(--text-muted);
  margin-left: 2rpx;
  line-height: 1;
}

/* 资产卡片 */
.asset-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(var(--shadow-rgb), 0.30), 0 8rpx 16rpx rgba(var(--shadow-rgb), 0.18);
  border: 1rpx solid rgba(var(--shadow-rgb), 0.35);
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  width: 100%;
  box-sizing: border-box;
  position: relative;
}

.asset-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-neumorph-sm);
}

/* 简单视图 - 瀑布流 */
.simple-asset-grid {
  display: flex;
  align-items: flex-start;
  width: 100%;
  box-sizing: border-box;
  padding: 0;
}

.masonry-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.masonry-col + .masonry-col {
  margin-left: 15rpx;
}

.asset-card-simple {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
  box-shadow: -3rpx -3rpx 8rpx rgba(var(--text-inverse-rgb), 0.6), 3rpx 3rpx 16rpx rgba(var(--shadow-rgb), 0.22);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-evenly;
}

.asset-card-simple:active {
  transform: scale(0.97);
}

.simple-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin: 20rpx auto 12rpx;
  flex-shrink: 0;
}

.simple-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.simple-avatar-icon {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  line-height: 1;
}

.simple-name {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent-bg-text);
  text-align: center;
  line-height: 1.3;
  word-break: break-all;
}

.simple-cost {
  display: block;
  font-size: 22rpx;
  font-weight: 800;
  color: var(--accent-bg-primary);
  text-align: center;
}

/* 复杂模式资产卡片文字（主题化） */
.asset-card .asset-name {
  color: var(--card-name);
}

.asset-card .purchase-date {
  color: var(--card-date);
}

.asset-card .card-stats .stat-label {
  color: var(--card-label);
}

.asset-card .card-stats .stat-value {
  color: var(--card-value);
}

.asset-card .card-stats .stat-value.cost.included {
  color: var(--card-primary);
}

.asset-card .card-stats .stat-value.price {
  color: var(--card-primary);
}

.asset-card .period-number {
  color: var(--card-primary);
}

.asset-card .period-symbol {
  color: var(--card-muted);
}

.asset-card .category-tag-inline {
  color: var(--card-category-text);
  background: var(--card-category-bg);
}

/* 简单模式资产卡片文字（主题化） */
.asset-card-simple .simple-name {
  color: var(--simple-card-name);
}

.asset-card-simple .simple-cost {
  color: var(--simple-card-cost);
}

.card-left {
  flex-shrink: 0;
  width: 64rpx;
}

.asset-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-icon {
  font-size: 40rpx;
  line-height: 1;
}

.card-content {
  flex: 1;
  min-width: 0;
}

/* 资产类型角标 - 卡片左上角 */
.asset-type-corner {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.type-corner-icon {
  width: 32rpx;
  height: 32rpx;
}

.card-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.name-with-category {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  overflow: hidden;
}

/* 名称下方的标签信息 */
.name-sub-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.asset-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent-bg-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.asset-badge.active {
  background: var(--success-bg);
  color: var(--success);
  border: 1rpx solid rgba(var(--primary-600-rgb), 0.25);
}

.asset-badge.retired {
  background: var(--warning-bg);
  color: var(--warning);
  border: 1rpx solid rgba(var(--warning-rgb), 0.25);
}

.asset-badge.sold {
  background: var(--bg-subtle);
  color: var(--text-hint);
  border: 1rpx solid var(--border-default);
}

/* 订阅资产每期金额显示 - 与订阅标签同行 */
.period-amount-text {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.period-symbol {
  font-size: 16rpx;
  font-weight: 500;
  color: var(--accent-bg-text-muted);
}

.period-number {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--accent-bg-primary);
}

/* 待生效标签 */
.pending-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
  background: var(--warning-bg);
  color: var(--warning);
  border: 1rpx solid rgba(var(--warning-rgb), 0.3);
}

/* 订阅中标签 */
.subscribing-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
  background: var(--subscription-bg);
  color: var(--subscription);
  border: 1rpx solid rgba(var(--subscription-rgb), 0.3);
}

/* 已结束标签 */
.ended-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
  background: var(--error-bg);
  color: var(--error);
  border: 1rpx solid rgba(var(--error-rgb), 0.3);
}

.card-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-stats {
  display: flex;
  align-items: stretch;
  margin-top: 12rpx;
  padding: 10rpx 0;
}

.card-stats .stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
  align-items: center;
  text-align: center;
}

.card-stats .stat-item.has-badge {
  position: relative;
}

.card-stats .stat-label {
  font-size: 14rpx;
  color: var(--accent-bg-text-muted);
  white-space: nowrap;
}

.card-stats .stat-value {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--accent-bg-text);
  white-space: nowrap;
}

/* 计入总日均 - 加深颜色 */
.card-stats .stat-value.cost.included {
  color: var(--accent-bg-text-active);
}

/* 不计入总日均 - 灰色 */
.card-stats .stat-value.cost.excluded {
  color: var(--text-hint);
}

/* 不计入标签 - 右上角 */
.exclude-badge {
  position: absolute;
  top: 0;
  right: -6rpx;
  font-size: 10rpx;
  font-weight: 600;
  color: var(--error);
  background: rgba(var(--error-rgb), 0.12);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.card-stats .stat-value.price {
  color: var(--accent-bg-primary);
  font-weight: 700;
}

/* 不计入总资产 - 价格灰色 */
.card-stats .stat-value.price.excluded {
  color: var(--text-hint);
}

.stat-divider {
  width: 1rpx;
  height: 32rpx;
  background: var(--border-default);
  margin: 0 12rpx;
  align-self: center;
  flex-shrink: 0;
}

.category-tag {
  display: flex;
  align-items: center;
  font-size: 18rpx;
  color: var(--text-muted);
  background: var(--neutral-100);
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
}

.tag-icon {
  width: 22rpx;
  height: 22rpx;
  margin-right: 6rpx;
}

.tag-icon-text {
  font-size: 20rpx;
  margin-right: 6rpx;
}

/* 不计入标签容器 */
.exclude-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.exclude-tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.exclude-tag.total {
  color: var(--warning);
  background: rgba(var(--warning-rgb), 0.3);
}

.exclude-tag.daily {
  color: var(--success);
  background: rgba(var(--primary-600-rgb), 0.28);
}

/* 资产名后面的分类标签 */
.category-tag-inline {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  color: var(--accent-bg-text-muted);
  background: rgba(var(--accent-bg-text-rgb), 0.06);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.tag-icon-inline {
  width: 20rpx;
  height: 20rpx;
  margin-right: 10rpx;
}

.tag-icon-text-inline {
  font-size: 18rpx;
  margin-right: 10rpx;
}

.tag-text-inline {
  /* 文字样式 */
}

.purchase-date {
  font-size: 18rpx;
  color: var(--accent-bg-text-muted);
}

/* 空状态 - 活泼可爱风格 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 20rpx;
  position: relative;
  overflow: hidden;
}

/* 漂浮气泡 */
.empty-bubble {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.bubble-1 {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--gold) 0%, var(--warm-yellow) 100%);
  top: 20rpx;
  left: 60rpx;
  animation: bubbleFloat1 4s ease-in-out infinite;
}

.bubble-2 {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, var(--pink) 0%, var(--hot-pink) 100%);
  top: 100rpx;
  right: 80rpx;
  animation: bubbleFloat2 5s ease-in-out infinite;
}

.bubble-3 {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, var(--mint) 0%, var(--emerald) 100%);
  bottom: 60rpx;
  left: 100rpx;
  animation: bubbleFloat3 3.5s ease-in-out infinite;
}

@keyframes bubbleFloat1 {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

@keyframes bubbleFloat2 {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30rpx) scale(1.1); }
}

@keyframes bubbleFloat3 {
  0%, 100% { transform: translateX(0) translateY(0); }
  50% { transform: translateX(15rpx) translateY(-15rpx); }
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

/* 可爱表情 */
.empty-face {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(180deg, var(--cream) 0%, var(--cream-dark) 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(var(--gold-rgb), 0.3);
  position: relative;
  animation: faceBounce 2s ease-in-out infinite;
}

@keyframes faceBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.face-eyes {
  display: flex;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.eye {
  width: 24rpx;
  height: 32rpx;
  background: var(--neutral-900);
  border-radius: 50%;
  position: relative;
  animation: eyeBlink 4s ease-in-out infinite;
}

.eye-pupil {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background: var(--text-default);
  border-radius: 50%;
  top: 6rpx;
  right: 4rpx;
}

@keyframes eyeBlink {
  0%, 45%, 55%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.1); }
}

.eye-left {
  animation-delay: 0s;
}

.eye-right {
  animation-delay: 0.1s;
}

.face-mouth {
  width: 40rpx;
  height: 20rpx;
  border: 4rpx solid var(--neutral-900);
  border-top: none;
  border-radius: 0 0 40rpx 40rpx;
  background: transparent;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-default);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
}

.list-bottom-spacer {
  height: 40rpx;
}

/* 设置视图样式 */
.setting-content {
  min-height: 100vh;
  background: var(--bg-base);
  padding-bottom: 200rpx;
}

.setting-header {
  padding: 30rpx 30rpx 20rpx;
  text-align: center;
}

.setting-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-default);
}

.setting-list {
  padding: 20rpx;
}

.setting-item-full {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-neumorph-sm);
}

.setting-item-full:last-child {
  margin-bottom: 0;
}

/* 设置项按钮（用于 open-type="contact"） */
.setting-item-btn {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-neumorph-sm);
  border: none;
  width: 100% !important;
  max-width: 100%;
  text-align: left;
  line-height: 1.5;
  font-size: 28rpx;
  font-family: inherit;
  border-radius: 16rpx;
  margin: 0;
  position: relative;
  box-sizing: border-box;
}

.setting-item-btn {
  margin-left: 0 !important;
  margin-right: 0 !important;
}

.setting-item-btn::after {
  display: none;
}

.setting-icon-box {
  width: 60rpx;
  height: 60rpx;
  background: var(--primary-soft);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  color: var(--primary-600);
  font-size: 28rpx;
}

.setting-info {
  flex: 1;
}

.setting-title-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-default);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.setting-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
}

.setting-arrow {
  color: var(--text-muted);
  font-size: 32rpx;
}

.version-info {
  padding: 60rpx 30rpx 0;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 分类管理页面样式 */
.category-management-container {
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  margin-top: 10rpx;
  box-shadow: var(--shadow-neumorph-sm);
}

.category-list {
  background: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-neumorph-sm);
}

.category-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.category-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  color: var(--text-inverse);
  font-size: 28rpx;
}

.category-name {
  font-size: 28rpx;
  color: var(--text-default);
}

.category-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-muted);
}

.add-category-btn {
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  color: var(--text-inverse);
  margin-top: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-inverse);
}

/* 底部控制按钮 - 首页/设置和新增资产分开 */
.bottom-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx calc(28rpx + env(safe-area-inset-bottom));
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  pointer-events: none;
}

.bottom-controls .mode-switch-fab,
.bottom-controls .add-asset-fab {
  pointer-events: auto;
}

/* 首页/统计/设置切换悬浮按钮组 - 透明玻璃样式 */
.mode-switch-fab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.fab-group {
  display: flex;
  gap: 12rpx;
  background: linear-gradient(
    135deg,
    rgba(var(--bg-card-rgb), 0.42) 0%,
    rgba(var(--bg-card-rgb), 0.22) 100%
  );
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.46);
  box-shadow:
    0 18rpx 44rpx rgba(var(--neutral-900-rgb), 0.10),
    inset 0 1rpx 0 rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.66),
    inset 0 -1rpx 0 rgba(var(--neutral-900-rgb), 0.04);
  -webkit-backdrop-filter: blur(36rpx) saturate(190%);
  backdrop-filter: blur(36rpx) saturate(190%);
}

.fab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  padding: 12rpx 8rpx;
  border-radius: 32rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  color: var(--primary-700);
  background: rgba(var(--bg-card-rgb), 0.04);
}

.fab-item:active {
  transform: scale(0.92);
  background: rgba(var(--bg-card-rgb), 0.24);
}

.fab-item.active {
  background: linear-gradient(
    135deg,
    rgba(var(--primary-600-rgb), 0.76) 0%,
    rgba(var(--primary-600-rgb), 0.52) 100%
  );
  color: var(--text-inverse);
  box-shadow:
    0 12rpx 28rpx rgba(var(--primary-600-rgb), 0.24),
    inset 0 1rpx 0 rgba(var(--text-inverse-rgb), 0.44);
  border: 1rpx solid rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.28);
}

.fab-item.active .fab-icon {
  color: var(--text-inverse);
}

.fab-item.active .fab-label {
  color: var(--text-inverse);
}

.fab-icon {
  font-size: 28rpx;
  color: var(--primary-700);
  line-height: 1;
  margin-bottom: 4rpx;
}

.fab-icon-svg {
  width: 28rpx;
  height: 28rpx;
  margin-bottom: 4rpx;
}

.fab-label {
  font-size: 16rpx;
  color: var(--text-muted);
  line-height: 1;
}

.action-fab-group {
  display: flex;
  gap: 24rpx;
  align-items: center;
  pointer-events: auto;
  background: linear-gradient(
    135deg,
    rgba(var(--bg-card-rgb), 0.42) 0%,
    rgba(var(--bg-card-rgb), 0.20) 100%
  );
  border-radius: 50rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.46);
  box-shadow:
    0 18rpx 44rpx rgba(var(--neutral-900-rgb), 0.10),
    inset 0 1rpx 0 rgba(var(--glass-highlight-rgb, 255, 255, 255), 0.66),
    inset 0 -1rpx 0 rgba(var(--neutral-900-rgb), 0.04);
  -webkit-backdrop-filter: blur(36rpx) saturate(190%);
  backdrop-filter: blur(36rpx) saturate(190%);
}

.action-fab-group .fab-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 4rpx;
}

/* 新增资产悬浮按钮 */
.add-asset-fab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  position: relative;
}

/* 搜索资产悬浮按钮 */
.search-asset-fab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  position: relative;
}

.action-fab-group > view::after {
  content: '';
  position: absolute;
  right: -8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 24rpx;
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(var(--neutral-900-rgb), 0.12),
    transparent
  );
}

.action-fab-group > view:last-child::after {
  display: none;
}

.action-fab-group.only-add > view::after {
  display: none;
}

.action-fab-group.no-back-top > view:nth-last-child(2)::after {
  display: none;
}

.add-asset-fab,
.search-asset-fab,
.back-to-top-fab {
  position: relative;
}

.search-asset-fab .fab-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-asset-fab .fab-inner:active {
  background: rgba(var(--bg-card-rgb), 0.20);
}

.search-asset-fab .fab-icon {
  font-size: 40rpx;
  color: var(--primary-700);
  line-height: 1;
}

.search-asset-fab .fab-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 4rpx;
}

.search-asset-fab .fab-glow {
  display: none;
}

/* 搜索按钮激活状态 */
.search-asset-fab.active .fab-icon {
  color: var(--error);
}

/* 搜索输入框容器 - 商务黑白灰风格 */
.search-bar-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  background: var(--bg-base);
  z-index: 1000;
}

/* 搜索输入框 - 商务黑白灰风格 */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  gap: 10rpx;
  box-shadow: var(--shadow-neumorph-sm);
}

.search-icon {
  font-size: 28rpx;
  color: var(--text-hint);
}

.search-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-default);
  background: transparent;
}

.search-input::placeholder {
  color: var(--text-hint);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 8rpx;
}

.search-cancel {
  font-size: 28rpx;
  color: var(--primary-600);
  font-weight: 500;
  padding: 10rpx 16rpx;
}

/* 回到顶部按钮 - 在按钮组内 */
.back-to-top-fab {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
}

.back-to-top-fab.show {
  display: flex;
}

.back-to-top-fab:active {
  background: rgba(var(--bg-card-rgb), 0.20);
}

.back-top-icon {
  width: 28rpx;
  height: 28rpx;
  margin-bottom: 4rpx;
}

.back-top-icon-emoji {
  font-size: 36rpx;
  color: var(--primary-700);
  line-height: 1;
}

/* ============================================
   批量删除功能 - 温暖活泼风格
   ============================================ */

/* 设置项 - 温暖活泼特殊样式 */
.warm-item {
  position: relative;
  overflow: hidden;
}

.warm-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(var(--warning-rgb), 0.05) 0%, rgba(var(--error-rgb), 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.warm-item:active::before {
  opacity: 1;
}

.warm-icon {
  background: var(--warning-bg) !important;
  color: var(--warning) !important;
  box-shadow: none;
}

.warm-arrow {
  color: var(--warning) !important;
}

/* 批量删除页面容器 */
.batch-delete-content {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 - 移除 */
.batch-bg-decor {
  display: none;
}

/* 批量删除头部 */
.batch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  background: var(--error);
  position: relative;
  z-index: 1;
}

.batch-back {
  width: 70rpx;
  height: 70rpx;
  background: rgba(var(--text-inverse-rgb), 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.batch-back:active {
  transform: scale(0.9);
  background: rgba(var(--text-inverse-rgb), 0.35);
}

.back-icon {
  font-size: 36rpx;
  color: var(--text-inverse);
  font-weight: bold;
}

.batch-header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.batch-subtitle {
  font-size: 22rpx;
  color: rgba(var(--text-inverse-rgb), 0.85);
}

.batch-placeholder {
  width: 70rpx;
}

/* 搜索框 */
.batch-search-bar {
  padding: 20rpx 24rpx 0;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.batch-search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  box-shadow: var(--shadow-neumorph-sm);
  gap: 16rpx;
  border: 1rpx solid var(--border-default);
}

.batch-search-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

.batch-search-icon-img {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

.batch-search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-default);
}

.batch-search-input::placeholder {
  color: var(--text-muted);
}

.batch-search-clear {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

/* 全选操作栏 */
.batch-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: var(--bg-card);
  margin: 20rpx 24rpx;
  border-radius: 12rpx;
  position: relative;
  z-index: 1;
  box-shadow: var(--shadow-neumorph-sm);
  border: 1rpx solid var(--border-light);
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: rgba(var(--text-inverse-rgb), 0.06);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.select-all-btn.selected {
  background: var(--error-bg);
  border: 1rpx solid rgba(var(--error-rgb), 0.3);
}

.select-all-btn:active {
  transform: scale(0.95);
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background: var(--bg-base);
}

.checkbox.checked {
  background: var(--error);
  border-color: transparent;
}

.check-icon {
  font-size: 24rpx;
  color: var(--text-inverse);
  font-weight: bold;
}

.select-all-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-default);
}

.select-all-btn.selected .select-all-text {
  color: var(--error);
}

.filter-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 资产选择列表 */
.batch-asset-list {
  height: calc(100vh - 420rpx);
  position: relative;
  z-index: 1;
}

.batch-asset-grid {
  display: flex;
  flex-direction: column;
  padding: 10rpx 30rpx;
  gap: 16rpx;
}

.batch-asset-card {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  position: relative;
  box-shadow: var(--shadow-neumorph-sm);
  transition: all 0.2s ease;
  border: 1rpx solid var(--border-light);
  overflow: hidden;
  box-sizing: border-box;
}

.batch-asset-card:active {
  transform: scale(0.97);
}

.batch-asset-card.selected {
  border-color: var(--error);
  background: var(--error-bg);
}

/* 卡片装饰 - 移除 */
.card-decoration {
  display: none;
}

/* 选中状态指示器 */
.select-indicator {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.select-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background: var(--bg-base);
}

.select-circle.checked {
  background: var(--error);
  border-color: transparent;
}

.select-check {
  font-size: 24rpx;
  color: var(--text-inverse);
  font-weight: bold;
}

/* 资产图标 */
.batch-asset-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  overflow: hidden;
}

.icon-img {
  width: 100%;
  height: 100%;
}

.icon-emoji {
  font-size: 36rpx;
  line-height: 1;
}

/* 资产信息 */
.batch-asset-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.batch-asset-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.batch-asset-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-default);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.batch-status-badge {
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 18rpx;
  font-weight: 500;
}

.batch-status-badge.active {
  background: var(--success-bg);
  color: var(--success);
}

.batch-status-badge.retired {
  background: var(--warning-bg);
  color: var(--warning);
}

.batch-status-badge.sold {
  background: var(--bg-subtle);
  color: var(--text-hint);
}

.batch-asset-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.batch-asset-price {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-default);
}

.batch-asset-divider {
  font-size: 20rpx;
  color: var(--border-default);
}

.batch-asset-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.batch-asset-category {
  font-size: 20rpx;
  color: var(--text-muted);
  background: var(--bg-subtle);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

/* 空状态 */
.batch-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-sun {
  display: none;
}

.batch-empty .empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-default);
  margin-bottom: 12rpx;
}

.batch-empty .empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 底部留白 */
.batch-list-spacer {
  height: 200rpx;
}

/* 底部删除按钮 */
.batch-delete-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-default);
  z-index: 100;
}

.delete-summary {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

.summary-count {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--error);
  min-width: 40rpx;
  text-align: center;
}

.summary-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--error);
  margin-left: 16rpx;
}

.delete-btn-wrapper {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.delete-btn.active {
  background: var(--error);
  box-shadow: var(--shadow-neumorph-sm);
}

.delete-btn.active:active {
  transform: scale(0.95);
}

.delete-btn.disabled {
  background: rgba(var(--text-inverse-rgb), 0.06);
  box-shadow: none;
}

.delete-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-inverse);
}

/* ============================================
   统计视图样式 - 简洁灵动风格
   ============================================ */

/* 统计视图容器 */
.report-view {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-subtle) 0%, var(--bg-subtle) 100%);
  position: relative;
  overflow: hidden;
  animation: reportFadeIn 0.4s ease-out;
}

@keyframes reportFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 背景装饰 - 更柔和灵动 */
.report-bg-decor {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.decor-circle {
  display: none;
}

.decor-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
  animation-delay: 0s;
}

.decor-2 {
  width: 280rpx;
  height: 280rpx;
  top: 35%;
  left: -80rpx;
  animation-delay: -4s;
}

.decor-3 {
  width: 320rpx;
  height: 320rpx;
  bottom: 15%;
  right: -60rpx;
  animation-delay: -8s;
}

@keyframes floatDecor {
  0%, 100% {
    transform: translateY(0) scale(1);
    opacity: 0.4;
  }
  50% {
    transform: translateY(-30rpx) scale(1.08);
    opacity: 0.5;
  }
}

/* 加载状态 - 简洁优雅 */
.report-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  z-index: 10;
  position: relative;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 3rpx solid rgba(var(--text-inverse-rgb), 0.1);
  border-top-color: var(--primary-600);
  border-radius: 50%;
  animation: spinPulse 1s ease-in-out infinite;
}

@keyframes spinPulse {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: var(--primary-600);
  font-weight: 500;
  letter-spacing: 2rpx;
  animation: textPulse 1.5s ease-in-out infinite;
}

@keyframes textPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* 空状态 - 更灵动可爱 */
.report-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  position: relative;
  z-index: 10;
}

.empty-face {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(180deg, var(--cream-light) 0%, var(--cream-mid) 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(var(--gold-rgb), 0.2);
  animation: faceFloat 3s ease-in-out infinite;
}

@keyframes faceFloat {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  25% {
    transform: translateY(-8rpx) rotate(-2deg);
  }
  75% {
    transform: translateY(-8rpx) rotate(2deg);
  }
}

.face-eyes {
  display: flex;
  gap: 36rpx;
  margin-bottom: 16rpx;
}

.eye {
  width: 20rpx;
  height: 28rpx;
  background: var(--text-default);
  border-radius: 50%;
  position: relative;
  animation: eyeBlink 4s ease-in-out infinite;
}

.eye-pupil {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: var(--text-default);
  border-radius: 50%;
  top: 5rpx;
  right: 3rpx;
}

@keyframes eyeBlink {
  0%, 45%, 55%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.1); }
}

.eye-left {
  animation-delay: 0s;
}

.eye-right {
  animation-delay: 0.1s;
}

.face-mouth {
  width: 36rpx;
  height: 18rpx;
  border: 3rpx solid var(--text-default);
  border-top: none;
  border-radius: 0 0 36rpx 36rpx;
  background: transparent;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 40rpx;
}

/* 统计内容 - 活泼配色 */
.report-content {
  padding: 20rpx 24rpx;
  position: relative;
  z-index: 1;
}

/* 资产概览卡片 */
.report-overview {
  background: var(--bg-card);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-neumorph);
  animation: cardSlideIn 0.5s ease-out;
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.main-metric-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

/* 主资产卡片 - 主色系渐变 */
.main-asset-card {
  flex: 1;
  min-width: 0;
  position: relative;
  background: var(--primary-600);
  border-radius: 24rpx;
  padding: 28rpx 22rpx;
  overflow: hidden;
  box-shadow: var(--shadow-neumorph);
}

.main-asset-card.daily-main {
  background: var(--success);
}

.main-asset-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.main-asset-label {
  font-size: 24rpx;
  color: rgba(var(--text-inverse-rgb), 0.9);
  font-weight: 600;
}

.main-asset-badge {
  flex-shrink: 0;
  font-size: 18rpx;
  color: var(--text-inverse);
  background: rgba(var(--text-inverse-rgb), 0.15);
  padding: 5rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.main-asset-value {
  max-width: 100%;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-inverse);
  text-shadow: 0 4rpx 20rpx rgba(var(--neutral-900-rgb),0.12);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.main-asset-glow {
  display: none;
}

/* 次要数据网格 */
.overview-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.overview-grid:last-of-type {
  margin-bottom: 24rpx;
}

.overview-compare {
  align-items: stretch;
}

.overview-item {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 12rpx;
  background: rgba(var(--text-inverse-rgb), 0.03);
  border-radius: 16rpx;
}

.overview-item.daily {
  background: var(--success-bg);
}

.overview-item.total {
  background: var(--primary-soft);
}

.overview-item.included-total,
.overview-item.included-daily {
  padding-right: 70rpx;
  background: var(--primary-100);
}

.overview-item.included-daily {
  background: var(--success-bg);
}

.overview-item.exclude {
  padding-right: 70rpx;
  background: var(--bg-subtle);
}

.overview-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.overview-icon-svg {
  width: 36rpx;
  height: 36rpx;
}

.overview-info {
  display: flex;
  flex-direction: column;
}

.overview-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-default);
}

.overview-unit {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-muted);
  margin-left: 2rpx;
}

.overview-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.overview-count-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(var(--neutral-900-rgb), 0.08);
  color: var(--text-muted);
  font-size: 18rpx;
  font-weight: 600;
  line-height: 1.2;
}

.overview-item.included-total .overview-value,
.overview-item.included-total .overview-icon {
  color: var(--accent-bg-text);
}

.overview-item.included-total .overview-label,
.overview-item.included-total .overview-count-badge {
  color: var(--accent-bg-text-muted);
}

.overview-item.included-daily .overview-value,
.overview-item.included-daily .overview-icon {
  color: var(--text-default);
}

.overview-item.included-daily .overview-label,
.overview-item.included-daily .overview-count-badge {
  color: var(--text-muted);
}

/* 资产状态分隔线 */
.overview-divider {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.overview-divider::before,
.overview-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(var(--text-inverse-rgb), 0.06), transparent);
}

.overview-divider-text {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 0 20rpx;
}

/* 资产状态网格 */
.status-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.status-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(var(--text-inverse-rgb), 0.03);
  transition: all 0.3s ease;
}

.status-item.active {
  background: var(--success-bg);
}

.status-item.pending {
  background: var(--primary-soft);
}

.status-item.retired {
  background: var(--bg-subtle);
}

.status-item.sold {
  background: var(--warning-bg);
}

.status-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon-svg {
  width: 36rpx;
  height: 36rpx;
}

.status-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  width: 100%;
}

.status-count {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-default);
}

.status-unit {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-muted);
  margin-left: 2rpx;
}

.status-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  width: 100%;
  text-align: center;
  line-height: 26rpx;
  overflow-wrap: anywhere;
}

.status-price {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 图表区域 - 简洁清爽 */
.report-chart-section {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-neumorph-sm);
  border: 1rpx solid var(--border-light);
  animation: cardSlideIn 0.5s ease-out;
  animation-fill-mode: both;
}

.report-chart-section:nth-child(2) {
  animation-delay: 0.1s;
}

.report-chart-section:nth-child(3) {
  animation-delay: 0.2s;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-muted);
}

.section-title-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.section-count-badge {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(var(--neutral-900-rgb), 0.08);
  color: var(--text-muted);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.section-scope-badge {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(var(--primary-600-rgb), 0.08);
  color: var(--primary-600);
  border: 1rpx solid rgba(var(--primary-600-rgb), 0.14);
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.section-scope-badge:active {
  transform: scale(0.96);
  background: rgba(var(--primary-600-rgb), 0.14);
}

.section-icon {
  font-size: 32rpx;
}

.section-icon-svg {
  width: 36rpx;
  height: 36rpx;
}

/* 分类列表 - 更灵动 */
.category-list {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(var(--text-inverse-rgb), 0.04);
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  border-bottom: none;
}

.category-entry {
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.category-entry.expanded {
  margin: 0 0 14rpx;
  background: var(--bg-subtle);
  overflow: hidden;
}

.category-entry.disabled {
  opacity: 0.58;
}

.category-entry.disabled .category-item:active {
  background: transparent;
}

.category-item:active {
  background: transparent;
}

.category-item.expanded {
  background: transparent;
}

.category-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.category-icon {
  width: 32rpx;
  height: 32rpx;
}

.category-emoji {
  font-size: 26rpx;
}

.category-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 3rpx;
  box-shadow: 0 2rpx 4rpx rgba(var(--neutral-900-rgb),0.1);
}

.category-name {
  min-width: 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.category-count {
  font-size: 20rpx;
  color: var(--text-hint);
  background: rgba(var(--text-inverse-rgb), 0.03);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.category-price {
  font-size: 26rpx;
  font-weight: 600;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  min-width: 90rpx;
  text-align: right;
}

.category-percent {
  flex-shrink: 0;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  background: rgba(var(--primary-600-rgb), 0.06);
  font-size: 19rpx;
  font-weight: 600;
  color: var(--primary-600);
  line-height: 1.2;
}

/* 图表包装器 */
.chart-wrapper {
  width: 100%;
  position: relative;
}

/* 底部留白 - 为底部固定按钮留出空间 */
.report-bottom-spacer {
  height: 180rpx;
}

/* ============================================
   时间段统计样式 - 简洁灵动
   ============================================ */

/* 时间段选择器 - 更精致 */
.time-period-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx;
}

.period-pill {
  padding: 10rpx 20rpx;
  background: var(--bg-subtle);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  transition: all 0.25s ease;
  border: 1rpx solid transparent;
}

.period-pill:active {
  transform: scale(0.95);
}

.period-pill.active {
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 12rpx rgba(var(--neutral-900-rgb),0.25);
  border: 1rpx solid rgba(var(--text-inverse-rgb), 0.2);
}

/* 粒度选择器 - 更简洁 */
.granularity-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 16rpx 16rpx;
}

.granularity-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-right: 4rpx;
}

.granularity-pill {
  padding: 6rpx 16rpx;
  background: var(--bg-subtle);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  transition: all 0.25s ease;
}

.granularity-pill:active {
  transform: scale(0.95);
}

.granularity-pill.active {
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  color: var(--text-inverse);
}

/* 统计概览 - 更清新 */
.time-stats-summary {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, rgba(var(--text-inverse-rgb), 0.02) 0%, rgba(var(--text-inverse-rgb), 0.02) 100%);
  border-radius: 14rpx;
  margin: 0 16rpx 16rpx;
}

.summary-item {
  text-align: center;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 6rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 时间段空状态 */
.time-empty-state {
  padding: 32rpx 16rpx;
  text-align: center;
}

.time-empty-state .empty-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 选中柱图的资产列表 */
.period-asset-list {
  margin: 16rpx 24rpx 0;
  padding: 20rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-default);
}

.period-asset-list.category-inline-asset-list {
  margin: 0 16rpx 16rpx 16rpx;
  padding: 16rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-default);
  box-shadow: none;
}

.period-asset-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-default);
}

.period-asset-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.period-asset-close {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 4rpx 8rpx;
}

.period-asset-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-default);
}

.period-asset-count {
  font-size: 22rpx;
  color: var(--text-hint);
}

.period-asset-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx 0;
  gap: 10rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.period-asset-item:last-child {
  border-bottom: 0;
}

.category-inline-asset-list .period-asset-item {
  padding: 12rpx 0;
  border-bottom: 0;
}

.period-asset-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.period-asset-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.period-asset-type-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.period-asset-name {
  min-width: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-default);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.period-asset-price {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--primary-600);
  flex-shrink: 0;
}

.period-asset-status {
  flex-shrink: 0;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 1.2;
  color: var(--text-muted);
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-light);
}

.period-asset-status.active {
  color: var(--success);
  background: var(--success-bg);
  border-color: rgba(var(--primary-600-rgb), 0.25);
}

.period-asset-status.subscribing {
  color: var(--subscription);
  background: var(--subscription-bg);
  border-color: rgba(var(--subscription-rgb), 0.3);
}

.period-asset-status.pending {
  color: var(--warning);
  background: var(--warning-bg);
  border-color: rgba(var(--warning-rgb), 0.3);
}

.period-asset-status.retired {
  color: var(--warning);
  background: var(--warning-bg);
  border-color: rgba(var(--warning-rgb), 0.25);
}

.period-asset-status.ended {
  color: var(--error);
  background: var(--error-bg);
  border-color: rgba(var(--error-rgb), 0.3);
}

.period-asset-status.sold {
  color: var(--text-hint);
  background: var(--bg-subtle);
  border-color: var(--border-default);
}

.period-asset-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  width: 100%;
  padding-left: 38rpx;
  box-sizing: border-box;
}

.period-category-tag,
.period-exclude-tag {
  display: flex;
  align-items: center;
  max-width: 100%;
  min-width: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 1.25;
  box-sizing: border-box;
}

.period-category-tag {
  gap: 5rpx;
  color: var(--text-muted);
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-light);
}

.period-category-icon-img {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
}

.period-category-icon {
  flex-shrink: 0;
  font-size: 18rpx;
  line-height: 1;
}

.period-category-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.period-exclude-tag {
  flex-shrink: 0;
  color: var(--error);
  background: rgba(var(--error-rgb), 0.10);
  border: 1rpx solid rgba(var(--error-rgb), 0.20);
}

.period-exclude-tag.daily {
  color: var(--warning);
  background: rgba(var(--warning-rgb), 0.10);
  border-color: rgba(var(--warning-rgb), 0.20);
}

.period-asset-date {
  display: block;
  width: 100%;
  padding-left: 38rpx;
  box-sizing: border-box;
  font-size: 20rpx;
  line-height: 1.4;
  color: var(--text-hint);
}

.period-asset-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  width: 100%;
  padding-left: 38rpx;
  box-sizing: border-box;
}

.period-mini-stat {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  max-width: 100%;
  padding: 6rpx 10rpx;
  border-radius: 12rpx;
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-light);
  box-sizing: border-box;
}

.period-mini-stat.period-amount-stat {
  background: rgba(var(--primary-600-rgb), 0.08);
  border-color: rgba(var(--primary-600-rgb), 0.18);
}

.period-mini-label {
  flex-shrink: 0;
  font-size: 18rpx;
  color: var(--text-muted);
  line-height: 1.3;
}

.period-mini-value {
  min-width: 0;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--text-default);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.period-mini-value.cost {
  color: var(--success);
}

.period-mini-value.price {
  color: var(--primary-600);
}

.period-mini-stat.excluded .period-mini-label,
.period-mini-stat.excluded .period-mini-value {
  color: var(--text-hint);
}

/* 资产分类统计口径弹窗 */
.category-scope-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9998;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.category-scope-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
}

.category-scope-panel {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  border-radius: 28rpx;
  box-shadow: 0 24rpx 70rpx rgba(var(--neutral-900-rgb), 0.28);
  overflow: hidden;
}

.category-scope-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 30rpx 22rpx;
  background: var(--bg-subtle);
}

.category-scope-title,
.category-scope-subtitle,
.scope-rule-label,
.scope-rule-text {
  display: block;
}

.category-scope-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-default);
  line-height: 1.25;
}

.category-scope-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

.category-scope-close {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--bg-subtle);
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
}

.category-scope-body {
  display: flex;
  flex-direction: column;
  padding: 12rpx 30rpx 30rpx;
}

.scope-rule-card {
  margin-top: 18rpx;
  padding: 0;
  background: transparent;
  border: 0;
}

.scope-rule-label {
  margin-bottom: 8rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: var(--primary-600);
  line-height: 1.35;
}

.scope-rule-text {
  display: block;
  width: 100%;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
  white-space: normal;
  word-break: break-all;
}

.category-scope-footer {
  margin: 0 30rpx 30rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: var(--primary-600);
  color: var(--text-inverse);
  text-align: center;
}

.category-scope-footer-text {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
}

/* 用户授权弹窗 */
.auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.35s ease;
}

.auth-modal.show {
  opacity: 1;
  visibility: visible;
}

.auth-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(var(--neutral-900-rgb),0.6);
}

.auth-panel {
  position: relative;
  width: 100%;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 32rpx rgba(var(--shadow-rgb), 0.08);
}

.auth-modal.show .auth-panel {
  transform: translateY(0);
}

.auth-panel-header {
  padding: 36rpx 32rpx 24rpx;
}

.auth-panel-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-default);
  margin-bottom: 8rpx;
}

.auth-panel-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.auth-panel-body {
  padding: 16rpx 32rpx;
}

.auth-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background: var(--bg-subtle);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.auth-row:last-child {
  margin-bottom: 0;
}

.auth-row-label {
  font-size: 28rpx;
  color: var(--text-default);
  font-weight: 500;
}

.auth-avatar-btn-small {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  background: transparent;
  padding: 0;
  border: none;
  flex: 1;
}

.auth-avatar-btn-small::after {
  border: none;
}

.auth-avatar-text {
  font-size: 28rpx;
  font-weight: 600;
}

.auth-avatar-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--border-default);
  flex-shrink: 0;
}

.auth-avatar-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
}

.auth-nickname-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  background: transparent;
  padding: 0;
  border: none;
  flex: 1;
}

.auth-nickname-btn::after {
  border: none;
}

.auth-nickname-text {
  font-size: 28rpx;
  font-weight: 600;
}

.auth-nickname-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
}

.auth-nickname-hidden {
  position: fixed;
  top: -100px;
  left: -100px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.auth-avatar-text.is-empty,
.auth-nickname-text.is-empty {
  color: var(--text-hint);
}

.auth-avatar-text.is-filled,
.auth-nickname-text.is-filled {
  color: var(--primary-500);
}

.auth-tip {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.auth-tip-secondary {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-hint);
}

.auth-random-option {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(var(--text-inverse-rgb), 0.04);
  border-radius: 12rpx;
  transition: background 0.2s ease;
}

.auth-random-option:active {
  background: rgba(var(--text-inverse-rgb), 0.08);
}

.auth-random-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.auth-random-text {
  font-size: 24rpx;
  color: var(--primary-600);
}

.auth-panel-footer {
  display: flex;
  padding: 24rpx 32rpx 40rpx;
  gap: 16rpx;
}

.auth-cancel-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-subtle);
  border-radius: 42rpx;
  font-size: 30rpx;
  color: var(--text-muted);
  border: none;
