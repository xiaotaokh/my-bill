}

.setting-info {
  flex: 1;
}

.setting-title-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.setting-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.setting-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.version-info {
  padding: 60rpx 30rpx 0;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: #999;
}

/* 分类管理页面样式 */
.category-management-container {
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-top: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.category-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  color: #fff;
  font-size: 28rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
}

.add-category-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  margin-top: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
}

/* 底部控制按钮 - 首页/设置和新增资产分开 */
.bottom-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx 40rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  pointer-events: none;
}

.bottom-controls .mode-switch-fab,
.bottom-controls .add-asset-fab {
  pointer-events: auto;
}

/* 首页/统计/设置切换悬浮按钮组 - 自然生态风格扁平化样式 */
.mode-switch-fab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.fab-group {
  display: flex;
  gap: 12rpx;
  /* 使用紫色渐变透明背景与首页主题一致 */
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.2);
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

.fab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  padding: 12rpx 8rpx;
  border-radius: 32rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  color: #667eea;
  /* 半透明背景与整体风格一致 */
  background: rgba(255, 255, 255, 0.5);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.15);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.fab-item:active {
  transform: scale(0.92);
}

.fab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
  border-color: transparent;
}

.fab-item.active .fab-icon {
  color: #fff;
}

.fab-item.active .fab-icon-svg {
  /* 保持原色 */
}

.fab-item.active .fab-label {
  color: #fff;
}

.fab-icon {
  font-size: 28rpx;
  color: #667eea;
  line-height: 1;
  margin-bottom: 4rpx;
}

.fab-icon-svg {
  width: 28rpx;
  height: 28rpx;
  margin-bottom: 4rpx;
}

.fab-label {
  font-size: 16rpx;
  color: #667eea;
  line-height: 1;
}

/* 新增资产悬浮按钮 - 自然生态风格扁平化样式 */
.add-asset-fab {
  width: 90rpx;
  height: 90rpx;
  position: relative;
}

.add-asset-fab .fab-inner {
  width: 100%;
  height: 100%;
  /* 使用自然生态风格的绿色渐变 */
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 自然生态风格阴影 */
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.25);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-asset-fab .fab-inner:active {
  transform: scale(0.92);
}

.add-asset-fab .fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.add-asset-fab .fab-label {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

.add-asset-fab .fab-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(76, 175, 80, 0.15) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

/* 回到顶部悬浮按钮 */
.back-to-top-fab {
  position: fixed;
  right: 40rpx;
  bottom: 150rpx;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
  opacity: 0;
  transform: scale(0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
  z-index: 998;
}

.back-to-top-fab.show {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.back-to-top-fab:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.back-top-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

/* ============================================
   批量删除功能 - 温暖活泼风格
   ============================================ */

/* 设置项 - 温暖活泼特殊样式 */
.warm-item {
  position: relative;
  overflow: hidden;
}

.warm-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 183, 77, 0.05) 0%, rgba(255, 138, 101, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.warm-item:active::before {
  opacity: 1;
}

.warm-icon {
  background: linear-gradient(135deg, #FFB74D 0%, #FF8A65 100%) !important;
  box-shadow: 0 4rpx 12rpx rgba(255, 138, 101, 0.3);
}

.warm-arrow {
  color: #FF8A65 !important;
}

/* 批量删除页面容器 */
.batch-delete-content {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFECB3 30%, #FFE0B2 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.batch-bg-decor {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.decor-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.4;
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 183, 77, 0.3) 0%, transparent 70%);
  top: -100rpx;
  right: -50rpx;
  animation: floatDecor 8s ease-in-out infinite;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 138, 101, 0.25) 0%, transparent 70%);
  top: 300rpx;
  left: -80rpx;
  animation: floatDecor 6s ease-in-out infinite reverse;
}

.circle-3 {
  width: 250rpx;
  height: 250rpx;
  background: radial-gradient(circle, rgba(255, 213, 79, 0.3) 0%, transparent 70%);
  bottom: 200rpx;
  right: -60rpx;
  animation: floatDecor 7s ease-in-out infinite;
}

@keyframes floatDecor {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30rpx) scale(1.05); }
}

/* 批量删除头部 */
.batch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 100%);
  position: relative;
  z-index: 1;
}

.batch-back {
  width: 70rpx;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.batch-back:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.4);
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.batch-header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.batch-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.batch-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.batch-placeholder {
  width: 70rpx;
}

/* 搜索框 */
.batch-search-bar {
  padding: 20rpx 24rpx 0;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.batch-search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 101, 0.1);
  gap: 16rpx;
}

.batch-search-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

.batch-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.batch-search-input::placeholder {
  color: #bbb;
}

.batch-search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 全选操作栏 */
.batch-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10rpx);
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(255, 138, 101, 0.1);
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.select-all-btn.selected {
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 100%);
}

.select-all-btn:active {
  transform: scale(0.95);
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #FFB74D;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  background: #fff;
}

.checkbox.checked {
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 100%);
  border-color: transparent;
  animation: checkPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes checkPop {
  0% { transform: scale(0.8); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.select-all-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF8A65;
}

.select-all-btn.selected .select-all-text {
  color: #fff;
}

.filter-hint {
  font-size: 24rpx;
  color: #999;
}

/* 资产选择列表 */
.batch-asset-list {
  height: calc(100vh - 420rpx);
  position: relative;
  z-index: 1;
}

.batch-asset-grid {
  display: flex;
  flex-direction: column;
  padding: 10rpx 30rpx;
  gap: 16rpx;
}

.batch-asset-card {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(255, 138, 101, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
  overflow: hidden;
  box-sizing: border-box;
}

.batch-asset-card:active {
  transform: scale(0.97);
}

.batch-asset-card.selected {
  border-color: #FF8A65;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 248, 225, 0.95) 100%);
  box-shadow: 0 8rpx 30rpx rgba(255, 138, 101, 0.2);
}

.batch-asset-card.selected::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 138, 101, 0.05) 0%, rgba(255, 183, 77, 0.05) 100%);
  pointer-events: none;
}

/* 卡片装饰 */
.card-decoration {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 60rpx;
  height: 60rpx;
  background: radial-gradient(circle, rgba(255, 183, 77, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.batch-asset-card.selected .card-decoration {
  opacity: 1;
}

/* 选中状态指示器 */
.select-indicator {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.select-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  background: #fff;
}

.select-circle.checked {
  background: linear-gradient(135deg, #FF8A65 0%, #FFB74D 100%);
  border-color: transparent;
}

.select-check {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
  animation: checkIn 0.3s ease;
}

@keyframes checkIn {
  0% { transform: scale(0) rotate(-45deg); opacity: 0; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

/* 资产图标 */
.batch-asset-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 183, 77, 0.15);
}

.icon-img {
  width: 44rpx;
  height: 44rpx;
}

.icon-emoji {
  font-size: 36rpx;
}

/* 资产信息 */
.batch-asset-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.batch-asset-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.batch-asset-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.batch-status-badge {
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 18rpx;
  font-weight: 500;
}

.batch-status-badge.active {
  background: #E8F5E9;
  color: #2E7D32;
}

.batch-status-badge.retired {
  background: #FFF3E0;
  color: #E65100;
}

.batch-status-badge.sold {
  background: #E3F2FD;
  color: #1565C0;
}

.batch-asset-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.batch-asset-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF8A65;
}

.batch-asset-divider {
  font-size: 20rpx;
  color: #CCC;
}

.batch-asset-date {
  font-size: 22rpx;
  color: #888;
}

.batch-asset-category {
  font-size: 20rpx;
  color: #999;
  background: #F5F5F5;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

/* 空状态 */
.batch-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-sun {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  margin-bottom: 40rpx;
}

.sun-face {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFD54F 0%, #FFB74D 100%);
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 8rpx 30rpx rgba(255, 183, 77, 0.4);
  animation: sunPulse 3s ease-in-out infinite;
}

@keyframes sunPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50% { transform: translate(-50%, -50%) scale(1.05); }
}

.sun-ray {
  position: absolute;
  width: 20rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #FFD54F 0%, transparent 100%);
  border-radius: 3rpx;
  top: 50%;
  left: 50%;
  transform-origin: 0 50%;
}

.ray-1 { transform: rotate(0deg) translateX(60rpx); animation: rayRotate 10s linear infinite; }
.ray-2 { transform: rotate(120deg) translateX(60rpx); animation: rayRotate 10s linear infinite; animation-delay: -3.3s; }
.ray-3 { transform: rotate(240deg) translateX(60rpx); animation: rayRotate 10s linear infinite; animation-delay: -6.6s; }

@keyframes rayRotate {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.batch-empty .empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.batch-empty .empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 底部留白 */
.batch-list-spacer {
  height: 200rpx;
}

/* 底部删除按钮 */
.batch-delete-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 183, 77, 0.2);
  z-index: 100;
}

.delete-summary {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-text {
  font-size: 26rpx;
  color: #666;
}

.summary-count {
  font-size: 40rpx;
  font-weight: 800;
  color: #FF8A65;
  min-width: 40rpx;
  text-align: center;
}

.summary-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF8A65;
  margin-left: 16rpx;
}

.delete-btn-wrapper {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.delete-btn.active {
  background: linear-gradient(135deg, #FF8A65 0%, #FF7043 100%);
  box-shadow: 0 8rpx 30rpx rgba(255, 112, 67, 0.35);
}

.delete-btn.active:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(255, 112, 67, 0.3);
}

.delete-btn.disabled {
  background: #E0E0E0;
  box-shadow: none;
}

.delete-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* ============================================
   统计视图样式 - 简洁灵动风格
   ============================================ */

/* 统计视图容器 */
.report-view {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fc 0%, #eef1f8 100%);
  position: relative;
  overflow: hidden;
  animation: reportFadeIn 0.4s ease-out;
}

@keyframes reportFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 背景装饰 - 更柔和灵动 */
.report-bg-decor {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.decor-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.4;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.15) 0%, transparent 70%);
  animation: floatDecor 12s ease-in-out infinite;
}

.decor-1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
  animation-delay: 0s;
}

.decor-2 {
  width: 280rpx;
  height: 280rpx;
  top: 35%;
  left: -80rpx;
  animation-delay: -4s;
}

.decor-3 {
  width: 320rpx;
  height: 320rpx;
  bottom: 15%;
  right: -60rpx;
  animation-delay: -8s;
}

@keyframes floatDecor {
  0%, 100% {
    transform: translateY(0) scale(1);
    opacity: 0.4;
  }
  50% {
    transform: translateY(-30rpx) scale(1.08);
    opacity: 0.5;
  }
}

/* 加载状态 - 简洁优雅 */
.report-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  z-index: 10;
  position: relative;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 3rpx solid rgba(102, 126, 234, 0.15);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spinPulse 1s ease-in-out infinite;
}

@keyframes spinPulse {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  letter-spacing: 2rpx;
  animation: textPulse 1.5s ease-in-out infinite;
}

@keyframes textPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* 空状态 - 更灵动可爱 */
.report-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  position: relative;
  z-index: 10;
}

.empty-face {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(180deg, #fef7e6 0%, #fde9b8 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(251, 191, 36, 0.2);
  animation: faceFloat 3s ease-in-out infinite;
}

@keyframes faceFloat {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  25% {
    transform: translateY(-8rpx) rotate(-2deg);
  }
  75% {
    transform: translateY(-8rpx) rotate(2deg);
  }
}

.face-eyes {
  display: flex;
  gap: 36rpx;
  margin-bottom: 16rpx;
}

.eye {
  width: 20rpx;
  height: 28rpx;
  background: #374151;
  border-radius: 50%;
  position: relative;
  animation: eyeBlink 4s ease-in-out infinite;
}

.eye-pupil {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 50%;
  top: 5rpx;
  right: 3rpx;
}

@keyframes eyeBlink {
  0%, 45%, 55%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.1); }
}

.eye-left {
  animation-delay: 0s;
}

.eye-right {
  animation-delay: 0.1s;
}

.face-mouth {
  width: 36rpx;
  height: 18rpx;
  border: 3rpx solid #374151;
  border-top: none;
  border-radius: 0 0 36rpx 36rpx;
  background: transparent;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4b5563;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 统计内容 - 活泼配色 */
.report-content {
  padding: 20rpx 24rpx;
  position: relative;
  z-index: 1;
}

/* 统计概览卡片 - 主打大数字设计 */
.report-stats-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: cardSlideIn 0.5s ease-out;
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 主资产卡片 - 珊瑚橙渐变 */
.main-asset-card {
  position: relative;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 50%, #FFA94D 100%);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.main-asset-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.main-asset-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.main-asset-badge {
  font-size: 20rpx;
  color: #FF6B6B;
  background: rgba(255, 255, 255, 0.95);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.main-asset-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: -1rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
}

.main-asset-glow {
  position: absolute;
  right: -40rpx;
  bottom: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

/* 次要数据网格 */
.sub-stats-grid {
  display: flex;
  gap: 10rpx;
}

.sub-stat-item {
  flex: 1;
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.25s ease;
}

.sub-stat-item:active {
  transform: scale(0.97);
}

/* 资产总数 - 薄荷绿 */
.sub-stat-item:nth-child(1) {
  background: linear-gradient(135deg, #E8FDF5 0%, #D1FAE5 100%);
  border: 1rpx solid rgba(16, 185, 129, 0.15);
}

.sub-stat-item:nth-child(1) .sub-stat-icon {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.sub-stat-item:nth-child(1) .sub-stat-value {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 分类 - 靛蓝紫 */
.sub-stat-item:nth-child(2) {
  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
  border: 1rpx solid rgba(99, 102, 241, 0.15);
}

.sub-stat-item:nth-child(2) .sub-stat-icon {
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.sub-stat-item:nth-child(2) .sub-stat-value {
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sub-stat-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.sub-stat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
}

.sub-stat-value {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.sub-stat-unit {
  font-size: 16rpx;
  font-weight: 500;
  color: #9ca3af;
  margin-left: 2rpx;
}

.sub-stat-label {
  font-size: 18rpx;
  color: #6B7280;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 不计入 - 玫红色 */
.sub-stat-item.excluded {
  background: linear-gradient(135deg, #FFF1F2 0%, #FECDD3 100%);
  border: 1rpx solid rgba(244, 63, 94, 0.15);
}

.sub-stat-item.excluded .sub-stat-icon {
  background: linear-gradient(135deg, #FDA4AF 0%, #FB7185 100%);
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.sub-stat-item.excluded .sub-stat-value {
  background: linear-gradient(135deg, #F43F5E 0%, #E11D48 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sub-stat-item.excluded .sub-stat-label {
  color: #F43F5E;
}

/* 图表区域 - 简洁清爽 */
.report-chart-section {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  animation: cardSlideIn 0.5s ease-out;
  animation-fill-mode: both;
}

.report-chart-section:nth-child(2) {
  animation-delay: 0.1s;
}

.report-chart-section:nth-child(3) {
  animation-delay: 0.2s;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4b5563;
}

.section-icon {
  font-size: 32rpx;
}

.section-icon-svg {
  width: 36rpx;
  height: 36rpx;
}

/* 分类列表 - 更灵动 */
.category-list {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(102, 126, 234, 0.06);
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.category-item:active {
  transform: scale(0.98);
  background: rgba(102, 126, 234, 0.04);
}

.category-item:not(:last-child) {
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.05);
}

.category-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.category-icon {
  width: 32rpx;
  height: 32rpx;
}

.category-emoji {
  font-size: 26rpx;
}

.category-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 3rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.category-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #4b5563;
}

.category-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-count {
  font-size: 20rpx;
  color: #9ca3af;
  background: rgba(102, 126, 234, 0.06);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.category-price {
  font-size: 26rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  min-width: 90rpx;
  text-align: right;
}

/* 图表包装器 */
.chart-wrapper {
  width: 100%;
  position: relative;
}

/* 底部留白 - 为底部固定按钮留出空间 */
.report-bottom-spacer {
  height: 180rpx;
}

/* ============================================
   时间段统计样式 - 简洁灵动
   ============================================ */

/* 时间段选择器 - 更精致 */
.time-period-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx;
}

.period-pill {
  padding: 10rpx 20rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #6b7280;
  transition: all 0.25s ease;
  border: 1rpx solid transparent;
}

.period-pill:active {
  transform: scale(0.95);
}

.period-pill.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* 粒度选择器 - 更简洁 */
.granularity-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 16rpx 16rpx;
}

.granularity-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-right: 4rpx;
}

.granularity-pill {
  padding: 6rpx 16rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #6b7280;
  transition: all 0.25s ease;
}

.granularity-pill:active {
  transform: scale(0.95);
}

.granularity-pill.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 统计概览 - 更清新 */
.time-stats-summary {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.04) 0%, rgba(118, 75, 162, 0.04) 100%);
  border-radius: 14rpx;
  margin: 0 16rpx 16rpx;
}

.summary-item {
  text-align: center;
}

.summary-label {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 6rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 时间段空状态 */
.time-empty-state {
  padding: 32rpx 16rpx;
  text-align: center;
}

.time-empty-state .empty-text {
  font-size: 24rpx;
  color: #9ca3af;
}