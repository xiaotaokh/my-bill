/* index.wxss - 蓝紫渐变主题设计 */

page {
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --accent-purple: #9b72e8;
  --accent-blue: #667eea;
  --glass-bg: rgba(255, 255, 255, 0.95);
  --glass-border: rgba(255, 255, 255, 0.3);
  --shadow-soft: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f5 0%, #e8eaf6 100%);
  position: relative;
}

/* 顶部背景 - 随内容滚动 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 500rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #9b72e8 100%);
  border-radius: 0 0 50% 50% / 0 0 100rpx 100rpx;
  z-index: 0;
}

/* 日期显示 - 简化样式 */
.date-section {
  position: relative;
  z-index: 1;
  padding: 0;
  margin-bottom: 20rpx;
}

.date-display {
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
  padding: 20rpx;
}

.date-day {
  font-size: 96rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 12rpx;
}

.date-month {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

.date-week {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 总资产卡片 - 左右布局 */
.total-card {
  position: relative;
  margin: 30rpx 20rpx;
  padding: 40rpx 50rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 32rpx;
  box-shadow: var(--shadow-soft);
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  overflow: hidden;
}

.total-card-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.total-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.total-value {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
  line-height: 1;
}

.total-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, #e0e0e0, transparent);
  margin: 0 40rpx;
  flex-shrink: 0;
}

.total-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 140rpx;
}

.daily-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.daily-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
}

.total-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.15) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

/* 统计指标卡片 */
.stats-section {
  position: relative;
  z-index: 1;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.active-icon {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.retired-icon {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.sold-icon {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.total-icon {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.stat-name {
  font-size: 20rpx;
  color: #999;
  white-space: nowrap;
}

/* 筛选和排序 */
.filter-section {
  position: relative;
  z-index: 1;
  padding: 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
}

.filter-pill {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  background: var(--glass-bg);
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
}

.filter-pill.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.sort-wrapper {
  display: flex;
  justify-content: flex-end;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--glass-bg);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
  box-shadow: var(--shadow-card);
}

.sort-arrow {
  font-size: 16rpx;
  color: #999;
  transition: transform 0.3s;
}

.sort-arrow.desc {
  transform: rotate(180deg);
}

/* 资产列表 */
.asset-list {
  position: relative;
  z-index: 1;
  padding: 10rpx 20rpx 120rpx;
  height: calc(100vh - 580rpx);
  width: 100%;
  box-sizing: border-box;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

/* 资产卡片 */
.asset-card {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  width: 100%;
  box-sizing: border-box;
}

.asset-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.card-left {
  flex-shrink: 0;
  width: 64rpx;
}

.asset-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.asset-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.asset-badge.active {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #2e7d32;
}

.asset-badge.retired {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  color: #f57c00;
}

.asset-badge.sold {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1565c0;
}

.card-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 10rpx 0;
}

.card-stats .stat-item {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.card-stats .stat-label {
  font-size: 14rpx;
  color: #999;
  white-space: nowrap;
}

.card-stats .stat-value {
  font-size: 18rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
}

.card-stats .stat-value.cost {
  color: #667eea;
}

.card-stats .stat-value.price {
  color: #f57c00;
}

.stat-divider {
  width: 1rpx;
  height: 32rpx;
  background: #e0e0e0;
  margin: 0 12rpx;
}

.category-tag {
  font-size: 18rpx;
  color: #667eea;
  background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
}

.purchase-date {
  font-size: 18rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.list-bottom-spacer {
  height: 40rpx;
}

/* 添加按钮 */
.add-fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  z-index: 999;
}

.fab-inner {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.fab-inner:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.fab-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}