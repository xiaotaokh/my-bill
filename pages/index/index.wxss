/* 关于弹窗 */
.about-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9998;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.about-modal.show {
  opacity: 1;
  visibility: visible;
}

.about-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(var(--neutral-900-rgb), 0.4);
  backdrop-filter: blur(4rpx);
}

.about-panel {
  position: relative;
  width: 620rpx;
  max-height: 85vh;
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-base) 100%);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 80rpx rgba(var(--neutral-900-rgb),0.4), 0 8rpx 32rpx rgba(var(--neutral-900-rgb),0.2);
  transform: scale(0.85) translateY(40rpx);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.about-modal.show .about-panel {
  transform: scale(1) translateY(0);
}

/* 头部装饰 - 几何元素 */
.about-header-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  pointer-events: none;
}

.decor-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(var(--text-inverse-rgb), 0.08);
}

.ring-1 {
  width: 120rpx;
  height: 120rpx;
  top: 30rpx;
  left: 40rpx;
  animation: ring-float 3s ease-in-out infinite;
}

.ring-2 {
  width: 80rpx;
  height: 80rpx;
  top: 60rpx;
  right: 60rpx;
  animation: ring-float 4s ease-in-out infinite reverse;
}

.ring-3 {
  width: 40rpx;
  height: 40rpx;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  animation: ring-pulse 2s ease-in-out infinite;
}

.decor-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  border-radius: 50%;
  opacity: 0.6;
}

.dot-1 {
  top: 80rpx;
  left: 100rpx;
  animation: dot-bounce 2.5s ease-in-out infinite;
}

.dot-2 {
  top: 120rpx;
  right: 120rpx;
  animation: dot-bounce 3s ease-in-out infinite 0.5s;
}

.dot-3 {
  top: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  animation: dot-glow 2s ease-in-out infinite;
}

@keyframes ring-float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-10rpx) rotate(180deg); }
}

@keyframes ring-pulse {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.15; }
  50% { transform: translateX(-50%) scale(1.2); opacity: 0.25; }
}

@keyframes dot-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

@keyframes dot-glow {
  0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
  50% { opacity: 1; transform: translateX(-50%) scale(1.3); }
}

/* Logo区域 */
.about-logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.about-logo-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  animation: logo-entrance 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes logo-entrance {
  0% { transform: scale(0.5) rotate(-10deg); opacity: 0; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.logo-gradient-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 50%, var(--primary-400) 100%);
  border-radius: 24rpx;
  animation: gradient-shift 4s ease-in-out infinite;
}

@keyframes gradient-shift {
  0%, 100% { background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 50%, var(--primary-400) 100%); }
  50% { background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-400) 50%, var(--primary-600) 100%); }
}

.logo-icon-svg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  z-index: 1;
}

.about-app-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-default);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  animation: text-fade-in 0.5s ease-out 0.2s forwards;
  opacity: 0;
}

.about-app-slogan {
  font-size: 24rpx;
  color: var(--primary-600);
  font-weight: 500;
  letter-spacing: 1rpx;
  animation: text-fade-in 0.5s ease-out 0.35s forwards;
  opacity: 0;
}

@keyframes text-fade-in {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

/* 功能卡片区域 */
.about-features {
  padding: 16rpx 24rpx;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.feature-card {
  width: 48%;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-neumorph-sm);
  box-sizing: border-box;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  animation: card-stagger-in 0.4s ease-out forwards;
  opacity: 0;
}

.feature-card:nth-child(1) { animation-delay: 0.4s; }
.feature-card:nth-child(2) { animation-delay: 0.5s; }
.feature-card:nth-child(3) { animation-delay: 0.6s; }
.feature-card:nth-child(4) { animation-delay: 0.7s; }
.feature-card:nth-child(5) { animation-delay: 0.8s; }
.feature-card:nth-child(6) { animation-delay: 0.9s; }

@keyframes card-stagger-in {
  0% { opacity: 0; transform: translateY(20rpx) scale(0.95); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.feature-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(var(--neutral-900-rgb),0.25);
}

/* 功能卡片渐变边框 - 深色风格 */
.card-1 { background: linear-gradient(var(--bg-card), var(--bg-card)) padding-box, linear-gradient(135deg, var(--primary-600), var(--primary-500)) border-box; border: 2rpx solid transparent; box-sizing: border-box; }
.card-2 { background: linear-gradient(var(--bg-card), var(--bg-card)) padding-box, linear-gradient(135deg, var(--pink), var(--orange)) border-box; border: 2rpx solid transparent; box-sizing: border-box; }
.card-3 { background: linear-gradient(var(--bg-card), var(--bg-card)) padding-box, linear-gradient(135deg, var(--mint), var(--blue)) border-box; border: 2rpx solid transparent; box-sizing: border-box; }
.card-4 { background: linear-gradient(var(--bg-card), var(--bg-card)) padding-box, linear-gradient(135deg, var(--purple), var(--gold)) border-box; border: 2rpx solid transparent; box-sizing: border-box; }
.card-5 { background: linear-gradient(var(--bg-card), var(--bg-card)) padding-box, linear-gradient(135deg, var(--sky-blue), var(--primary-400)) border-box; border: 2rpx solid transparent; box-sizing: border-box; }
.card-6 { background: linear-gradient(var(--bg-card), var(--bg-card)) padding-box, linear-gradient(135deg, var(--orange), var(--pink)) border-box; border: 2rpx solid transparent; box-sizing: border-box; }

.feature-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.feature-icon {
  font-size: 28rpx;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-default);
  margin-bottom: 2rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* 底部区域 */
.about-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx 40rpx;
}

.about-message {
  font-size: 26rpx;
  color: var(--primary-600);
  font-weight: 500;
  text-align: center;
  margin-bottom: 24rpx;
  animation: message-glow 3s ease-in-out infinite;
}

@keyframes message-glow {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}

.about-close-btn {
  width: 260rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-500) 100%);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--text-inverse);
  border: none;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(var(--neutral-900-rgb),0.35);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  animation: btn-entrance 0.5s ease-out 1s forwards;
  opacity: 0;
}

.about-close-btn::after {
  border: none;
}

.about-close-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(var(--neutral-900-rgb),0.4);
}

@keyframes btn-entrance {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

