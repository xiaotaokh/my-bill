/* index.wxss - 保留原始样式，只添加悬浮按钮的自然风格样式 */

/* 原有的所有样式保持不变 */
page {
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --accent-purple: #9b72e8;
  --accent-blue: #667eea;
  --glass-bg: rgba(255, 255, 255, 0.95);
  --glass-border: rgba(255, 255, 255, 0.3);
  --shadow-soft: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f5 0%, #e8eaf6 100%);
  position: relative;
}

/* 顶部背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 340rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #9b72e8 100%);
  border-radius: 0 0 50% 50% / 0 0 80rpx 80rpx;
  z-index: 0;
}

/* 日期显示 - 简化样式 */
.date-section {
  position: relative;
  z-index: 1;
  padding: 0;
  margin-bottom: 0;
}

.date-display {
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
  padding: 20rpx;
}

.date-day {
  font-size: 96rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 12rpx;
}

.date-month {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

.date-week {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 天气显示 */
.weather-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
  padding: 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  backdrop-filter: blur(10px);
  margin-bottom: 8rpx;
}

.weather-icon {
  font-size: 44rpx;
}

.weather-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
}

.weather-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.weather-temp {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1.2;
}

.weather-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
}

.weather-range {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.temp-max {
  color: rgba(255, 255, 255, 0.95);
}

.temp-divider {
  color: rgba(255, 255, 255, 0.6);
  margin: 0 2rpx;
}

.temp-min {
  color: rgba(255, 255, 255, 0.75);
}

/* 总资产卡片 - 左右布局 */
.total-card {
  position: relative;
  margin: 0 20rpx 24rpx;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 32rpx;
  box-shadow: var(--shadow-soft);
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-card-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.total-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.total-value {
  font-weight: 800;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.total-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, #e0e0e0, transparent);
  margin: 0 40rpx;
  flex-shrink: 0;
}

.total-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.daily-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.daily-value {
  font-weight: 700;
  color: #667eea;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

.total-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.15) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

/* 统计指标卡片 */
.stats-section {
  position: relative;
  z-index: 1;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  background: var(--glass-bg);
  border-radius: 28rpx;
  padding: 20rpx 16rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.stat-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.active-icon {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.retired-icon {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.sold-icon {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.total-icon {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  flex: 1;
}

.stat-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.stat-name {
  font-size: 18rpx;
  color: #999;
  white-space: nowrap;
}

/* 筛选和排序 */
.filter-section {
  position: relative;
  z-index: 1;
  padding: 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ============================================
   分类筛选栏 - 标签云风格（轻盈、可横向滚动）
   ============================================ */
.category-bar {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 4rpx 4rpx;
  /* 隐藏滚动条 */
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.category-bar::-webkit-scrollbar {
  display: none;
}

.category-pill {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #555;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
}

.category-pill:active {
  transform: scale(0.96);
}

.category-pill.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.35);
  border-color: transparent;
}

/* 分类图标 - emoji */
.pill-icon {
  font-size: 26rpx;
  line-height: 1;
}

/* 分类图标 - 图片 */
.pill-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.pill-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 新增类别按钮 - 虚线边框设计 */
.category-add {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #764ba2;
  background: rgba(118, 75, 162, 0.06);
  border: 2rpx dashed rgba(118, 75, 162, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-add:active {
  background: rgba(118, 75, 162, 0.12);
  border-color: rgba(118, 75, 162, 0.7);
  transform: scale(0.96);
}

.category-add .add-icon {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

/* ============================================
   状态筛选栏 - 分段控制器风格（一体化、紧凑）
   ============================================ */
.filter-bar {
  display: inline-flex;
  padding: 6rpx 0;
  gap: 12rpx;
}

.filter-pill {
  flex: 1;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
  background: rgba(255, 255, 255, 0.5);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  text-align: center;
  min-width: 80rpx;
}

.filter-pill:active {
  transform: scale(0.95);
}

/* 状态筛选 - 选中状态带颜色 */
.filter-pill.active-all {
  background: linear-gradient(135deg, #5c6ac4 0%, #4a55a8 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(92, 106, 196, 0.4);
}

.filter-pill.active-active {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(5, 150, 105, 0.4);
}

.filter-pill.active-retired {
  background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(217, 119, 6, 0.4);
}

.filter-pill.active-sold {
  background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(2, 132, 199, 0.4);
}

.sort-wrapper {
  display: flex;
  align-items: center;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.35);
  transition: all 0.2s ease;
}

.sort-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.25);
}

.sort-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.sort-arrow {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  transition: transform 0.3s ease;
}

.sort-arrow.desc {
  transform: rotate(180deg);
}

/* 资产列表 - 无限滚动 */
.asset-list {
  position: relative;
  z-index: 1;
  padding: 10rpx 20rpx 200rpx;
  width: 100%;
  box-sizing: border-box;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.list-title-wrapper {
  display: flex;
  align-items: center;
  gap: 34rpx;
}

.list-title-box {
  position: relative;
  display: flex;
  align-items: flex-start;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.list-count-badge {
  position: absolute;
  top: -8rpx;
  right: -30rpx;
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.list-count-badge text {
  line-height: 1;
}

.list-total-price {
  display: flex;
  align-items: flex-end;
}

.list-price-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.list-total-price .price-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
}

.list-total-price .price-label {
  font-size: 18rpx;
  font-weight: 500;
  color: #999;
  margin-left: 2rpx;
  margin-bottom: 1rpx;
}

/* 资产卡片 */
.asset-card {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  width: 100%;
  box-sizing: border-box;
}

.asset-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.card-left {
  flex-shrink: 0;
  width: 64rpx;
}

.asset-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 2rpx solid #e5e7eb;
}

.avatar-icon {
  font-size: inherit;
  line-height: 1;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.name-with-category {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  overflow: hidden;
}

/* 名称下方的标签信息 */
.name-sub-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.asset-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.asset-badge.active {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #2e7d32;
}

.asset-badge.retired {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  color: #f57c00;
}

.asset-badge.sold {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1565c0;
}

.card-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 10rpx 0;
}

.card-stats .stat-item {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.card-stats .stat-item.has-badge {
  position: relative;
}

.card-stats .stat-label {
  font-size: 14rpx;
  color: #999;
  white-space: nowrap;
}

.card-stats .stat-value {
  font-size: 18rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
}

/* 计入总日均 - 加深颜色 */
.card-stats .stat-value.cost.included {
  color: #E11D48;
}

/* 不计入总日均 - 灰色 */
.card-stats .stat-value.cost.excluded {
  color: #9CA3AF;
}

/* 不计入标签 - 右上角 */
.exclude-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  font-size: 10rpx;
  font-weight: 500;
  color: #F472B6;
  background: #FDF2F8;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
  border: 1rpx solid #FBCFE8;
}

.card-stats .stat-value.price {
  color: #3B82F6;
}

/* 不计入总资产 - 价格灰色 */
.card-stats .stat-value.price.excluded {
  color: #9CA3AF;
}

.stat-divider {
  width: 1rpx;
  height: 32rpx;
  background: #e0e0e0;
  margin: 0 12rpx;
}

.category-tag {
  display: flex;
  align-items: center;
  font-size: 18rpx;
  color: #667eea;
  background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
}

.tag-icon {
  width: 22rpx;
  height: 22rpx;
  margin-right: 6rpx;
}

.tag-icon-text {
  font-size: 20rpx;
  margin-right: 6rpx;
}

/* 不计入标签容器 */
.exclude-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.exclude-tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.exclude-tag.total {
  color: #f59e0b;
  background: #fef3c7;
}

.exclude-tag.daily {
  color: #10b981;
  background: #d1fae5;
}

/* 资产名后面的分类标签 */
.category-tag-inline {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  color: #667eea;
  background: #e8eaf6;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.tag-icon-inline {
  width: 20rpx;
  height: 20rpx;
  margin-right: 4rpx;
}

.tag-icon-text-inline {
  font-size: 18rpx;
  margin-right: 4rpx;
}

.tag-text-inline {
  /* 文字样式 */
}

.purchase-date {
  font-size: 18rpx;
  color: #999;
}

/* 空状态 - 活泼可爱风格 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 20rpx;
  position: relative;
  overflow: hidden;
}

/* 漂浮气泡 */
.empty-bubble {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.bubble-1 {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  top: 20rpx;
  left: 60rpx;
  animation: bubbleFloat1 4s ease-in-out infinite;
}

.bubble-2 {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%);
  top: 100rpx;
  right: 80rpx;
  animation: bubbleFloat2 5s ease-in-out infinite;
}

.bubble-3 {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  bottom: 60rpx;
  left: 100rpx;
  animation: bubbleFloat3 3.5s ease-in-out infinite;
}

@keyframes bubbleFloat1 {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

@keyframes bubbleFloat2 {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30rpx) scale(1.1); }
}

@keyframes bubbleFloat3 {
  0%, 100% { transform: translateX(0) translateY(0); }
  50% { transform: translateX(15rpx) translateY(-15rpx); }
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

/* 可爱表情 */
.empty-face {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(180deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(251, 191, 36, 0.3);
  position: relative;
  animation: faceBounce 2s ease-in-out infinite;
}

@keyframes faceBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.face-eyes {
  display: flex;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.eye {
  width: 24rpx;
  height: 32rpx;
  background: #1f2937;
  border-radius: 50%;
  position: relative;
  animation: eyeBlink 4s ease-in-out infinite;
}

.eye-pupil {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background: #fff;
  border-radius: 50%;
  top: 6rpx;
  right: 4rpx;
}

@keyframes eyeBlink {
  0%, 45%, 55%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.1); }
}

.eye-left {
  animation-delay: 0s;
}

.eye-right {
  animation-delay: 0.1s;
}

.face-mouth {
  width: 40rpx;
  height: 20rpx;
  border: 4rpx solid #1f2937;
  border-top: none;
  border-radius: 0 0 40rpx 40rpx;
  background: transparent;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
}

.list-bottom-spacer {
  height: 40rpx;
}

/* 设置视图样式 */
.setting-content {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

.setting-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 40rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.setting-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.setting-list {
  padding: 20rpx;
}

.setting-item-full {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.setting-item-full:last-child {
  margin-bottom: 0;
}

.setting-icon-box {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
