/* index.wxss - 保留原始样式，只添加悬浮按钮的自然风格样式 */

/* 原有的所有样式保持不变 */
page {
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --accent-purple: #9b72e8;
  --accent-blue: #667eea;
  --glass-bg: rgba(255, 255, 255, 0.95);
  --glass-border: rgba(255, 255, 255, 0.3);
  --shadow-soft: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f5 0%, #e8eaf6 100%);
  position: relative;
}

/* 顶部背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 500rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #9b72e8 100%);
  border-radius: 0 0 50% 50% / 0 0 100rpx 100rpx;
  z-index: 0;
}

/* 日期显示 - 简化样式 */
.date-section {
  position: relative;
  z-index: 1;
  padding: 0;
  margin-bottom: 20rpx;
}

.date-display {
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
  padding: 20rpx;
}

.date-day {
  font-size: 96rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-bottom: 12rpx;
}

.date-month {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

.date-week {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 总资产卡片 - 左右布局 */
.total-card {
  position: relative;
  margin: 30rpx 20rpx;
  padding: 40rpx 50rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 32rpx;
  box-shadow: var(--shadow-soft);
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  overflow: hidden;
}

.total-card-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.total-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.total-value {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
  line-height: 1;
}

.total-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, #e0e0e0, transparent);
  margin: 0 40rpx;
  flex-shrink: 0;
}

.total-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 140rpx;
}

.daily-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.daily-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
}

.total-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.15) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

/* 统计指标卡片 */
.stats-section {
  position: relative;
  z-index: 1;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.active-icon {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.retired-icon {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.sold-icon {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.total-icon {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.stat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.stat-name {
  font-size: 20rpx;
  color: #999;
  white-space: nowrap;
}

/* 筛选和排序 */
.filter-section {
  position: relative;
  z-index: 1;
  padding: 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ============================================
   分类筛选栏 - 标签云风格（轻盈、可横向滚动）
   ============================================ */
.category-bar {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 4rpx 4rpx;
  /* 隐藏滚动条 */
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.category-bar::-webkit-scrollbar {
  display: none;
}

.category-pill {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #555;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  letter-spacing: 0.5rpx;
}

.category-pill:active {
  transform: scale(0.96);
}

.category-pill.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.35);
  border-color: transparent;
}

/* 新增类别按钮 - 虚线边框设计 */
.category-add {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #764ba2;
  background: rgba(118, 75, 162, 0.06);
  border: 2rpx dashed rgba(118, 75, 162, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-add:active {
  background: rgba(118, 75, 162, 0.12);
  border-color: rgba(118, 75, 162, 0.7);
  transform: scale(0.96);
}

.category-add .add-icon {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

/* ============================================
   状态筛选栏 - 分段控制器风格（一体化、紧凑）
   ============================================ */
.filter-bar {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 6rpx;
  gap: 6rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
}

.filter-pill {
  flex: 1;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
  background: rgba(255, 255, 255, 0.5);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  text-align: center;
  min-width: 80rpx;
}

.filter-pill:active {
  transform: scale(0.95);
}

/* 状态筛选 - 选中状态带颜色 */
.filter-pill.active-all {
  background: linear-gradient(135deg, #5c6ac4 0%, #4a55a8 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(92, 106, 196, 0.4);
}

.filter-pill.active-active {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(5, 150, 105, 0.4);
}

.filter-pill.active-retired {
  background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(217, 119, 6, 0.4);
}

.filter-pill.active-sold {
  background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
  color: #fff;
  box-shadow: 0 3rpx 12rpx rgba(2, 132, 199, 0.4);
}

.sort-wrapper {
  display: flex;
  align-items: center;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--glass-bg);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
  box-shadow: var(--shadow-card);
}

.sort-arrow {
  font-size: 16rpx;
  color: #999;
  transition: transform 0.3s;
}

.sort-arrow.desc {
  transform: rotate(180deg);
}

/* 资产列表 */
.asset-list {
  position: relative;
  z-index: 1;
  padding: 10rpx 20rpx 200rpx;
  height: calc(100vh - 580rpx);
  width: 100%;
  box-sizing: border-box;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.list-title-wrapper {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.list-count-badge {
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.list-count-badge text {
  line-height: 1;
}

/* 资产卡片 */
.asset-card {
  background: var(--glass-bg);
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  width: 100%;
  box-sizing: border-box;
}

.asset-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.card-left {
  flex-shrink: 0;
  width: 64rpx;
}

.asset-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 2rpx solid #e5e7eb;
}

.avatar-icon {
  font-size: inherit;
  line-height: 1;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.asset-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.asset-badge.active {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #2e7d32;
}

.asset-badge.retired {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  color: #f57c00;
}

.asset-badge.sold {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1565c0;
}

.card-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 10rpx 0;
}

.card-stats .stat-item {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.card-stats .stat-label {
  font-size: 14rpx;
  color: #999;
  white-space: nowrap;
}

.card-stats .stat-value {
  font-size: 18rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
}

.card-stats .stat-value.cost {
  color: #667eea;
}

.card-stats .stat-value.price {
  color: #f57c00;
}

.stat-divider {
  width: 1rpx;
  height: 32rpx;
  background: #e0e0e0;
  margin: 0 12rpx;
}

.category-tag {
  font-size: 18rpx;
  color: #667eea;
  background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%);
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
}

.purchase-date {
  font-size: 18rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.list-bottom-spacer {
  height: 40rpx;
}

/* 设置视图样式 */
.setting-content {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx; /* 为底部悬浮控件留出足够空间 */
  padding-top: 20rpx;
}

.setting-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
}

.setting-back {
  position: absolute;
  left: 30rpx;
  top: 40rpx;
  z-index: 2;
}

.back-icon {
  font-size: 48rpx;
  line-height: 1;
  color: #fff;
}

.setting-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
  text-align: center;
  padding: 0 60rpx;
}

.setting-main {
  padding: 20rpx;
}

.setting-section {
  margin-bottom: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 30rpx 20rpx;
  text-transform: uppercase;
}

.setting-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.item-label {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.item-value {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  line-height: 1;
}

.item-switch {
  transform: scale(0.7);
}

/* 分类管理页面样式 */
.category-management-container {
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-top: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.category-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  color: #fff;
  font-size: 28rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
}

.add-category-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  margin-top: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
}

/* 底部控制按钮 - 首页/设置和新增资产分开 */
.bottom-controls {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 40rpx 40rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  pointer-events: none;
}

.bottom-controls .mode-switch-fab,
.bottom-controls .add-asset-fab {
  pointer-events: auto;
}

/* 首页/设置切换悬浮按钮组 - 自然生态风格扁平化样式 */
.mode-switch-fab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.fab-group {
  display: flex;
  gap: 16rpx;
  /* 使用自然生态风格的透明渐变背景 */
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, rgba(240, 248, 255, 0.4) 100%);
  border-radius: 50rpx; /* 更加椭圆形 */
  padding: 20rpx 30rpx; /* 增加内边距使整体更大更椭圆 */
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.fab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  padding: 14rpx 10rpx;
  border-radius: 36rpx; /* 更大的圆角 */
  transition: all 0.3s ease;
  color: #4CAF50;
  /* 半透明背景与整体风格一致 */
  background: rgba(255, 255, 255, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.15);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

.fab-item:active {
  transform: scale(0.95);
}

.fab-item.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.fab-item.active .fab-icon {
  color: #fff;
}

.fab-item.active .fab-label {
  color: #fff;
}

.fab-icon {
  font-size: 32rpx;
  color: #4CAF50;
  line-height: 1;
  margin-bottom: 4rpx;
}

.fab-label {
  font-size: 18rpx;
  color: #4CAF50;
  line-height: 1;
}

/* 新增资产悬浮按钮 - 自然生态风格扁平化样式 */
.add-asset-fab {
  width: 90rpx;
  height: 90rpx;
  position: relative;
}

.add-asset-fab .fab-inner {
  width: 100%;
  height: 100%;
  /* 使用自然生态风格的绿色渐变 */
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 自然生态风格阴影 */
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.25);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-asset-fab .fab-inner:active {
  transform: scale(0.92);
}

.add-asset-fab .fab-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.add-asset-fab .fab-label {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

.add-asset-fab .fab-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
