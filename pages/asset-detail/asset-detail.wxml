<!--asset-detail.wxml-->
<view class="container">
  <!-- 动态背景 -->
  <view class="bg-decoration">
    <view class="bubble bubble-1"></view>
    <view class="bubble bubble-2"></view>
    <view class="bubble bubble-3"></view>
    <view class="bubble bubble-4"></view>
  </view>

  <!-- 主卡片 -->
  <view class="detail-card">
    <!-- 资产名称 -->
    <view class="asset-name">
      <text>{{asset.name}}</text>
      <!-- 订阅标签 -->
      <text class="subscription-tag" wx:if="{{asset.assetType === 'subscription'}}">订阅</text>
    </view>

    <!-- 价格展示 -->
    <view class="price-wrapper">
      <text class="currency">¥</text>
      <!-- 订阅资产显示总投入，普通资产显示价格 -->
      <text class="asset-price" wx:if="{{asset.assetType === 'subscription'}}">{{displayInfo.totalInvestment}}</text>
      <text class="asset-price" wx:else>{{asset.price}}</text>
    </view>

    <!-- 订阅资产：每期金额 -->
    <view class="period-amount-wrapper" wx:if="{{asset.assetType === 'subscription'}}">
      <text class="period-label">每期</text>
      <text class="period-amount">¥{{asset.periodAmount}}</text>
      <text class="period-type">/{{displayInfo.periodTypeText}}</text>
    </view>

    <!-- 图标和状态/分类同行 -->
    <view class="icon-status-row">
      <!-- 资产图标 -->
      <view class="asset-icon-wrapper">
        <view class="asset-icon-container">
          <image wx:if="{{displayIcon}}" class="asset-icon-img" src="{{displayIcon}}" mode="aspectFit" bindtap="previewIcon"></image>
          <text wx:else class="asset-icon">{{asset.icon || '📦'}}</text>
        </view>
        <view class="icon-shine"></view>
      </view>

      <!-- 右侧：状态和分类 -->
      <view class="status-category-wrapper">
        <!-- 订阅资产状态标签 -->
        <block wx:if="{{asset.assetType === 'subscription'}}">
          <view class="status-pill pending" wx:if="{{asset.subscriptionStatus === 'pending'}}">
            <text class="status-dot"></text>
            ⏳ 待生效
          </view>
          <view class="status-pill active" wx:elif="{{asset.subscriptionStatus === 'active' || !asset.subscriptionStatus}}">
            <text class="status-dot"></text>
            🔄 订阅中
          </view>
          <view class="status-pill ended" wx:else>
            <text class="status-dot"></text>
            ⏹️ 已结束
          </view>
        </block>
        <!-- 普通资产状态标签 -->
        <block wx:else>
          <view class="status-pill {{asset.status}}">
            <text class="status-dot"></text>
            {{asset.status === 'active' ? '💪 服役中' : asset.status === 'retired' ? '😴 已退役' : '💰 已卖出'}}
          </view>
        </block>

        <!-- 类别标签 -->
        <view class="category-tag">
          <image wx:if="{{categoryIcon}}" class="tag-icon-img" src="{{categoryIcon}}" mode="aspectFit"></image>
          <text wx:elif="{{categoryIconEmoji}}" class="tag-icon">{{categoryIconEmoji}}</text>
          <text wx:else class="tag-icon">🏷️</text>
          <text class="tag-text">{{asset.category}}</text>
        </view>
      </view>
    </view>

    <!-- 信息卡片区域 -->
    <view class="info-cards">
      <!-- 订阅资产专属信息 -->
      <block wx:if="{{asset.assetType === 'subscription'}}">
        <!-- 周期类型 -->
        <view class="info-card subscription-card">
          <view class="card-icon">🔄</view>
          <view class="card-content">
            <view class="card-label">周期类型</view>
            <view class="card-value">{{displayInfo.periodTypeText}}</view>
          </view>
        </view>

        <!-- 订阅开始日期 -->
        <view class="info-card" wx:if="{{asset.subscriptionStartDate}}">
          <view class="card-icon">📅</view>
          <view class="card-content">
            <view class="card-label">开始日期</view>
            <view class="card-value">{{displayInfo.subscriptionStartDateFormatted}}</view>
          </view>
        </view>

        <!-- 订阅结束日期 -->
        <view class="info-card" wx:if="{{asset.subscriptionEndDate}}">
          <view class="card-icon">🏁</view>
          <view class="card-content">
            <view class="card-label">结束日期</view>
            <view class="card-value">{{displayInfo.subscriptionEndDateFormatted}}</view>
          </view>
        </view>

        <!-- 已订阅时长 -->
        <view class="info-card highlight" wx:if="{{asset.subscriptionStatus !== 'pending'}}">
          <view class="card-icon">⏰</view>
          <view class="card-content">
            <view class="card-label">已订阅时长</view>
            <view class="card-value highlight-value">{{displayInfo.usedDays}} 天</view>
          </view>
          <view class="card-decoration"></view>
        </view>

        <!-- 日均成本 -->
        <view class="info-card highlight" wx:if="{{asset.subscriptionStatus !== 'pending'}}">
          <view class="card-icon">📊</view>
          <view class="card-content">
            <view class="card-label">日均成本</view>
            <view class="card-value highlight-value">¥{{displayInfo.dailyCost}}/天</view>
          </view>
          <view class="card-decoration"></view>
        </view>

        <!-- 总投入 -->
        <view class="info-card highlight" wx:if="{{asset.subscriptionStatus !== 'pending'}}">
          <view class="card-icon">💰</view>
          <view class="card-content">
            <view class="card-label">总投入</view>
            <view class="card-value highlight-value">¥{{displayInfo.totalInvestment}}</view>
          </view>
          <view class="card-decoration"></view>
        </view>
      </block>

      <!-- 普通资产信息 -->
      <block wx:else>
        <!-- 购买日期 -->
        <view class="info-card" wx:if="{{asset.purchaseDate}}">
          <view class="card-icon">📅</view>
          <view class="card-content">
            <view class="card-label">购买日期</view>
            <view class="card-value">{{displayInfo.purchaseDateFormatted}}</view>
          </view>
        </view>

        <!-- 添加时间 -->
        <view class="info-card" wx:if="{{asset.createdAt}}">
          <view class="card-icon">✨</view>
          <view class="card-content">
            <view class="card-label">添加时间</view>
            <view class="card-value">{{displayInfo.createdAtFormatted}}</view>
          </view>
        </view>

        <!-- 退役日期 -->
        <view class="info-card" wx:if="{{asset.status === 'retired' && asset.retiredDate}}">
          <view class="card-icon">🏁</view>
          <view class="card-content">
            <view class="card-label">退役日期</view>
            <view class="card-value">{{displayInfo.retiredDateFormatted}}</view>
          </view>
        </view>

        <!-- 卖出日期 -->
        <view class="info-card" wx:if="{{asset.status === 'sold' && asset.soldDate}}">
          <view class="card-icon">💵</view>
          <view class="card-content">
            <view class="card-label">卖出日期</view>
            <view class="card-value">{{displayInfo.soldDateFormatted}}</view>
          </view>
        </view>

        <!-- 使用时长 (退役/卖出状态显示) -->
        <view class="info-card" wx:if="{{(asset.status === 'retired' || asset.status === 'sold') && asset.purchaseDate}}">
          <view class="card-icon">📆</view>
          <view class="card-content">
            <view class="card-label">使用时长</view>
            <view class="card-value">{{displayInfo.usedDays}} 天</view>
          </view>
        </view>

        <!-- 折合每日 (退役/卖出状态显示) -->
        <view class="info-card" wx:if="{{(asset.status === 'retired' || asset.status === 'sold') && asset.price && asset.purchaseDate}}">
          <view class="card-icon">📊</view>
          <view class="card-content">
            <view class="card-label">折合每日</view>
            <view class="card-value">¥{{displayInfo.dailyEquivalent}}/天</view>
          </view>
        </view>

        <!-- 服役时长 (服役中状态显示) -->
        <view class="info-card highlight" wx:if="{{asset.status === 'active' && asset.purchaseDate}}">
          <view class="card-icon">⏰</view>
          <view class="card-content">
            <view class="card-label">服役时长</view>
            <view class="card-value highlight-value">{{displayInfo.usedDays}} 天</view>
          </view>
          <view class="card-decoration"></view>
        </view>

        <!-- 日均成本 (服役中状态显示) -->
        <view class="info-card highlight" wx:if="{{asset.status === 'active' && asset.price && asset.purchaseDate}}">
          <view class="card-icon">📊</view>
          <view class="card-content">
            <view class="card-label">日均成本</view>
            <view class="card-value highlight-value">¥{{displayInfo.dailyCost}}/天</view>
          </view>
          <view class="card-decoration"></view>
        </view>
      </block>
    </view>

    <!-- 特殊设置 -->
    <view class="special-tags" wx:if="{{asset.excludeTotal || asset.excludeDaily}}">
      <view class="special-tag total" wx:if="{{asset.excludeTotal}}">
        <text>🚫 不计入总资产</text>
      </view>
      <view class="special-tag daily" wx:if="{{asset.excludeDaily}}">
        <text>🚫 不计入总日均</text>
      </view>
    </view>

    <!-- 备注区域 -->
    <view class="remark-section" wx:if="{{asset.remark}}">
      <view class="remark-header">
        <text class="remark-icon">📝</text>
        <text class="remark-title">备注</text>
      </view>
      <view class="remark-content">{{asset.remark}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn edit-btn" bindtap="editAsset">
        <text class="btn-icon">✏️</text>
        <text class="btn-text">编辑</text>
      </button>
      <button class="btn delete-btn" bindtap="deleteAsset">
        <text class="btn-icon">🗑️</text>
        <text class="btn-text">删除</text>
      </button>
    </view>
  </view>
</view>