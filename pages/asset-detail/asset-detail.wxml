<!--asset-detail.wxml-->
<view class="container theme-{{currentThemeKey}}" style="{{themeStyle}}">
  <!-- 动态背景 -->
  <view class="bg-decoration">
    <view class="bubble bubble-1"></view>
    <view class="bubble bubble-2"></view>
    <view class="bubble bubble-3"></view>
    <view class="bubble bubble-4"></view>
  </view>

  <!-- 主卡片 -->
  <view class="detail-card">
    <!-- 资产类型图标和文案 -->
    <view class="asset-type-badge" wx:if="{{asset.assetType === 'subscription'}}">
      <image class="type-badge-icon" src="/images/subscription-asset.svg" mode="aspectFit"></image>
      <text class="type-badge-text">订阅</text>
    </view>
    <view class="asset-type-badge" wx:else>
      <image class="type-badge-icon" src="/images/fixed-asset.svg" mode="aspectFit"></image>
      <text class="type-badge-text">普通</text>
    </view>

    <!-- 资产名称 -->
    <view class="asset-name">
      <text>{{asset.name}}</text>
    </view>

    <!-- 价格展示 -->
    <view class="price-wrapper">
      <text class="currency">¥</text>
      <!-- 订阅资产显示总投入，普通资产显示价格 -->
      <text class="asset-price" wx:if="{{asset.assetType === 'subscription'}}">{{displayInfo.totalInvestment}}</text>
      <text class="asset-price" wx:else>{{asset.price}}</text>
    </view>

    <!-- 订阅资产：每期金额 -->
    <view class="period-amount-wrapper" wx:if="{{asset.assetType === 'subscription'}}">
      <text class="period-label">每期</text>
      <text class="period-amount">¥{{asset.periodAmount}}</text>
      <text class="period-type">/{{displayInfo.periodTypeText}}</text>
    </view>

    <!-- 资产头像 - 圆形居中 -->
    <view class="asset-avatar-section">
      <view class="avatar-wrapper">
        <view class="avatar-ring"></view>
        <view class="avatar-container">
          <image wx:if="{{displayIcon}}" class="avatar-img" src="{{displayIcon}}" mode="aspectFill" bindtap="previewIcon"></image>
          <text wx:else class="avatar-emoji">{{asset.icon || '📦'}}</text>
        </view>
        <view class="avatar-glow"></view>
      </view>
    </view>

    <!-- 状态和分类标签行 -->
    <view class="status-category-row">
      <!-- 订阅资产状态标签 -->
      <block wx:if="{{asset.assetType === 'subscription'}}">
        <view class="status-pill pending" wx:if="{{asset.subscriptionStatus === 'pending'}}">
          <image class="status-pill-icon" src="/images/pending.svg" mode="aspectFit"></image>
          待生效
        </view>
        <view class="status-pill active" wx:elif="{{asset.subscriptionStatus === 'active' || !asset.subscriptionStatus}}">
          <image class="status-pill-icon" src="/images/subscribing.svg" mode="aspectFit"></image>
          订阅中
        </view>
        <view class="status-pill ended" wx:else>
          <image class="status-pill-icon" src="/images/subscription-ended.svg" mode="aspectFit"></image>
          已结束
        </view>
      </block>
      <!-- 普通资产状态标签 -->
      <block wx:else>
        <view class="status-pill {{asset.status}}">
          <image wx:if="{{asset.status}}" class="status-pill-icon" src="/images/{{asset.status}}.svg" mode="aspectFit"></image>
          {{asset.status === 'active' ? '服役中' : asset.status === 'retired' ? '已退役' : '已卖出'}}
        </view>
      </block>

      <!-- 类别标签 -->
      <view class="category-tag">
        <image wx:if="{{categoryIcon}}" class="tag-icon-img" src="{{categoryIcon}}" mode="aspectFit"></image>
        <text wx:elif="{{categoryIconEmoji}}" class="tag-icon">{{categoryIconEmoji}}</text>
        <text wx:else class="tag-icon">🏷️</text>
        <text class="tag-text">{{asset.category}}</text>
      </view>
    </view>

    <!-- 信息卡片区域 -->
    <view class="info-cards">
      <!-- 订阅资产专属信息 -->
      <block wx:if="{{asset.assetType === 'subscription'}}">
        <!-- 周期类型 -->
        <view class="info-card subscription-card">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/period-type.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">周期类型</view>
            <view class="card-value">
              <text wx:if="{{asset.periodType === 'custom'}}">自定义 / {{asset.periodDays || 30}}天</text>
              <text wx:else>{{displayInfo.periodTypeText}}</text>
            </view>
          </view>
        </view>

        <!-- 周期计算方式 -->
        <view class="info-card" wx:if="{{displayInfo.periodCalcMethodText}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/period-type.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">周期计算方式</view>
            <view class="card-value">{{displayInfo.periodCalcMethodText}}</view>
          </view>
        </view>

        <!-- 订阅开始日期（待订阅显示"开始日期"，活跃/已结束显示"订阅日期"） -->
        <view class="info-card" wx:if="{{asset.subscriptionStartDate || asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/start-date.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">{{asset.subscriptionStatus === 'pending' ? '开始日期' : '订阅日期'}}</view>
            <view class="card-value">{{displayInfo.subscriptionStartDateFormatted || displayInfo.purchaseDateFormatted}}</view>
          </view>
        </view>

        <!-- 订阅结束日期 -->
        <view class="info-card" wx:if="{{asset.subscriptionEndDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/end-date.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">结束日期</view>
            <view class="card-value">{{displayInfo.subscriptionEndDateFormatted}}</view>
          </view>
        </view>

        <!-- 订阅时长 -->
        <view class="info-card highlight" wx:if="{{asset.subscriptionStatus !== 'pending'}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/subscription-duration.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">{{asset.subscriptionStatus === 'ended' ? '订阅时长' : '已订阅'}}</view>
            <view class="card-value highlight-value">{{displayInfo.usedDays}} 天</view>
          </view>
          <view class="card-decoration"></view>
        </view>

        <!-- 已订阅期数 -->
        <view class="info-card" wx:if="{{asset.subscriptionStatus !== 'pending' && displayInfo.periodCount > 0}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/subscription-duration.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">已订阅期数</view>
            <view class="card-value">{{displayInfo.periodCountText}}</view>
          </view>
        </view>

        <!-- 折合每日（已结束订阅显示） -->
        <view class="info-card" wx:if="{{asset.subscriptionStatus === 'ended'}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/daily-cost.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">折合每日</view>
            <view class="card-value">¥{{displayInfo.dailyEquivalent}}/天</view>
          </view>
        </view>

        <!-- 日均成本 -->
        <view class="info-card {{asset.subscriptionStatus === 'ended' ? '' : 'highlight'}}" wx:if="{{asset.subscriptionStatus !== 'pending'}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/daily-cost.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">日均成本</view>
            <view class="card-value {{asset.subscriptionStatus === 'ended' ? '' : 'highlight-value'}}">¥{{displayInfo.dailyCost}}/天</view>
          </view>
          <view class="card-decoration" wx:if="{{asset.subscriptionStatus !== 'ended'}}"></view>
        </view>

        <!-- 总投入 -->
        <view class="info-card highlight" wx:if="{{asset.subscriptionStatus !== 'pending'}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/total-investment.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">总投入</view>
            <view class="card-value highlight-value">¥{{displayInfo.totalInvestment}}</view>
          </view>
          <view class="card-decoration"></view>
        </view>
      </block>

      <!-- 普通资产信息 -->
      <block wx:else>
        <!-- 购买日期 -->
        <view class="info-card" wx:if="{{asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/purchase-date.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">购买日期</view>
            <view class="card-value">{{displayInfo.purchaseDateFormatted}}</view>
          </view>
        </view>

        <!-- 添加时间 -->
        <view class="info-card" wx:if="{{asset.createdAt}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/add-time.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">添加时间</view>
            <view class="card-value">{{displayInfo.createdAtFormatted}}</view>
          </view>
        </view>

        <!-- 退役日期 -->
        <view class="info-card" wx:if="{{asset.status === 'retired' && asset.retiredDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/retired-date.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">退役日期</view>
            <view class="card-value">{{displayInfo.retiredDateFormatted}}</view>
          </view>
        </view>

        <!-- 卖出日期 -->
        <view class="info-card" wx:if="{{asset.status === 'sold' && asset.soldDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/sold-date.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">卖出日期</view>
            <view class="card-value">{{displayInfo.soldDateFormatted}}</view>
          </view>
        </view>

        <!-- 服役时长 (退役/卖出状态显示) -->
        <view class="info-card" wx:if="{{(asset.status === 'retired' || asset.status === 'sold') && asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/active-duration.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">服役时长</view>
            <view class="card-value">{{displayInfo.usedDays}} 天</view>
          </view>
        </view>

        <!-- 折合每日 (退役/卖出状态显示) -->
        <view class="info-card" wx:if="{{(asset.status === 'retired' || asset.status === 'sold') && asset.price && asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/daily-cost.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">折合每日</view>
            <view class="card-value">¥{{displayInfo.dailyEquivalent}}/天</view>
          </view>
        </view>

        <!-- 日均成本 (退役/卖出状态显示) -->
        <view class="info-card" wx:if="{{(asset.status === 'retired' || asset.status === 'sold') && asset.price && asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/daily-cost.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">日均成本</view>
            <view class="card-value">¥{{displayInfo.dailyCost}}/天</view>
          </view>
        </view>

        <!-- 已服役 (服役中状态显示) -->
        <view class="info-card highlight" wx:if="{{asset.status === 'active' && asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/active-duration.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">已服役</view>
            <view class="card-value highlight-value">{{displayInfo.usedDays}} 天</view>
          </view>
          <view class="card-decoration"></view>
        </view>

        <!-- 日均成本 (服役中状态显示) -->
        <view class="info-card highlight" wx:if="{{asset.status === 'active' && asset.price && asset.purchaseDate}}">
          <view class="card-icon">
            <image class="card-icon-svg" src="/images/daily-cost.svg" mode="aspectFit"></image>
          </view>
          <view class="card-content">
            <view class="card-label">日均成本</view>
            <view class="card-value highlight-value">¥{{displayInfo.dailyCost}}/天</view>
          </view>
          <view class="card-decoration"></view>
        </view>
      </block>
    </view>

    <!-- 特殊设置 -->
    <view class="special-tags" wx:if="{{asset.excludeTotal || asset.excludeDaily}}">
      <view class="special-tag total" wx:if="{{asset.excludeTotal}}">
        <text>不计入总资产</text>
      </view>
      <view class="special-tag daily" wx:if="{{asset.excludeDaily}}">
        <text>不计入总日均</text>
      </view>
    </view>

    <!-- 备注区域 -->
    <view class="remark-section" wx:if="{{asset.remark}}">
      <view class="remark-header">
        <image class="remark-icon-svg" src="/images/remark.svg" mode="aspectFit"></image>
        <text class="remark-title">备注</text>
      </view>
      <view class="remark-content">{{asset.remark}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn edit-btn" bindtap="editAsset">
        <image class="btn-icon-svg" src="/images/edit.svg" mode="aspectFit"></image>
        <text class="btn-text">编辑</text>
      </button>
      <button class="btn delete-btn" bindtap="deleteAsset">
        <image class="btn-icon-svg" src="/images/delete.svg" mode="aspectFit"></image>
        <text class="btn-text">删除</text>
      </button>
    </view>
  </view>
</view>
