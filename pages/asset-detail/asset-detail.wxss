/* asset-detail.wxss - 商务黑白灰风格 */

/* 变量定义 */
page {
  --dark: #333333;
  --gray-900: #1A1A1A;
  --gray-700: #555555;
  --gray-500: #888888;
  --gray-300: #CCCCCC;
  --gray-200: #E5E5E5;
  --gray-100: #F5F5F5;
  --white: #FFFFFF;
  --success: #52C41A;
  --success-100: #F6FFED;
  --error: #CF1322;
  --error-100: #FFF1F0;
  --warning: #D48806;
  --warning-100: #FFFBE6;
}

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
  position: relative;
}

/* 动态背景装饰 - 移除 */
.bg-decoration {
  display: none;
}

/* 主卡片 */
.detail-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 42, 54, 0.08);
  position: relative;
  border: 1rpx solid #CCCCCC;
}

/* 资产类型角标 - 卡片左上角 */
.asset-type-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
  line-height: 1;
  padding: 6rpx 12rpx;
  background: var(--primary-100);
  border-radius: 8rpx;
  border: 1rpx solid var(--primary-200);
}

.type-badge-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.type-badge-text {
  font-size: 22rpx;
  color: var(--primary-600);
  font-weight: 500;
  line-height: 1;
}

/* 资产头像 - 圆形居中 */
.asset-avatar-section {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 16rpx;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.avatar-container {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(30, 42, 54, 0.15);
}

.avatar-emoji {
  font-size: 100rpx;
  line-height: 1;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-glow {
  position: absolute;
  top: -30rpx;
  left: -30rpx;
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle, rgba(62, 115, 159, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

/* 状态和分类标签行 */
.status-category-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

/* 状态药丸 */
.status-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: var(--bg-subtle);
  color: var(--text-muted);
}

.status-pill.active {
  color: var(--success-700);
  background: var(--success-100);
}

.status-pill.pending {
  color: var(--warning-700);
  background: var(--warning-100);
}

.status-pill.ended {
  color: var(--text-muted);
  background: var(--bg-subtle);
}

.status-pill.retired {
  color: var(--gray-700, #555555);
  background: var(--gray-200, #E5E5E5);
}

.status-pill.sold {
  color: var(--error-700);
  background: var(--error-100);
}

.status-pill-icon {
  width: 20rpx;
  height: 20rpx;
}

/* 类别标签 */
.category-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: var(--primary-100);
  color: var(--primary-600);
}

.tag-icon {
  font-size: 20rpx;
  line-height: 1;
}

.tag-icon-img {
  width: 20rpx;
  height: 20rpx;
}

.tag-text {
  font-size: 24rpx;
  line-height: 1;
}

/* 资产名称 */
.asset-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #1A1A1A;
  text-align: center;
  margin-top: 20rpx;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

/* 价格包装 - 价格高亮显示 */
.price-wrapper {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
}

.currency {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 4rpx;
}

.asset-price {
  font-size: 64rpx;
  font-weight: 800;
  color: #333333;
}

/* 信息卡片区域 */
.info-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.info-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid #CCCCCC;
  box-shadow: 0 2rpx 6rpx rgba(30, 42, 54, 0.04);
}

.info-card.highlight {
  background: #FFFFFF;
  border: 1rpx solid #CCCCCC;
}

.card-value.highlight-value {
  color: #333333;
  font-weight: 700;
}

.card-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.card-icon-svg {
  width: 36rpx;
  height: 36rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-label {
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 4rpx;
}

.card-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.card-decoration {
  display: none;
}

/* 特殊设置标签 */
.special-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.special-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.special-tag.total {
  color: #9B5C1A;
  background: #FFFBE6;
}

.special-tag.daily {
  color: #0A6B52;
  background: #F6FFED;
}

/* 备注区域 */
.remark-section {
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  border: 1rpx dashed #CCCCCC;
}

.remark-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.remark-icon {
  font-size: 28rpx;
}

.remark-icon-svg {
  width: 28rpx;
  height: 28rpx;
}

.remark-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #555555;
}

.remark-content {
  font-size: 26rpx;
  color: #1A1A1A;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn {
  flex: 1;
  height: 96rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn::before {
  display: none;
}

/* 编辑按钮：主按钮样式 */
.edit-btn {
  background: #333333;
  color: #FFFFFF;
}

.edit-btn:active {
  background: #555555;
}

/* 删除按钮：边框按钮样式（次按钮） */
.delete-btn {
  background: #FFFFFF;
  color: #CF1322;
  border: 2rpx solid #CF1322;
}

.delete-btn:active {
  background: #FFF1F0;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-icon-svg {
  width: 32rpx;
  height: 32rpx;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.edit-btn:after,
.delete-btn:after {
  border: none;
}

/* 订阅标签 */
.asset-name {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.subscription-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #333333;
  vertical-align: middle;
}

/* 每期金额显示 - 高亮 */
.period-amount-wrapper {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
  gap: 4rpx;
}

.period-label {
  font-size: 24rpx;
  color: #333333;
}

.period-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.period-type {
  font-size: 24rpx;
  color: #555555;
}

/* 订阅资产状态样式 */
.status-pill.pending {
  color: #9B5C1A;
}

.status-pill.ended {
  color: #9B2C2C;
}

/* 订阅资产专属信息卡片 */
.info-card.subscription-card {
  background: #FFFFFF;
  border: 1rpx solid #CCCCCC;
}