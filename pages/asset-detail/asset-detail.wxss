/* asset-detail.wxss - 温暖极简浅色主题 */

.container {
  min-height: 100vh;
  background: var(--bg-base);
  padding: 30rpx;
  position: relative;
}

/* 动态背景装饰 */
.bg-decoration {
  display: none;
}

/* 主卡片 */
.detail-card {
  background: var(--bg-card);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: -3rpx -3rpx 8rpx rgba(255, 255, 255, 0.6), 3rpx 3rpx 12rpx rgba(var(--shadow-rgb), 0.1);
  position: relative;
  border: 1rpx solid var(--border-light);
}

/* 资产类型角标 */
.asset-type-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
  line-height: 1;
  padding: 6rpx 14rpx;
  background: var(--primary-soft);
  border-radius: 10rpx;
  border: 1rpx solid var(--primary-100);
}

.type-badge-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.type-badge-text {
  font-size: 22rpx;
  color: var(--primary-600);
  font-weight: 500;
  line-height: 1;
}

/* 资产头像 - 圆形居中 */
.asset-avatar-section {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 20rpx;
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar-container {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.5), 2rpx 2rpx 12rpx rgba(var(--shadow-rgb), 0.12);
}

.avatar-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-glow {
  display: none;
}

.avatar-ring {
  display: none;
}

/* 资产名称 */
.asset-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-default);
  text-align: center;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

/* 价格展示 */
.price-wrapper {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
}

.currency {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-muted);
  margin-right: 4rpx;
}

.asset-price {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-default);
  letter-spacing: 2rpx;
}

/* 订阅：每期金额 */
.period-amount-wrapper {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
  gap: 4rpx;
}

.period-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.period-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary-600);
}

.period-type {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 状态和分类标签行 */
.status-category-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

/* 状态药丸 */
.status-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: var(--bg-subtle);
  color: var(--text-muted);
}

.status-pill-icon {
  width: 20rpx;
  height: 20rpx;
}

.status-pill.active {
  color: var(--success);
  background: var(--success-bg);
}

.status-pill.pending {
  color: var(--warning);
  background: var(--warning-bg);
}

.status-pill.ended {
  color: var(--text-muted);
  background: var(--bg-subtle);
}

.status-pill.retired {
  color: var(--text-muted);
  background: var(--bg-subtle);
}

.status-pill.sold {
  color: var(--error);
  background: var(--error-bg);
}

/* 类别标签 */
.category-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: var(--primary-soft);
  color: var(--primary-600);
}

.tag-icon {
  font-size: 20rpx;
  line-height: 1;
}

.tag-icon-img {
  width: 20rpx;
  height: 20rpx;
}

.tag-text {
  font-size: 24rpx;
  line-height: 1;
}

/* 信息卡片网格 */
.info-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

/* 信息卡片 */
.info-card {
  background: var(--bg-subtle);
  border-radius: 18rpx;
  padding: 20rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  box-shadow: -1rpx -1rpx 4rpx rgba(255, 255, 255, 0.4), 1rpx 1px 6rpx rgba(var(--shadow-rgb), 0.06);
}

.info-card.highlight {
  background: var(--bg-card);
  border: 1rpx solid var(--primary-100);
  box-shadow: -1rpx -1rpx 4rpx rgba(255, 255, 255, 0.4), 1rpx 1px 6rpx rgba(var(--shadow-rgb), 0.06);
}

.card-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.card-icon-svg {
  width: 34rpx;
  height: 34rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
  font-weight: 500;
}

.card-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-default);
}

.card-value.highlight-value {
  color: var(--primary-600);
  font-weight: 700;
}

.card-decoration {
  display: none;
}

/* 特殊设置标签 */
.special-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.special-tag {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
  font-weight: 500;
}

.special-tag.total {
  color: var(--warning);
  background: var(--warning-bg);
}

.special-tag.daily {
  color: var(--success);
  background: var(--success-bg);
}

/* 备注区域 */
.remark-section {
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  background: var(--bg-subtle);
  border: 1rpx solid var(--border-light);
}

.remark-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.remark-icon {
  font-size: 28rpx;
}

.remark-icon-svg {
  width: 28rpx;
  height: 28rpx;
}

.remark-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-muted);
}

.remark-content {
  font-size: 26rpx;
  color: var(--text-default);
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn {
  flex: 1;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn::before {
  display: none;
}

.edit-btn {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 16rpx rgba(var(--primary-600-rgb), 0.25);
}

.edit-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.delete-btn {
  background: var(--bg-card);
  color: var(--error);
  border: 2rpx solid var(--error);
}

.delete-btn:active {
  background: var(--error-bg);
  transform: scale(0.97);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-icon-svg {
  width: 32rpx;
  height: 32rpx;
}

.edit-btn:after,
.delete-btn:after {
  border: none;
}

/* 订阅标签 */
.subscription-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: var(--bg-subtle);
  color: var(--text-muted);
  vertical-align: middle;
}
