/* asset-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 40rpx 30rpx;
}

.detail-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

/* 状态标签 */
.status-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.status-active {
  background-color: #e8f5e9;
  color: #4caf50;
  border: 1rpx solid #4caf50;
}

.status-retired {
  background-color: #f5f5f5;
  color: #9e9e9e;
  border: 1rpx solid #e0e0e0;
}

.status-sold {
  background-color: #e3f2fd;
  color: #2196f3;
  border: 1rpx solid #2196f3;
}

/* 资产信息 */
.asset-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.asset-price {
  font-size: 56rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 12rpx;
}

.asset-category {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  display: inline-block;
}

/* 信息列表 */
.info-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 180rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.remark {
  color: #666;
  white-space: pre-wrap;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 60rpx;
  display: flex;
  gap: 24rpx;
}

.edit-btn,
.delete-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.delete-btn {
  background-color: #f44336;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(244, 67, 54, 0.3);
}

.edit-btn:after,
.delete-btn:after {
  border: none;
}

.edit-btn:active,
.delete-btn:active {
  opacity: 0.9;
}
