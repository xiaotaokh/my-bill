<!-- pages/setting/setting.wxml -->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">设置</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="settings-list">
    <!-- 分类管理 -->
    <view class="setting-item" bindtap="navigateToCategoryManage">
      <view class="setting-icon">
        <text>🏷️</text>
      </view>
      <view class="setting-info">
        <text class="setting-title">分类管理</text>
        <text class="setting-desc">管理资产分类</text>
      </view>
      <view class="setting-arrow">
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 关于 -->
    <view class="setting-item" bindtap="showAboutInfo">
      <view class="setting-icon">
        <text>ℹ️</text>
      </view>
      <view class="setting-info">
        <text class="setting-title">关于</text>
        <text class="setting-desc">了解我的账本</text>
      </view>
      <view class="setting-arrow">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">我的账本 v1.0.0</text>
  </view>
</view>