/* category-manage.wxss - 自然有机/活泼风格 */

/* ========== CSS 变量 ========== */
page {
  --color-primary: #4A7C59;        /* 森林绿 */
  --color-primary-light: #6B9B7A;  /* 浅森林绿 */
  --color-primary-dark: #3D6349;   /* 深森林绿 */
  --color-secondary: #F5E6D3;      /* 米色/奶油色 */
  --color-accent: #E8A87C;         /* 温暖珊瑚橙 */
  --color-accent-light: #F4C4A8;    /* 浅珊瑚 */
  --color-bg: #FDF8F3;             /* 温暖的米白背景 */
  --color-bg-card: #FFFFFF;        /* 卡片白 */
  --color-text: #3D3D3D;           /* 主文字 - 深灰 */
  --color-text-light: #7A7A7A;     /* 辅助文字 */
  --color-text-muted: #A0A0A0;     /* 淡文字 */
  --color-success: #7CB342;        /* 成功绿 */
  --color-warning: #FFB74D;        /* 警告橙 */
  --color-danger: #E57373;         /* 柔和红 */
  --color-border: #E8E0D8;         /* 边框色 */

  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;

  --shadow-sm: 0 4rpx 12rpx rgba(74, 124, 89, 0.08);
  --shadow-md: 0 8rpx 24rpx rgba(74, 124, 89, 0.12);
  --shadow-lg: 0 16rpx 48rpx rgba(74, 124, 89, 0.16);

  --font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 装饰性背景 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.leaf {
  position: absolute;
  font-size: 48rpx;
  opacity: 0.15;
  animation: float 6s ease-in-out infinite;
}

.leaf-1 {
  top: 10%;
  right: 10%;
  animation-delay: 0s;
}

.leaf-2 {
  top: 30%;
  left: 5%;
  animation-delay: -2s;
}

.leaf-3 {
  bottom: 20%;
  right: 8%;
  animation-delay: -4s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(10deg);
  }
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(74, 124, 89, 0.05), rgba(232, 168, 124, 0.05));
}

.bubble-1 {
  width: 200rpx;
  height: 200rpx;
  top: -50rpx;
  left: -50rpx;
}

.bubble-2 {
  width: 150rpx;
  height: 150rpx;
  bottom: 10%;
  right: -30rpx;
}

/* ========== 页面头部 ========== */
.page-header {
  position: relative;
  z-index: 1;
  padding: 32rpx 0 24rpx;
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 4rpx;
  position: relative;
}

.header-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light));
  border-radius: 3rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--color-text-light);
  margin-top: 16rpx;
}

.batch-toggle-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 12rpx 24rpx;
  background: var(--color-secondary);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.batch-toggle-btn:active {
  opacity: 0.8;
}

/* ========== 分类列表区域 ========== */
.category-list-container {
  position: relative;
  z-index: 1;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.title-icon {
  font-size: 36rpx;
}

.category-count {
  font-size: 28rpx;
  color: var(--color-text-muted);
  font-weight: 400;
}

.sort-group {
  display: flex;
  gap: 12rpx;
}

/* 排序胶囊 */
.sort-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: var(--color-secondary);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
  transition: all 0.3s ease;
}

.sort-pill.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
}

.sort-pill:active {
  transform: scale(0.95);
}

.sort-pill .sort-arrow {
  font-size: 20rpx;
  color: var(--color-accent);
  transition: transform 0.3s ease;
}

.sort-pill.active .sort-arrow {
  color: #fff;
}

.sort-pill .sort-arrow.desc {
  transform: rotate(180deg);
}

/* ========== 分类网格 ========== */
.category-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 分类卡片 */
.category-card {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--color-border);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  animation: slideIn 0.4s ease-out backwards;
  animation-delay: var(--delay, 0s);
}

/* 左上角资产数量标记 */
.asset-count-tag {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx 18rpx 18rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(74, 124, 89, 0.3);
  z-index: 1;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.category-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.category-card.selected {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, rgba(74, 124, 89, 0.12) 0%, rgba(74, 124, 89, 0.06) 100%);
  box-shadow: 0 0 0 4rpx rgba(74, 124, 89, 0.15);
}

.category-card.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.card-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
  min-width: 0;
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-secondary) 0%, #FDF5EB 100%);
  border-radius: 24rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(74, 124, 89, 0.1);
}

.category-icon-img {
  width: 64rpx;
  height: 64rpx;
  object-fit: contain;
}

.category-emoji {
  font-size: 48rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-count-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 20rpx;
}

.category-date {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.category-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 卡片底部描述 */
.card-footer {
  width: 100%;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.card-footer .category-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.9);
}

.action-btn.edit {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.action-btn.delete {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.action-btn.move {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  font-size: 24rpx;
  font-weight: bold;
  color: #1976D2;
}

.action-btn.info {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

/* 选择指示器 */
.selection-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  font-size: 28rpx;
  color: #fff;
}

.checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.checkbox.disabled {
  background: var(--color-secondary);
  border-color: var(--color-border);
}

/* 空状态 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--color-border);
}

.empty-illustration {
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  text-align: center;
}

/* ========== 添加按钮区域 ========== */
.add-category-section {
  position: fixed;
  bottom: 48rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 100;
}

.add-btn-wrap {
  position: relative;
}

.add-btn {
  padding: 8rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 60rpx;
  box-shadow: 0 12rpx 32rpx rgba(74, 124, 89, 0.35);
  transition: all 0.3s ease;
}

.add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(74, 124, 89, 0.25);
}

.add-btn-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
  border-radius: 56rpx;
}

.add-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.add-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 2rpx;
}

/* 批量操作栏 */
.batch-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 16rpx;
}

.batch-action-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  white-space: nowrap;
}

.batch-icon {
  font-size: 32rpx;
}

.batch-text {
  font-size: 28rpx;
  white-space: nowrap;
}

.batch-action-btn.select-all {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  color: var(--color-primary);
  border: 2rpx solid rgba(74, 124, 89, 0.2);
}

.batch-action-btn.select-all:active {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.batch-action-btn.delete {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
  color: #B0BEC5;
  border: 2rpx solid transparent;
}

.batch-action-btn.delete.active {
  background: linear-gradient(135deg, var(--color-danger) 0%, #EF5350 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(229, 115, 115, 0.4);
}

.batch-action-btn.delete.active .batch-icon {
  animation: shake 0.3s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4rpx); }
  75% { transform: translateX(4rpx); }
}

.batch-action-btn:active {
  transform: scale(0.97);
}

/* ========== 详情弹窗样式 ========== */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 61, 61, 0.5);
  backdrop-filter: blur(8rpx);
  z-index: 1100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.detail-mask.show {
  opacity: 1;
  visibility: visible;
}

.detail-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 92%;
  max-width: 640rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  z-index: 1101;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.detail-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--color-border);
  position: relative;
}

.detail-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-secondary) 0%, #FDF5EB 100%);
  border-radius: 20rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.detail-icon-img {
  width: 56rpx;
  height: 56rpx;
  object-fit: contain;
}

.detail-emoji {
  font-size: 44rpx;
}

.detail-title-wrap {
  flex: 1;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-muted);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.detail-close:active {
  background: var(--color-secondary);
}

.detail-body {
  padding: 32rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 30rpx;
  color: var(--color-text);
}

.detail-value.desc {
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

.detail-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 2rpx solid var(--color-border);
}

.detail-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.detail-btn::after {
  border: none;
}

.detail-btn.edit {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
}

.detail-btn.delete {
  background: linear-gradient(135deg, var(--color-danger) 0%, #EF5350 100%);
  color: #fff;
}

.detail-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== 弹窗样式 ========== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 61, 61, 0.5);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.dialog-mask.show {
  opacity: 1;
  visibility: visible;
}

.dialog-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8) translateY(0);
  width: 92%;
  max-width: 680rpx;
  max-height: 85vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.dialog-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1) translateY(0);
}

.dialog-content {
  display: flex;
  flex-direction: column;
  max-height: 85vh;
  overflow: hidden;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 28rpx;
  border-bottom: 2rpx solid var(--color-border);
  flex-shrink: 0;
}

.dialog-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dialog-emoji {
  font-size: 44rpx;
}

.dialog-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text);
}

.dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-muted);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.dialog-close:active {
  background: var(--color-secondary);
  color: var(--color-text);
}

.dialog-form {
  padding: 32rpx;
  overflow-x: hidden;
  box-sizing: border-box;
  overflow-y: auto;
  flex: 1;
}

/* 表单项 */
.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
}

.required {
  color: var(--color-danger);
  font-size: 28rpx;
  font-weight: bold;
}

.input-wrap {
  position: relative;
}

.item-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--color-secondary);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  color: var(--color-text);
  box-sizing: border-box;
  transition: background 0.3s ease, border-color 0.3s ease;
  display: flex;
  align-items: center;
}

.item-input:focus {
  background: #fff;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(74, 124, 89, 0.1);
}

.input-placeholder {
  font-size: 30rpx;
  color: var(--color-text-muted);
  padding-top: 2rpx;
}

.item-textarea {
  width: 100%;
  height: 220rpx;
  padding: 30rpx 28rpx;
  background: var(--color-secondary);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  color: var(--color-text);
  box-sizing: border-box;
  transition: background 0.3s ease, border-color 0.3s ease;
  line-height: 1.5;
}

.item-textarea:focus {
  background: #fff;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(74, 124, 89, 0.1);
}

.textarea-placeholder {
  font-size: 30rpx;
  color: var(--color-text-muted);
}

/* 图标选择器 */
.icon-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 自定义图标区域：左右分布 */
.custom-icon-row {
  display: flex;
  gap: 20rpx;
}

.upload-box {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-secondary);
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.upload-box.has-image {
  padding: 24rpx;
  border-style: solid;
  border-color: var(--color-primary);
}

/* 自定义emoji输入区域 */
.emoji-input-box {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  border: 3rpx dashed var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-secondary);
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.emoji-input-box:active {
  background: #FDF5EB;
  border-color: var(--color-primary);
}

.emoji-input-box.has-emoji {
  padding: 24rpx;
  border-style: solid;
  border-color: var(--color-primary);
}

.emoji-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.emoji-icon {
  font-size: 48rpx;
}

.emoji-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.emoji-hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.emoji-preview {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.preview-emoji {
  font-size: 48rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-secondary);
  border-radius: var(--radius-sm);
}

.icon-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.icon-option:active {
  transform: scale(0.95);
}

.icon-option.selected {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  box-shadow: 0 4rpx 16rpx rgba(74, 124, 89, 0.2);
}

.icon-emoji {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.icon-name {
  font-size: 20rpx;
  color: var(--color-text-light);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.upload-box:active {
  background: #FDF5EB;
  border-color: var(--color-primary);
}

.upload-box.has-image {
  padding: 24rpx;
  border-style: solid;
  border-color: var(--color-primary);
}

/* 右上角删除按钮 */
.delete-corner-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--color-danger);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(229, 115, 115, 0.4);
  z-index: 10;
}

.delete-corner-btn:active {
  opacity: 0.8;
  transform: scale(0.9);
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.upload-icon {
  font-size: 64rpx;
}

.upload-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.upload-hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.upload-preview {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.upload-box.has-image:active .preview-overlay {
  opacity: 1;
}

.preview-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

/* 弹窗底部按钮 */
.dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 2rpx solid var(--color-border);
  flex-shrink: 0;
}

.dialog-btn {
  flex: 1;
  height: 96rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn.cancel {
  background: var(--color-secondary);
  color: var(--color-text-light);
}

.dialog-btn.cancel:active {
  background: #E8E0D8;
  transform: scale(0.98);
}

.dialog-btn.confirm {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
}

.dialog-btn.confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== Emoji输入弹窗样式 ========== */
.emoji-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 61, 61, 0.5);
  backdrop-filter: blur(8rpx);
  z-index: 1200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.emoji-dialog-mask.show {
  opacity: 1;
  visibility: visible;
}

.emoji-dialog-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 92%;
  max-width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  z-index: 1201;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.emoji-dialog-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.emoji-dialog-content {
  display: flex;
  flex-direction: column;
}

.emoji-dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.emoji-dialog-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.emoji-dialog-emoji {
  font-size: 40rpx;
}

.emoji-dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.emoji-dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-muted);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.emoji-dialog-close:active {
  background: var(--color-secondary);
  color: var(--color-text);
}

.emoji-dialog-body {
  padding: 32rpx;
}

.emoji-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: var(--radius-sm);
  margin-bottom: 24rpx;
}

.emoji-tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.emoji-tip-text {
  font-size: 26rpx;
  color: var(--color-text-light);
  line-height: 1.5;
  flex: 1;
}

.emoji-input-wrap {
  margin-bottom: 24rpx;
}

.emoji-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: var(--color-secondary);
  border: 2rpx solid transparent;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  color: var(--color-text);
  box-sizing: border-box;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
}

.emoji-input:focus {
  background: #fff;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(74, 124, 89, 0.1);
}

.emoji-input::placeholder {
  color: var(--color-text-muted);
}

.emoji-examples {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--color-secondary);
  border-radius: var(--radius-sm);
}

.emoji-examples-label {
  font-size: 26rpx;
  color: var(--color-text-muted);
  white-space: nowrap;
  flex-shrink: 0;
}

.emoji-example {
  font-size: 40rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.emoji-example:active {
  background: #fff;
  transform: scale(1.1);
}

.emoji-dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 2rpx solid var(--color-border);
}

.emoji-dialog-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.emoji-dialog-btn::after {
  border: none;
}

.emoji-dialog-btn.cancel {
  background: var(--color-secondary);
  color: var(--color-text-light);
}

.emoji-dialog-btn.cancel:active {
  background: #E8E0D8;
  transform: scale(0.98);
}

.emoji-dialog-btn.confirm {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
}

.emoji-dialog-btn.confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}