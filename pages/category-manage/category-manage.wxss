/* category-manage.wxss - 中性优先配色 */

/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  position: relative;
}

/* 装饰性背景 - 移除 */
.bg-decoration {
  display: none;
}

/* ========== 页面头部 ========== */
.page-header {
  position: relative;
  z-index: 1;
  padding: 32rpx 0 24rpx;
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 4rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #555555;
  margin-top: 16rpx;
}

.batch-toggle-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 12rpx 24rpx;
  background: #E5E5E5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  border: 1rpx solid #CCCCCC;
}

.batch-toggle-btn:active {
  background: #E5E5E5;
}

/* ========== 分类列表区域 ========== */
.category-list-container {
  position: relative;
  z-index: 1;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.title-icon {
  font-size: 36rpx;
}

.category-count {
  font-size: 28rpx;
  color: #888888;
  font-weight: 400;
}

.sort-group {
  display: flex;
  gap: 12rpx;
}

/* 排序胶囊 */
.sort-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #E5E5E5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #555555;
  transition: all 0.2s ease;
  border: 1rpx solid #CCCCCC;
}

.sort-pill.active {
  background: #333333;
  color: #FFFFFF;
  border-color: #333333;
}

.sort-pill:active {
  transform: scale(0.95);
}

.sort-pill .sort-arrow {
  font-size: 20rpx;
  color: #888888;
  transition: transform 0.2s ease;
}

.sort-pill.active .sort-arrow {
  color: #FFFFFF;
}

.sort-pill .sort-arrow.desc {
  transform: rotate(180deg);
}

/* ========== 分类网格 ========== */
.category-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 分类卡片 */
.category-card {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(30, 42, 54, 0.04);
  border: 1rpx solid #CCCCCC;
  transition: all 0.2s ease;
}

/* 左上角资产数量标记 */
.asset-count-tag {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: #333333;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx 18rpx 18rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.category-card:active {
  transform: scale(0.98);
}

.category-card.selected {
  border-color: #333333;
  background: #E5E5E5;
}

.category-card.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.card-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
  min-width: 0;
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E5E5E5;
  border-radius: 12rpx;
}

.category-icon-img {
  width: 64rpx;
  height: 64rpx;
  object-fit: contain;
}

.category-emoji {
  font-size: 48rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.category-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-count-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: #333333;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 12rpx;
}

.category-date {
  font-size: 24rpx;
  color: #888888;
}

.category-desc {
  font-size: 24rpx;
  color: #555555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 卡片底部描述 */
.card-footer {
  width: 100%;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #CCCCCC;
}

.card-footer .category-desc {
  font-size: 24rpx;
  color: #555555;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.9);
}

.action-btn.edit {
  background: #E7F5F1;
}

.action-btn.delete {
  background: #FBECEC;
}

.action-btn.move {
  background: #E5E5E5;
  font-size: 24rpx;
  font-weight: bold;
  color: #333333;
}

.action-btn.info {
  background: #FFF6E9;
}

/* 选择指示器 */
.selection-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  font-size: 28rpx;
  color: #FFFFFF;
  background: #FFFFFF;
}

.checkbox.checked {
  background: #333333;
  border-color: #333333;
}

.checkbox.disabled {
  background: #E5E5E5;
  border-color: #CCCCCC;
}

/* 空状态 */
.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx dashed #CCCCCC;
}

.empty-illustration {
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
}

/* ========== 添加按钮区域 ========== */
.add-category-section {
  position: fixed;
  bottom: 48rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 100;
}

.add-btn-wrap {
  position: relative;
}

.add-btn {
  padding: 8rpx;
  background: #333333;
  border-radius: 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(47, 94, 138, 0.2);
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.95);
}

.add-btn-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  background: #FFFFFF;
  border-radius: 56rpx;
}

.add-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #333333;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.add-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 2rpx;
}

/* 批量操作栏 */
.batch-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 16rpx;
}

.batch-action-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  padding: 0 24rpx;
  white-space: nowrap;
}

.batch-icon {
  font-size: 32rpx;
}

.batch-text {
  font-size: 28rpx;
  white-space: nowrap;
}

.batch-action-btn.select-all {
  background: #E5E5E5;
  color: #333333;
  border: 1rpx solid #CCCCCC;
}

.batch-action-btn.select-all:active {
  background: #E5E5E5;
}

.batch-action-btn.delete {
  background: #E5E5E5;
  color: #888888;
  border: 1rpx solid #CCCCCC;
}

.batch-action-btn.delete.active {
  background: #CF1322;
  color: #FFFFFF;
  border-color: #CF1322;
}

.batch-action-btn:active {
  transform: scale(0.97);
}

/* ========== 详情弹窗样式 ========== */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 42, 54, 0.5);
  z-index: 1100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.detail-mask.show {
  opacity: 1;
  visibility: visible;
}

.detail-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 92%;
  max-width: 640rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  z-index: 1101;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(30, 42, 54, 0.15);
}

.detail-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #CCCCCC;
  position: relative;
}

.detail-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E5E5E5;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.detail-icon-img {
  width: 56rpx;
  height: 56rpx;
  object-fit: contain;
}

.detail-emoji {
  font-size: 44rpx;
}

.detail-title-wrap {
  flex: 1;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #888888;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.detail-close:active {
  background: #E5E5E5;
}

.detail-body {
  padding: 32rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 30rpx;
  color: #1A1A1A;
}

.detail-value.desc {
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

.detail-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid #CCCCCC;
}

.detail-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.detail-btn::after {
  border: none;
}

.detail-btn.edit {
  background: #333333;
  color: #FFFFFF;
}

.detail-btn.delete {
  background: #CF1322;
  color: #FFFFFF;
}

.detail-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== 弹窗样式 ========== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 42, 54, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.dialog-mask.show {
  opacity: 1;
  visibility: visible;
}

.dialog-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8) translateY(0);
  width: 92%;
  max-width: 680rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 16rpx;
  z-index: 1001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(30, 42, 54, 0.15);
}

.dialog-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1) translateY(0);
}

.dialog-content {
  display: flex;
  flex-direction: column;
  max-height: 85vh;
  overflow: hidden;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 28rpx;
  border-bottom: 1rpx solid #CCCCCC;
  flex-shrink: 0;
}

.dialog-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dialog-emoji {
  font-size: 44rpx;
}

.dialog-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #888888;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.dialog-close:active {
  background: #E5E5E5;
  color: #1A1A1A;
}

.dialog-form {
  padding: 32rpx;
  overflow-x: hidden;
  box-sizing: border-box;
  overflow-y: auto;
  flex: 1;
}

/* 表单项 */
.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
}

.required {
  color: #CF1322;
  font-size: 28rpx;
  font-weight: bold;
}

.input-wrap {
  position: relative;
}

.item-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: #E5E5E5;
  border: 1rpx solid #CCCCCC;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  transition: background 0.2s ease, border-color 0.2s ease;
  display: flex;
  align-items: center;
}

.item-input:focus {
  background: #FFFFFF;
  border-color: #555555;
}

.input-placeholder {
  font-size: 30rpx;
  color: #888888;
  padding-top: 2rpx;
}

.item-textarea {
  width: 100%;
  height: 220rpx;
  padding: 30rpx 28rpx;
  background: #E5E5E5;
  border: 1rpx solid #CCCCCC;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  transition: background 0.2s ease, border-color 0.2s ease;
  line-height: 1.5;
}

.item-textarea:focus {
  background: #FFFFFF;
  border-color: #555555;
}

.textarea-placeholder {
  font-size: 30rpx;
  color: #888888;
}

/* 图标选择器 */
.icon-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 自定义图标区域：左右分布 */
.custom-icon-row {
  display: flex;
  gap: 20rpx;
}

.upload-box {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  border: 1rpx dashed #CCCCCC;
  border-radius: 12rpx;
  background: #E5E5E5;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.upload-box.has-image {
  padding: 24rpx;
  border-style: solid;
  border-color: #333333;
}

/* 自定义emoji输入区域 */
.emoji-input-box {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  border: 1rpx dashed #CCCCCC;
  border-radius: 12rpx;
  background: #E5E5E5;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.emoji-input-box:active {
  background: #FFFFFF;
  border-color: #555555;
}

.emoji-input-box.has-emoji {
  padding: 24rpx;
  border-style: solid;
  border-color: #333333;
}

.emoji-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.emoji-icon {
  font-size: 48rpx;
}

.emoji-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.emoji-hint {
  font-size: 22rpx;
  color: #888888;
}

.emoji-preview {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.preview-emoji {
  font-size: 48rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 20rpx;
  background: #E5E5E5;
  border-radius: 12rpx;
}

.icon-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid #CCCCCC;
  transition: all 0.2s ease;
}

.icon-option:active {
  transform: scale(0.95);
}

.icon-option.selected {
  border-color: #333333;
  background: #E5E5E5;
}

.icon-emoji {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.icon-name {
  font-size: 20rpx;
  color: #555555;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.upload-box:active {
  background: #FFFFFF;
  border-color: #555555;
}

/* 右上角删除按钮 */
.delete-corner-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: #CF1322;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  z-index: 10;
}

.delete-corner-btn:active {
  opacity: 0.8;
  transform: scale(0.9);
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.upload-icon {
  font-size: 64rpx;
}

.upload-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.upload-hint {
  font-size: 22rpx;
  color: #888888;
}

.upload-preview {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 42, 54, 0.4);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.upload-box.has-image:active .preview-overlay {
  opacity: 1;
}

.preview-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 弹窗底部按钮 */
.dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid #CCCCCC;
  flex-shrink: 0;
}

.dialog-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.2s ease;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn.cancel {
  background: #E5E5E5;
  color: #555555;
}

.dialog-btn.cancel:active {
  background: #E5E5E5;
  transform: scale(0.98);
}

.dialog-btn.confirm {
  background: #333333;
  color: #FFFFFF;
}

.dialog-btn.confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== Emoji输入弹窗样式 ========== */
.emoji-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 42, 54, 0.5);
  z-index: 1200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
}

.emoji-dialog-mask.show {
  opacity: 1;
  visibility: visible;
}

.emoji-dialog-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 92%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  z-index: 1201;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(30, 42, 54, 0.15);
}

.emoji-dialog-container.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

