<wxs module="utils">
function formatDate(timestamp) {
  if (!timestamp) return '';
  var date = getDate(timestamp);
  var month = date.getMonth() + 1;
  var day = date.getDate();
  var hour = date.getHours();
  var minute = date.getMinutes();
  var second = date.getSeconds();
  var pad = function(n) {
    return n < 10 ? '0' + n : n;
  };
  return month + '月' + day + '日 ' + pad(hour) + ':' + pad(minute) + ':' + pad(second);
}
module.exports = {
  formatDate: formatDate
};
</wxs>

<!-- category-manage.wxml -->
<view class="container">
  <!-- 装饰性背景元素 -->
  <view class="bg-decoration">
    <view class="leaf leaf-1">🌿</view>
    <view class="leaf leaf-2">🍃</view>
    <view class="leaf leaf-3">🌱</view>
    <view class="bubble bubble-1"></view>
    <view class="bubble bubble-2"></view>
  </view>

  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">分类管理</text>
      <text class="header-subtitle">整理你的资产分类</text>
    </view>
    <!-- 批量操作按钮 -->
    <view class="batch-toggle-btn" bindtap="toggleBatchMode">
      <text>{{batchMode ? '取消' : '批量管理'}}</text>
    </view>
  </view>

  <!-- 分类列表 -->
  <view class="category-list-container">
    <view class="section-title-row">
      <view class="section-title">
        <text class="title-icon">🏷️</text>
        <text>资产分类</text>
        <text class="category-count">({{categories.length}})</text>
      </view>
      <view class="sort-group">
        <view class="sort-pill {{currentSortIndex === -1 ? 'active' : ''}}" bindtap="resetToCustomSort">
          <text>自定义</text>
        </view>
        <view class="sort-pill {{currentSortIndex === 0 ? 'active' : ''}}" bindtap="changeSortByName">
          <text>名称</text>
          <text class="sort-arrow {{currentSortIndex === 0 && sortOrder === 'desc' ? 'desc' : ''}}">↑</text>
        </view>
        <view class="sort-pill {{currentSortIndex === 1 ? 'active' : ''}}" bindtap="changeSortByTime">
          <text>创建时间</text>
          <text class="sort-arrow {{currentSortIndex === 1 && sortOrder === 'desc' ? 'desc' : ''}}">↑</text>
        </view>
      </view>
    </view>

    <view class="category-grid">
      <view
        class="category-card {{item._selected ? 'selected' : ''}} {{batchMode && item.assetCount > 0 ? 'disabled' : ''}}"
        wx:for="{{categories}}"
        wx:key="_id"
        style="--delay: {{index * 0.05}}s"
        bindtap="{{batchMode && !item.assetCount ? 'toggleCategorySelection' : ''}}"
        data-id="{{item._id}}"
        data-index="{{index}}"
      >
        <!-- 左上角资产数量标记 -->
        <view class="asset-count-tag" wx:if="{{item.assetCount > 0}}">{{item.assetCount}}</view>

        <view class="card-content">
          <view class="category-icon-wrap">
            <image wx:if="{{item.displayIcon}}" src="{{item.displayIcon}}" mode="aspectFit" class="category-icon-img"></image>
            <text wx:else class="category-emoji">{{item.icon || '📦'}}</text>
          </view>
          <view class="category-info">
            <text class="category-name">{{item.name}}</text>
            <text class="category-date" wx:if="{{item.createdAt}}">{{utils.formatDate(item.createdAt)}}</text>
          </view>
        </view>
        <view class="card-actions" wx:if="{{!batchMode}}">
          <view class="action-btn info" catchtap="showCategoryDetail" data-index="{{index}}" data-id="{{item._id}}">
            <text>📋</text>
          </view>
          <view class="action-btn move" catchtap="moveUpCategory" data-index="{{index}}" wx:if="{{index > 0}}">
            <text>↑</text>
          </view>
          <view class="action-btn move" catchtap="moveDownCategory" data-index="{{index}}" wx:if="{{index < categories.length - 1}}">
            <text>↓</text>
          </view>
          <view class="action-btn edit" catchtap="editCategory" data-index="{{index}}" data-id="{{item._id}}">
            <text>✏️</text>
          </view>
          <view class="action-btn delete" catchtap="deleteCategory" data-index="{{index}}" data-id="{{item._id}}">
            <text>🗑️</text>
          </view>
        </view>

        <!-- 批量选择指示器 -->
        <view class="selection-indicator" wx:if="{{batchMode}}">
          <view class="checkbox {{item._selected ? 'checked' : ''}} {{item.assetCount > 0 ? 'disabled' : ''}}">
            <text wx:if="{{item._selected}}">✓</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{categories.length === 0}}" class="empty-card">
        <view class="empty-illustration">
          <text class="empty-icon">🌱</text>
        </view>
        <text class="empty-title">还没有分类</text>
        <text class="empty-desc">点击下方按钮添加第一个分类吧</text>
      </view>
    </view>
  </view>

  <!-- 添加分类按钮 -->
  <view class="add-category-section">
    <!-- 批量操作模式 -->
    <view class="batch-actions" wx:if="{{batchMode}}">
      <view class="batch-action-btn select-all" bindtap="toggleSelectAll">
        <text class="batch-icon">☑️</text>
        <text class="batch-text">{{selectedCategoryIds.length > 0 ? '取消全选' : '全选'}}</text>
      </view>
      <view class="batch-action-btn delete {{selectedCategoryIds.length > 0 ? 'active' : ''}}" bindtap="batchDeleteCategories">
        <text class="batch-icon">🗑️</text>
        <text class="batch-text">删除{{selectedCategoryIds.length > 0 ? ' (' + selectedCategoryIds.length + ')' : ''}}</text>
      </view>
    </view>
    <!-- 正常模式 -->
    <view class="add-btn-wrap" wx:else>
      <view class="add-btn" bindtap="addCategory">
        <view class="add-btn-inner">
          <text class="add-icon">+</text>
          <text class="add-text">添加新分类</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 自定义弹窗 -->
<view class="dialog-mask {{dialogVisible ? 'show' : ''}}" bindtap="closeDialog"></view>
<view class="dialog-container {{dialogVisible ? 'show' : ''}}">
  <view class="dialog-content">
    <!-- 标题 -->
    <view class="dialog-header">
      <view class="dialog-title-wrap">
        <text class="dialog-emoji">{{operationType === 'add' ? '🌱' : '✏️'}}</text>
        <text class="dialog-title">{{dialogTitle}}</text>
      </view>
      <view class="dialog-close" bindtap="closeDialog">✕</view>
    </view>

    <!-- 表单内容 -->
    <view class="dialog-form">
      <!-- 分类名称输入 -->
      <view class="form-item">
        <view class="item-label">
          <text class="label-icon">📝</text>
          <text>分类名称</text>
          <text class="required">*</text>
        </view>
        <view class="input-wrap">
          <input
            class="item-input"
            placeholder="请输入分类名称"
            value="{{tempCategoryName}}"
            bindinput="onCategoryNameInput"
            maxlength="10"
          />
        </view>
      </view>

      <!-- 分类描述输入 -->
      <view class="form-item">
        <view class="item-label">
          <text class="label-icon">📋</text>
          <text>分类描述</text>
        </view>
        <view class="input-wrap">
          <textarea
            class="item-textarea"
            placeholder="请输入分类描述（可选）"
            value="{{tempDescription}}"
            bindinput="onDescriptionInput"
            maxlength="120"
            auto-height
          />
        </view>
      </view>

      <!-- 选择图标 -->
      <view class="form-item">
        <view class="item-label">
          <text class="label-icon">🎨</text>
          <text>选择图标</text>
        </view>

        <view class="icon-selector">
          <!-- 内置图标选择 -->
          <view class="icon-grid">
            <view
              class="icon-option {{selectedIcon == item.icon && !uploadedImagePath ? 'selected' : ''}}"
              wx:for="{{builtinIcons}}"
              wx:key="index"
              bindtap="selectBuiltinIcon"
              data-icon="{{item}}"
            >
              <text class="icon-emoji">{{item.icon}}</text>
              <text class="icon-name">{{item.name}}</text>
            </view>
          </view>

          <!-- 上传自定义图标 -->
          <view class="upload-box {{uploadedImagePath ? 'has-image' : ''}}" bindtap="chooseImage">
            <view wx:if="{{!uploadedImagePath}}" class="upload-placeholder">
              <text class="upload-icon">📷</text>
              <text class="upload-text">上传自定义图标</text>
              <text class="upload-hint">支持jpg/png，不超过2M</text>
            </view>
            <view wx:else class="upload-preview">
              <image class="preview-img" src="{{uploadedImagePath}}" mode="aspectFill"></image>
              <view class="preview-overlay">
                <text class="preview-text">点击更换</text>
              </view>
            </view>
          </view>

          <!-- 已上传图片删除 -->
          <view class="remove-btn" wx:if="{{uploadedImagePath}}" bindtap="removeUploadedImage">
            <text>删除图片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="dialog-footer">
      <button class="dialog-btn cancel" bindtap="closeDialog">取消</button>
      <button class="dialog-btn confirm" bindtap="confirmCategoryOperation">
        <text>{{operationType === 'add' ? '🌱 添加' : '✨ 保存'}}</text>
      </button>
    </view>
  </view>
</view>

<!-- 分类详情弹窗 -->
<view class="detail-mask {{detailVisible ? 'show' : ''}}" bindtap="closeDetailDialog"></view>
<view class="detail-container {{detailVisible ? 'show' : ''}}">
  <view class="detail-content">
    <!-- 标题 -->
    <view class="detail-header">
      <view class="detail-icon-wrap">
        <image wx:if="{{currentCategory.displayIcon}}" src="{{currentCategory.displayIcon}}" mode="aspectFit" class="detail-icon-img"></image>
        <text wx:else class="detail-emoji">{{currentCategory.icon || '📦'}}</text>
      </view>
      <view class="detail-title-wrap">
        <text class="detail-title">{{currentCategory.name}}</text>
      </view>
      <view class="detail-close" bindtap="closeDetailDialog">✕</view>
    </view>

    <!-- 详情内容 -->
    <view class="detail-body">
      <view class="detail-item">
        <text class="detail-label">创建时间</text>
        <text class="detail-value">{{currentCategory.createdAt ? utils.formatDate(currentCategory.createdAt) : '-'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">资产数量</text>
        <text class="detail-value">{{currentCategory.assetCount || 0}} 个</text>
      </view>
      <view class="detail-item" wx:if="{{currentCategory.description}}">
        <text class="detail-label">分类描述</text>
        <text class="detail-value desc">{{currentCategory.description}}</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="detail-footer">
      <button class="detail-btn edit" bindtap="editFromDetail">
        <text>✏️ 编辑</text>
      </button>
      <button class="detail-btn delete" bindtap="deleteFromDetail" wx:if="{{!currentCategory.assetCount || currentCategory.assetCount === 0}}">
        <text>🗑️ 删除</text>
      </button>
    </view>
  </view>
</view>